# 小猫专注 服务端环境变量模板（腾讯云轻量 VPS / M4）
# 用法：cp server/.env.example server/.env 后填入真实值。
# server/.env 已在 .gitignore，切勿提交真实密钥。
# 进程启动时 index.ts 会优先加载 server/.env，其次根目录 .env。

# ── 运行 ──────────────────────────────────────────────
NODE_ENV=production
# 监听端口；需与 nginx 反代 proxy_pass 的端口一致。
PORT=3000

# ── 数据库（二选一）─────────────────────────────────
# 方式 A：单条连接串（推荐，存在时优先）
DATABASE_URL=mysql://cpa:CHANGE_ME@127.0.0.1:3306/cpa
# 方式 B：分字段（与 A 二选一）
# MYSQL_ADDRESS=127.0.0.1:3306
# MYSQL_USERNAME=cpa
# MYSQL_PASSWORD=CHANGE_ME
# MYSQL_DATABASE=cpa
# 启动时会幂等建表/补列（mysql-bootstrap.ts），无需手动跑 SQL。

# ── 微信登录（M1）+ 每日提醒 ────────────────────────
# 小程序后台 → 开发管理 → 开发设置：AppID / AppSecret
WECHAT_APP_ID=wxfb24f334e5070a82
WECHAT_APP_SECRET=CHANGE_ME
# 会话 token 的 HMAC 密钥：必须 ≥32 字符、高熵。
# 生产环境若 <32 字符服务端会拒绝启动（防 Bearer token 被爆破伪造）。
# 生成：openssl rand -base64 48
SESSION_SECRET=CHANGE_ME_openssl_rand_base64_48

# ── 对象存储 COS（M2）──────────────────────────────
# 腾讯云 访问管理 → API 密钥。建议用子账号 + 仅授权目标 bucket。
# ⚠️ 这两个是密钥，填真实值，切勿提交到 git（server/.env 已 gitignore）。
COS_SECRET_ID=CHANGE_ME
COS_SECRET_KEY=CHANGE_ME
# 桶名/地域/域名非机密，已按本项目实际值填好（上海 · 私有读写）。
COS_BUCKET=xiaomaozhuanzhu-1259551686
COS_REGION=ap-shanghai
# 公网访问基址（签名 GET / 头像渲染用），即 bucket 默认域名。
STORAGE_PUBLIC_BASE_URL=https://xiaomaozhuanzhu-1259551686.cos.ap-shanghai.myqcloud.com
# 注意：VPS 用 COS 存储，请勿设置 WECHAT_CLOUD_ENV —— 它会切回云托管存储模式。

# ── 管理后台（可选）────────────────────────────────
# /admin/api/* 的 Bearer 口令；不设则整个 admin API 返回 503（不泄漏数据）。
# 详见 docs/admin-dashboard.md。
ADMIN_TOKEN=CHANGE_ME

# ── 运维开关：维护 / 强制升级（v0.42，GET /api/app-config）────
# 默认全空 = 正常服务。切换/维护时按需开启，改完重启进程生效。
# 维护态：客户端启动弹「服务维护中」（终态数据同步那一小会儿可开）。
# MAINTENANCE=1
# 低于此版本的客户端弹「请更新」并触发自动更新（切换后排空旧版本用）。
# MIN_CLIENT_VERSION=0.42.0
# 维护/升级弹窗的自定义文案（可选）。
# MAINTENANCE_MESSAGE=服务升级中，预计 10 分钟后恢复
