# Set ADMIN_TOKEN to enable the /admin dashboard (see docs/admin-dashboard.md).
# If unset, /admin/api/* returns 503 so user data is never accidentally exposed.
ADMIN_TOKEN=

# DeepSeek API key for the AI tab (POST /api/ai/ask, see server/src/domain/ai.ts).
# Get one at https://platform.deepseek.com/api_keys. Per-user daily cap is
# enforced server-side (currently 30 questions/day). If unset, /api/ai/ask
# returns 503 so the miniprogram surfaces a friendly "尚未配置" message.
DEEPSEEK_API_KEY=
