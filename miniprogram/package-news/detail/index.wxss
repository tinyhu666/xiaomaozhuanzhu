.news-detail {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Loading dots animation */
.news-detail__loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  padding: 120rpx 0;
}

.news-detail__loading-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--mint-400);
  opacity: 0.4;
  animation: news-detail-pulse 1.2s ease-in-out infinite;
}

.news-detail__loading-dot:nth-child(2) { animation-delay: 0.18s; }
.news-detail__loading-dot:nth-child(3) { animation-delay: 0.36s; }

@keyframes news-detail-pulse {
  0%, 80%, 100% { transform: scale(0.7); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.news-detail__error {
  padding: 80rpx 36rpx;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(229, 123, 123, 0.06);
  border: 1rpx dashed rgba(229, 123, 123, 0.32);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.news-detail__error-icon {
  font-size: 64rpx;
  margin-bottom: 10rpx;
  line-height: 1;
}

.news-detail__error-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.news-detail__error-text {
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.6;
  letter-spacing: 0.2rpx;
}

/* Article head: category pill + date + title + lead summary */
.news-detail__head {
  padding: 30rpx 32rpx 28rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.22), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 10rpx 26rpx -4rpx rgba(46, 169, 133, 0.1);
}

.news-detail__meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.news-detail__cat {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
}

.news-detail__cat--announce { background: rgba(229, 158, 87, 0.18); color: #b56823; }
.news-detail__cat--outline  { background: rgba(94, 116, 200, 0.18); color: #3a4a92; }
.news-detail__cat--news     { background: rgba(46, 169, 133, 0.18); color: #1d7e63; }

.news-detail__date {
  font-size: 22rpx;
  color: var(--text-sub);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.4rpx;
}

.news-detail__title {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1.4;
}

.news-detail__summary {
  margin-top: 14rpx;
  padding-top: 14rpx;
  border-top: 1rpx dashed rgba(46, 169, 133, 0.16);
  font-size: 24rpx;
  color: var(--text-sub);
  line-height: 1.65;
  letter-spacing: 0.2rpx;
}

/* Article body — reading-tuned typography */
.news-detail__body {
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
}

.news-detail__body--placeholder {
  background: rgba(255, 247, 230, 0.6);
  border: 1rpx dashed rgba(229, 158, 87, 0.32);
}

.news-detail__content {
  display: block;
  font-size: 28rpx;
  color: var(--text-main);
  line-height: 1.8;
  letter-spacing: 0.3rpx;
  white-space: pre-wrap;
}

.news-detail__placeholder-text {
  display: block;
  font-size: 24rpx;
  color: #8a5a2b;
  line-height: 1.7;
  letter-spacing: 0.3rpx;
}

.news-detail__cta {
  width: 100%;
}

.news-detail__source {
  text-align: center;
  font-size: 20rpx;
  color: rgba(94, 125, 117, 0.55);
  letter-spacing: 0.5rpx;
  margin-top: 4rpx;
}
