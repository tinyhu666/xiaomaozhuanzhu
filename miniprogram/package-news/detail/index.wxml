<view class="page-shell news-detail">
  <view wx:if="{{loading}}" class="news-detail__loading">
    <view class="news-detail__loading-dot"></view>
    <view class="news-detail__loading-dot"></view>
    <view class="news-detail__loading-dot"></view>
  </view>

  <view wx:elif="{{errorMessage && !item}}" class="news-detail__error">
    <view class="news-detail__error-icon">⚠️</view>
    <text class="news-detail__error-title">加载失败</text>
    <text class="news-detail__error-text">{{errorMessage}}</text>
  </view>

  <block wx:elif="{{item}}">
    <view class="news-detail__head">
      <view class="news-detail__meta">
        <text class="news-detail__cat news-detail__cat--{{item.category}}">{{categoryLabel}}</text>
        <text class="news-detail__date">{{dateText}}</text>
      </view>
      <view class="news-detail__title">{{item.title}}</view>
      <view wx:if="{{item.summary}}" class="news-detail__summary">{{item.summary}}</view>
    </view>

    <view wx:if="{{item.content}}" class="news-detail__body">
      <text class="news-detail__content">{{item.content}}</text>
    </view>
    <view wx:else class="news-detail__body news-detail__body--placeholder">
      <text class="news-detail__placeholder-text">完整内容请通过下方按钮复制链接，在浏览器中查看官方原文。</text>
    </view>

    <button class="ghost-button news-detail__cta" bindtap="onCopyLink">复制原文链接</button>

    <view class="news-detail__source">来源标识：{{item.source}}</view>
  </block>
</view>
