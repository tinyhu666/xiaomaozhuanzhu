.garden-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* Staggered fade-up so the page composes itself top-down. */
@keyframes garden-fade-up {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.garden-page > view,
.garden-page > .garden-foot {
  animation: garden-fade-up 0.42s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.garden-page > view:nth-child(1) { animation-delay: 0.04s; }
.garden-page > view:nth-child(2) { animation-delay: 0.1s; }
.garden-page > .garden-foot { animation-delay: 0.16s; }

/* ============================================================
   Hero — title + total count + rarity filter chips.
   ============================================================ */
.garden-hero {
  padding: 26rpx 28rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.2), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f6fbf8 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 10rpx 26rpx -4rpx rgba(46, 169, 133, 0.08);
}

.garden-hero__title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.garden-hero__title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.garden-hero__actions {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.garden-hero__count {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 0.4rpx;
  font-feature-settings: "tnum" 1;
}

.garden-hero__share {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  box-shadow: 0 4rpx 12rpx rgba(46, 169, 133, 0.28);
  transition: transform 0.16s ease;
}

.garden-hero__share--hover {
  transform: scale(0.94);
}

.garden-hero__chips {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.rarity-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.3rpx;
  border: 1rpx solid transparent;
  background: rgba(46, 169, 133, 0.06);
  color: var(--text-sub);
  transition: all 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.rarity-chip:active { transform: scale(0.96); }

.rarity-chip__label { font-weight: 700; }
.rarity-chip__count {
  font-weight: 800;
  font-feature-settings: "tnum" 1;
  opacity: 0.7;
}

/* Active state — chip picks up the rarity color */
.rarity-chip.is-active.rarity-chip--all       { background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%); color: #fff; box-shadow: 0 4rpx 12rpx rgba(46, 169, 133, 0.28); }
.rarity-chip.is-active.rarity-chip--legendary { background: linear-gradient(135deg, #ffd86b 0%, #f0a93b 100%); color: #5a3a05; box-shadow: 0 4rpx 12rpx rgba(240, 169, 59, 0.32); }
.rarity-chip.is-active.rarity-chip--epic      { background: linear-gradient(135deg, #ffb86b 0%, #e57b2b 100%); color: #fff; box-shadow: 0 4rpx 12rpx rgba(229, 123, 43, 0.28); }
.rarity-chip.is-active.rarity-chip--rare      { background: linear-gradient(135deg, #8aa6f0 0%, #4a6ed9 100%); color: #fff; box-shadow: 0 4rpx 12rpx rgba(74, 110, 217, 0.28); }
.rarity-chip.is-active.rarity-chip--common    { background: rgba(94, 125, 117, 0.2); color: var(--text-main); }

/* ============================================================
   Cat grid — 5 columns of evenly-sized cards.
   ============================================================ */
@keyframes cat-pop {
  from { opacity: 0; transform: scale(0.7) translateY(8rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.garden-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
}

.cat-card {
  position: relative;
  aspect-ratio: 1 / 1.15;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 4rpx 12rpx -3rpx rgba(46, 169, 133, 0.06);
  animation: cat-pop 0.42s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  transition: transform 0.16s ease;
}

/* Stagger the cards so they pop in with a wave instead of all at
   once. First ~25 get explicit delays; beyond that they share the
   last delay so heavy scrolling doesn't cause perceptible waits. */
.cat-card:nth-child(1) { animation-delay: 0.04s; }
.cat-card:nth-child(2) { animation-delay: 0.07s; }
.cat-card:nth-child(3) { animation-delay: 0.1s; }
.cat-card:nth-child(4) { animation-delay: 0.13s; }
.cat-card:nth-child(5) { animation-delay: 0.16s; }
.cat-card:nth-child(6) { animation-delay: 0.19s; }
.cat-card:nth-child(7) { animation-delay: 0.22s; }
.cat-card:nth-child(8) { animation-delay: 0.25s; }
.cat-card:nth-child(9) { animation-delay: 0.28s; }
.cat-card:nth-child(10) { animation-delay: 0.31s; }
.cat-card:nth-child(n+11) { animation-delay: 0.34s; }

.cat-card--hover { transform: scale(0.94); }

/* Rarity-specific frames */
.cat-card--common {
  /* no extra decoration */
}

.cat-card--rare {
  border-color: rgba(74, 110, 217, 0.3);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 0 16rpx -2rpx rgba(74, 110, 217, 0.22),
    0 4rpx 12rpx -3rpx rgba(74, 110, 217, 0.16);
}

.cat-card--epic {
  border-color: rgba(229, 123, 43, 0.4);
  background:
    linear-gradient(180deg, #fff8ec 0%, #ffe6c0 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 0 18rpx -2rpx rgba(229, 123, 43, 0.32),
    0 6rpx 14rpx -3rpx rgba(229, 123, 43, 0.22);
}

.cat-card--legendary {
  border-color: rgba(240, 169, 59, 0.55);
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 216, 107, 0.4), transparent 60%),
    linear-gradient(180deg, #fff6dc 0%, #ffd86b 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
    0 0 22rpx -2rpx rgba(240, 169, 59, 0.5),
    0 6rpx 16rpx -3rpx rgba(240, 169, 59, 0.3);
}

.cat-card__emoji {
  font-size: 48rpx;
  line-height: 1;
}

.cat-card__accessory {
  font-size: 16rpx;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
  margin-top: 2rpx;
}

.cat-card--epic .cat-card__accessory,
.cat-card--legendary .cat-card__accessory {
  color: #7a4310;
}

.cat-card__star {
  position: absolute;
  top: 6rpx;
  right: 8rpx;
  font-size: 18rpx;
  line-height: 1;
  filter: drop-shadow(0 1rpx 2rpx rgba(0,0,0,0.12));
}

.cat-card__crown {
  position: absolute;
  top: 4rpx;
  right: 6rpx;
  font-size: 22rpx;
  line-height: 1;
  filter: drop-shadow(0 1rpx 2rpx rgba(0,0,0,0.16));
}

/* ============================================================
   Skeleton + empty states.
   ============================================================ */
.garden-skeleton {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12rpx;
}

@keyframes garden-shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.garden-skeleton__cell {
  aspect-ratio: 1 / 1.15;
  border-radius: 18rpx;
  background: linear-gradient(90deg,
    rgba(46, 169, 133, 0.06) 0%,
    rgba(46, 169, 133, 0.14) 50%,
    rgba(46, 169, 133, 0.06) 100%);
  background-size: 200% 100%;
  animation: garden-shimmer 1.4s linear infinite;
}

.garden-empty {
  padding: 60rpx 36rpx 70rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx dashed rgba(46, 169, 133, 0.2);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.garden-empty--error {
  background: rgba(229, 123, 123, 0.06);
  border-color: rgba(229, 123, 123, 0.32);
}

.garden-empty__icon {
  font-size: 56rpx;
  margin-bottom: 6rpx;
  line-height: 1;
}

.garden-empty__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.garden-empty__text {
  font-size: 22rpx;
  color: var(--text-sub);
  line-height: 1.6;
  letter-spacing: 0.2rpx;
  max-width: 460rpx;
}

.garden-foot {
  display: block;
  margin-top: 8rpx;
  text-align: center;
  font-size: 20rpx;
  color: var(--text-sub);
  opacity: 0.65;
  letter-spacing: 0.3rpx;
}

/* ============================================================
   Detail bottom-sheet — appears on tap.
   ============================================================ */
@keyframes garden-detail-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes garden-detail-slide {
  from { opacity: 0; transform: translateY(40rpx) scale(0.94); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.garden-detail {
  position: fixed;
  inset: 0;
  z-index: 200;
  background: rgba(20, 60, 50, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: garden-detail-fade 0.24s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.garden-detail__card {
  width: 100%;
  max-width: 580rpx;
  position: relative;
  padding: 60rpx 36rpx 28rpx;
  border-radius: 32rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  animation: garden-detail-slide 0.32s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.garden-detail__star {
  position: absolute;
  top: 20rpx;
  right: 28rpx;
  font-size: 36rpx;
  line-height: 1;
}

.garden-detail__crown {
  position: absolute;
  top: 14rpx;
  right: 24rpx;
  font-size: 44rpx;
  line-height: 1;
}

.garden-detail__emoji {
  font-size: 110rpx;
  line-height: 1;
}

.garden-detail__subject {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  margin-top: 4rpx;
}

.garden-detail__meta {
  width: 100%;
  margin-top: 14rpx;
  padding: 14rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(46, 169, 133, 0.06);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.garden-detail__meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.garden-detail__meta-label {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.garden-detail__meta-value {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

.garden-detail__meta-value--legendary { color: #b3700a; }
.garden-detail__meta-value--epic      { color: #c25c1a; }
.garden-detail__meta-value--rare      { color: #3a4a92; }
.garden-detail__meta-value--common    { color: var(--text-main); }

.garden-detail__close {
  margin-top: 18rpx;
  padding: 14rpx 50rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  box-shadow: 0 6rpx 18rpx rgba(46, 169, 133, 0.28);
}

.garden-detail__close:active { transform: scale(0.96); }

/* ============================================================
   Milestone celebration — bigger, more festive than the cat
   detail modal. The huge number is the visual anchor; confetti
   emoji + warm gradient give the moment some weight.
   ============================================================ */
@keyframes garden-milestone-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes garden-milestone-pop {
  0% { opacity: 0; transform: scale(0.7) translateY(40rpx); }
  60% { transform: scale(1.04) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes confetti-bounce {
  0%, 100% { transform: translateY(0) rotate(0); }
  30% { transform: translateY(-14rpx) rotate(-10deg); }
  60% { transform: translateY(-6rpx) rotate(8deg); }
}

@keyframes milestone-number-pop {
  from { transform: scale(0.4); opacity: 0; }
  60% { transform: scale(1.18); opacity: 1; }
  to { transform: scale(1); opacity: 1; }
}

.garden-milestone {
  position: fixed;
  inset: 0;
  z-index: 220;
  background: rgba(20, 60, 50, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: garden-milestone-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.garden-milestone__card {
  width: 100%;
  max-width: 600rpx;
  position: relative;
  padding: 48rpx 36rpx 32rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 216, 107, 0.36), transparent 60%),
    linear-gradient(180deg, #fffaf0 0%, #fff2d5 100%);
  border: 1rpx solid rgba(240, 169, 59, 0.32);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(240, 169, 59, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  animation: garden-milestone-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.garden-milestone__confetti {
  display: flex;
  gap: 18rpx;
  margin-bottom: 8rpx;
}

.garden-milestone__confetti-piece {
  font-size: 44rpx;
  line-height: 1;
  animation: confetti-bounce 1.6s ease-in-out infinite;
}

.garden-milestone__confetti-piece:nth-child(2) {
  animation-delay: 0.2s;
  font-size: 32rpx;
}

.garden-milestone__confetti-piece:nth-child(3) {
  animation-delay: 0.4s;
}

.garden-milestone__number {
  font-size: 144rpx;
  font-weight: 800;
  line-height: 1;
  color: #c2782b;
  font-feature-settings: "tnum" 1;
  letter-spacing: 2rpx;
  text-shadow: 0 6rpx 16rpx rgba(229, 158, 87, 0.32);
  animation: milestone-number-pop 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) 0.15s backwards;
}

.garden-milestone__title {
  font-size: 32rpx;
  font-weight: 800;
  color: #7a4310;
  letter-spacing: 0.5rpx;
  margin-top: 4rpx;
}

.garden-milestone__subtitle {
  font-size: 24rpx;
  color: #8a5320;
  line-height: 1.65;
  letter-spacing: 0.3rpx;
  text-align: center;
  max-width: 460rpx;
  opacity: 0.9;
}

.garden-milestone__close {
  margin-top: 24rpx;
  padding: 16rpx 52rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffd86b 0%, #f0a93b 100%);
  color: #5a3a05;
  font-size: 26rpx;
  font-weight: 800;
  letter-spacing: 0.5rpx;
  box-shadow: 0 6rpx 18rpx rgba(240, 169, 59, 0.34);
}

.garden-milestone__close:active { transform: scale(0.96); }
