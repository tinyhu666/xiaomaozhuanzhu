<view class="page-shell onboarding-page">
  <view class="hero-card">
    <view class="badge">{{mode === 'edit' ? '更新资料' : '首次设置'}}</view>
    <view class="title onboarding-page__title">用微信昵称和头像完成你的学习主页</view>
    <view class="subtitle">只保留必要信息，点一次授权，就能把微信昵称和头像同步到“我的”页面。</view>
  </view>

  <view class="surface-card onboarding-preview">
    <view class="field-label">当前资料预览</view>
    <view class="onboarding-preview__row">
      <image wx:if="{{avatarUrl}}" class="onboarding-preview__avatar" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="onboarding-preview__avatar onboarding-preview__avatar--placeholder">我</view>

      <view class="onboarding-preview__content">
        <text class="onboarding-preview__name">{{nickname || '等待同步微信昵称'}}</text>
        <text class="onboarding-preview__hint">授权后会自动更新头像和昵称</text>
      </view>
    </view>
  </view>

  <button class="cta-button onboarding-page__button" loading="{{saving}}" disabled="{{saving}}" bindtap="authorizeProfile">
    {{mode === 'edit' ? '同步微信昵称头像' : '微信授权并开始使用'}}
  </button>
</view>
