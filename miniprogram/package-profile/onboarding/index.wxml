<view class="page-shell">
  <view class="hero-card">
    <view class="badge">{{mode === 'edit' ? '编辑资料' : '首次设置'}}</view>
    <view class="title" style="margin-top: 18rpx;">给你的学习主页一个清爽的名字</view>
    <view class="subtitle">昵称和头像会显示在你的公开主页里，也会让打卡更有“自己的空间感”。</view>
  </view>

  <view class="surface-card" style="margin-top: 24rpx;">
    <view class="field-label">头像</view>
    <button class="ghost-button" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
      {{avatarUrl ? '重新选择头像' : '选择头像'}}
    </button>
    <image
      wx:if="{{avatarUrl}}"
      src="{{avatarUrl}}"
      mode="aspectFill"
      style="width: 120rpx; height: 120rpx; border-radius: 50%; margin-top: 22rpx;"
    />
  </view>

  <view class="surface-card" style="margin-top: 20rpx;">
    <view class="field-label">昵称</view>
    <input class="text-input" maxlength="20" placeholder="比如：稳稳上岸 CPA" value="{{nickname}}" bindinput="handleNicknameInput" />
  </view>

  <button class="cta-button" style="margin-top: 24rpx;" loading="{{saving}}" bindtap="submit">保存资料</button>
</view>
