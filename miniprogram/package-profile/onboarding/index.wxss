.page-shell {
  padding: 28rpx 28rpx 56rpx;
}

.onboarding-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.onboarding-page__title {
  margin-top: 18rpx;
}

.onboarding-preview {
  margin-top: 0;
}

.onboarding-avatar-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 168rpx;
  height: 168rpx;
  margin: 16rpx 0 0;
  padding: 0;
  border: none;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(99, 203, 168, 0.16) 0%, rgba(46, 169, 133, 0.22) 100%);
  overflow: hidden;
  line-height: normal;
}

.onboarding-avatar-btn__img {
  width: 100%;
  height: 100%;
}

.onboarding-avatar-btn__placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--mint-600);
}

.onboarding-avatar-btn__plus {
  font-size: 56rpx;
  font-weight: 600;
  line-height: 1;
}

.onboarding-avatar-btn__hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.onboarding-preview__nick-label {
  margin-top: 28rpx;
}

.onboarding-page__button {
  width: 100%;
}
