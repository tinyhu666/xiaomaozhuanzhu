.page-shell {
  padding: 28rpx 28rpx 56rpx;
}

.onboarding-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.onboarding-page__title {
  margin-top: 18rpx;
}

.onboarding-preview {
  margin-top: 0;
}

.onboarding-preview__row {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.onboarding-preview__avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.onboarding-preview__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(99, 203, 168, 0.16) 0%, rgba(46, 169, 133, 0.22) 100%);
  color: var(--mint-600);
  font-size: 34rpx;
  font-weight: 700;
}

.onboarding-preview__content {
  min-width: 0;
  flex: 1;
}

.onboarding-preview__name,
.onboarding-preview__hint {
  display: block;
}

.onboarding-preview__name {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

.onboarding-preview__hint {
  margin-top: 10rpx;
  color: var(--text-sub);
  font-size: 24rpx;
  line-height: 1.6;
}

.onboarding-page__button {
  width: 100%;
}
