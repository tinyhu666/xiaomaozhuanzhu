.mistakes-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.mistakes-page__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 8rpx 4rpx;
}

.mistakes-page__title-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.mistakes-page__title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.mistakes-page__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
}

.mistakes-page__filter {
  flex-shrink: 0;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(74, 110, 217, 0.08);
  border: 1rpx solid rgba(74, 110, 217, 0.18);
  font-size: 22rpx;
  font-weight: 600;
  color: #4a6ed9;
  letter-spacing: 0.3rpx;
}

.mistakes-page__filter:active {
  background: rgba(74, 110, 217, 0.18);
}

.mistakes-page__loading,
.mistakes-page__error,
.mistakes-page__empty {
  padding: 80rpx 0;
  text-align: center;
  color: var(--text-sub);
  font-size: 26rpx;
  line-height: 1.6;
}

.mistakes-page__empty-icon {
  font-size: 56rpx;
  margin-bottom: 14rpx;
}

.mistakes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.mistakes-card {
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 18rpx -4rpx rgba(46, 169, 133, 0.06);
  transition: opacity 0.22s ease;
}

.mistakes-card.is-mastered {
  opacity: 0.7;
}

.mistakes-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.mistakes-card__meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 20rpx;
  color: var(--text-sub);
}

.mistakes-card__subject {
  font-weight: 700;
  color: var(--mint-600);
  font-size: 22rpx;
}

.mistakes-card__difficulty,
.mistakes-card__date {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
}

.mistakes-card__divider {
  color: rgba(94, 125, 117, 0.4);
}

.mistakes-card__mastered-btn {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  border: 1rpx solid rgba(46, 169, 133, 0.18);
  font-size: 20rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 0.3rpx;
}

.mistakes-card__mastered-btn.is-on {
  background: rgba(46, 169, 133, 0.18);
  color: #155946;
}

.mistakes-card__mastered-btn:active {
  transform: scale(0.96);
}

.mistakes-card__question {
  display: block;
  font-size: 28rpx;
  line-height: 1.65;
  color: var(--text-main);
  letter-spacing: 0.2rpx;
}

.mistakes-card__options {
  margin-top: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.mistakes-card__option {
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(46, 169, 133, 0.04);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-main);
}

.mistakes-card__option.is-correct {
  background: rgba(46, 169, 133, 0.16);
  border-color: var(--mint-500);
  color: #155946;
  font-weight: 600;
}

.mistakes-card__option.is-wrong {
  background: rgba(217, 80, 80, 0.1);
  border-color: rgba(217, 80, 80, 0.36);
  color: #7a1a1a;
  font-weight: 600;
}

.mistakes-card__answers {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.mistakes-card__answer-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.3rpx;
}

.mistakes-card__answer-pill--wrong {
  background: rgba(217, 80, 80, 0.12);
  color: #7a1a1a;
}

.mistakes-card__answer-pill--correct {
  background: rgba(46, 169, 133, 0.18);
  color: #1d6f59;
}

.mistakes-card__explanation {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(74, 110, 217, 0.06);
  border: 1rpx solid rgba(74, 110, 217, 0.16);
}

.mistakes-card__explanation-label {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(74, 110, 217, 0.18);
  color: #3a4a92;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.3rpx;
  margin-bottom: 8rpx;
}

.mistakes-card__explanation-text {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-main);
  white-space: pre-wrap;
}
