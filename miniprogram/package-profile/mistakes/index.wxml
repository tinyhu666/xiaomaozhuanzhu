<view class="page-shell mistakes-page">
  <view class="mistakes-page__head">
    <view class="mistakes-page__title-wrap">
      <text class="mistakes-page__title">错题本</text>
      <text class="mistakes-page__sub">{{showMastered ? "已含「已掌握」" : "只看未掌握的题"}}</text>
    </view>
    <view class="mistakes-page__filter" bindtap="onToggleShowMastered">
      {{showMastered ? "隐藏已掌握" : "显示全部"}}
    </view>
  </view>

  <view wx:if="{{loading}}" class="mistakes-page__loading">加载中…</view>

  <view wx:elif="{{errorMessage}}" class="mistakes-page__error">
    <text>{{errorMessage}}</text>
  </view>

  <view wx:elif="{{!items.length}}" class="mistakes-page__empty">
    <view class="mistakes-page__empty-icon">📚</view>
    <text class="mistakes-page__empty-text">{{emptyMessage}}</text>
  </view>

  <view wx:else class="mistakes-list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="mistakes-card {{item.isMastered ? 'is-mastered' : ''}}"
    >
      <view class="mistakes-card__head">
        <view class="mistakes-card__meta">
          <text class="mistakes-card__subject">{{item.subject}}</text>
          <text class="mistakes-card__divider">·</text>
          <text class="mistakes-card__difficulty">{{item.difficultyLabel}}</text>
          <text class="mistakes-card__divider">·</text>
          <text class="mistakes-card__date">{{item.dateText}}</text>
        </view>
        <view
          class="mistakes-card__mastered-btn {{item.isMastered ? 'is-on' : ''}}"
          data-id="{{item.id}}"
          bindtap="onTapMastered"
        >{{item.isMastered ? "✓ 已掌握" : "标记掌握"}}</view>
      </view>

      <text class="mistakes-card__question">{{item.question}}</text>

      <view class="mistakes-card__options">
        <view
          wx:for="{{item.options}}"
          wx:for-item="opt"
          wx:key="*this"
          class="mistakes-card__option {{opt.charAt(0) === item.correctAnswer ? 'is-correct' : ''}} {{opt.charAt(0) === item.userAnswer && item.userAnswer !== item.correctAnswer ? 'is-wrong' : ''}}"
        >{{opt}}</view>
      </view>

      <view class="mistakes-card__answers">
        <text class="mistakes-card__answer-pill mistakes-card__answer-pill--wrong">你选 {{item.userAnswer}}</text>
        <text class="mistakes-card__answer-pill mistakes-card__answer-pill--correct">正确 {{item.correctAnswer}}</text>
      </view>

      <view wx:if="{{item.aiExplanation}}" class="mistakes-card__explanation">
        <text class="mistakes-card__explanation-label">AI 解析</text>
        <text class="mistakes-card__explanation-text">{{item.aiExplanation}}</text>
      </view>
    </view>
  </view>
</view>
