.share-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.share-card {
  padding: 28rpx 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow: 0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.08);
}

.share-card__top,
.share-card__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.share-card__title-wrap,
.share-card__row-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.share-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.share-card__hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  line-height: 1.5;
}

.share-card__switch {
  /* relative 必须在 switch 自身：::after 命中区才以开关为中心（放父行会
     悬在整行文字上导致误触）。 */
  position: relative;
  transform: scale(0.85);
}

/* v0.43 — 触控扩区（对齐 settings 开关的 v0.42.1 基线）。104rpx ≈ 88/0.85，
   补偿 scale(0.85) 坐标系后净得约 88rpx。透明、零视觉影响。
   ⚠️ 原生 <switch> 走 bindchange：真机需点一次扩张区确认能触发；
   若不触发，回退方案 = 删掉 scale(0.85) 用原生尺寸。 */
.share-card__switch::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 104rpx;
  height: 104rpx;
}

.share-card__label {
  display: block;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.share-card__link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: rgba(46, 169, 133, 0.08);
  gap: 12rpx;
}

.share-card__link-text {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  font-family: "SF Mono", Menlo, Consolas, monospace;
  color: var(--mint-600);
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.share-card__copy {
  flex-shrink: 0;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: var(--mint-500);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.share-page__hidden-note {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(46, 169, 133, 0.04);
}

.share-page__note-title {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.share-page__note-list {
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

/* GPT image2 redesign pass */
.share-page {
  gap: 24rpx;
}

.share-card,
.share-page__hidden-note {
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #D2E1DA;
  box-shadow: 0 2rpx 8rpx rgba(20, 60, 50, 0.04);
}

.share-card__title,
.share-page__note-title {
  color: #1F2624;
  font-size: 28rpx;
  font-weight: 600;
}

.share-card__hint,
.share-page__note-list,
.share-card__label {
  color: #5E7D75;
}

.share-card__link {
  border-radius: 16rpx;
  background: #ECF5F0;
}

.share-card__link-text {
  color: #155946;
}

.share-card__copy {
  background: #155946;
}

.share-page__hidden-note {
  padding: 24rpx;
}
