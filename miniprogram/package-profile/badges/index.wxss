.badges-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ============================================================
   Hero — N/M ratio + sub-line.
   ============================================================ */
.badges-hero {
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.22), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow: 0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.1);
  text-align: center;
}

.badges-hero__title {
  display: block;
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1.05;
  color: var(--mint-600);
  letter-spacing: 1rpx;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.badges-hero__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

/* ============================================================
   v0.21 — 成就说明 (achievement guide). Collapsed by default.
   ============================================================ */
.badges-guide {
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: 0 6rpx 18rpx -4rpx rgba(46, 169, 133, 0.06);
  overflow: hidden;
}

.badges-guide__head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 22rpx 26rpx;
}

.badges-guide__head:active {
  background: rgba(46, 169, 133, 0.06);
}

.badges-guide__title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.badges-guide__hint {
  font-size: 22rpx;
  color: var(--mint-600);
  letter-spacing: 0.3rpx;
}

.badges-guide__chevron {
  width: 32rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text-sub);
  font-weight: 700;
}

.badges-guide__body {
  padding: 6rpx 22rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.guide-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: rgba(46, 169, 133, 0.04);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
}

.guide-row.is-unlocked {
  background: rgba(46, 169, 133, 0.1);
  border-color: rgba(46, 169, 133, 0.2);
}

.guide-row__icon {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  line-height: 1;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 14rpx;
  flex-shrink: 0;
}

.guide-row__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.guide-row__line1 {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.guide-row__cat {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.guide-row__pill {
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.guide-row__pill--common    { background: rgba(94, 125, 117, 0.16);  color: var(--text-main); }
.guide-row__pill--rare      { background: rgba(74, 110, 217, 0.18);  color: #3a4a92; }
.guide-row__pill--epic      { background: rgba(229, 123, 43, 0.2);   color: #7a3f0a; }
.guide-row__pill--legendary { background: rgba(240, 169, 59, 0.3);   color: #6b4108; }

.guide-row__cond {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  line-height: 1.4;
}

/* ============================================================
   Per-rarity grid section
   ============================================================ */
.badges-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.badges-section__head {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  padding: 4rpx 4rpx;
}

.badges-section__title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.badges-section__count {
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.7;
  letter-spacing: 0.3rpx;
}

.badges-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

/* ============================================================
   Badge tile — rarity-themed background, locked vs unlocked
   ============================================================ */
.badge-tile {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 28rpx 22rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: 0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.06);
  filter: grayscale(0.85);
  opacity: 0.55;
  transition: filter 0.3s ease, opacity 0.3s ease, transform 0.18s ease;
}

.badge-tile:active {
  transform: scale(0.98);
}

.badge-tile.is-unlocked {
  filter: none;
  opacity: 1;
}

/* Rarity-specific unlocked treatments. Mirror the cat-reveal modal
   colors so the two surfaces feel like one collection. */
.badge-tile--common.is-unlocked {
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.28), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border-color: rgba(46, 169, 133, 0.28);
  box-shadow: 0 12rpx 28rpx -4rpx rgba(46, 169, 133, 0.18);
}

.badge-tile--rare.is-unlocked {
  background:
    radial-gradient(circle at 50% 0%, rgba(138, 166, 240, 0.32), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #eef3ff 100%);
  border-color: rgba(74, 110, 217, 0.28);
  box-shadow: 0 12rpx 28rpx -4rpx rgba(74, 110, 217, 0.2);
}

.badge-tile--epic.is-unlocked {
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 107, 0.36), transparent 60%),
    linear-gradient(180deg, #fffaf0 0%, #ffe6c0 100%);
  border-color: rgba(229, 123, 43, 0.34);
  box-shadow: 0 12rpx 28rpx -4rpx rgba(229, 123, 43, 0.22);
}

.badge-tile--legendary.is-unlocked {
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 216, 107, 0.5), transparent 60%),
    linear-gradient(180deg, #fffaeb 0%, #ffe79b 100%);
  border-color: rgba(240, 169, 59, 0.5);
  box-shadow: 0 12rpx 28rpx -4rpx rgba(240, 169, 59, 0.3);
}

.badge-tile__crown,
.badge-tile__star {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  font-size: 36rpx;
  line-height: 1;
  filter: drop-shadow(0 2rpx 6rpx rgba(0, 0, 0, 0.18));
}

.badge-tile__star {
  font-size: 30rpx;
}

.badge-tile__icon {
  font-size: 72rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.badge-tile__name {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.badge-tile--rare.is-unlocked .badge-tile__name      { color: #3a4a92; }
.badge-tile--epic.is-unlocked .badge-tile__name      { color: #7a3f0a; }
.badge-tile--legendary.is-unlocked .badge-tile__name { color: #6b4108; }
.badge-tile--common.is-unlocked .badge-tile__name    { color: var(--mint-600); }

.badge-tile__desc {
  font-size: 21rpx;
  line-height: 1.45;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.2rpx;
}

.badge-tile__track {
  width: 100%;
  height: 6rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
}

.badge-tile__fill {
  height: 100%;
  background: linear-gradient(90deg, #6fc99a 0%, #2ea985 100%);
  border-radius: inherit;
  transition: width 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.badge-tile--rare.is-unlocked .badge-tile__fill {
  background: linear-gradient(90deg, #8aa6f0 0%, #4a6ed9 100%);
}

.badge-tile--epic.is-unlocked .badge-tile__fill {
  background: linear-gradient(90deg, #ffb86b 0%, #e57b2b 100%);
}

.badge-tile--legendary.is-unlocked .badge-tile__fill {
  background: linear-gradient(90deg, #ffd86b 0%, #f0a93b 100%);
}

.badge-tile__progress {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.badge-tile.is-unlocked .badge-tile__progress {
  color: var(--text-main);
  opacity: 0.7;
}
