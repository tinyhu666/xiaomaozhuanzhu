.badges-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.badges-hero {
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.22), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow: 0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.1);
  text-align: center;
}

.badges-hero__title {
  display: block;
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1.05;
  color: var(--mint-600);
  letter-spacing: 1rpx;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.badges-hero__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

.badges-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.badge-tile {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 22rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow: 0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.06);
  filter: grayscale(0.5);
  opacity: 0.7;
  transition: filter 0.3s ease, opacity 0.3s ease, transform 0.18s ease;
}

.badge-tile:active {
  transform: scale(0.98);
}

.badge-tile.is-unlocked {
  filter: none;
  opacity: 1;
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.28), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border-color: rgba(46, 169, 133, 0.28);
  box-shadow: 0 12rpx 28rpx -4rpx rgba(46, 169, 133, 0.18);
}

.badge-tile__icon {
  font-size: 64rpx;
  line-height: 1;
  margin-bottom: 6rpx;
}

.badge-tile__name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.badge-tile.is-unlocked .badge-tile__name {
  color: var(--mint-600);
}

.badge-tile__desc {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.badge-tile__track {
  width: 100%;
  height: 6rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
}

.badge-tile__fill {
  height: 100%;
  background: linear-gradient(90deg, #6fc99a 0%, #2ea985 100%);
  border-radius: inherit;
  transition: width 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.badge-tile.is-unlocked .badge-tile__fill {
  background: linear-gradient(90deg, #2ea985 0%, #155946 100%);
}

.badge-tile__progress {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.badge-tile.is-unlocked .badge-tile__progress {
  color: var(--mint-600);
}
