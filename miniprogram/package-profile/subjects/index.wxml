<view class="page-shell subjects-page">
  <view class="overall-card">
    <view class="overall-card__row">
      <text class="overall-card__title">六科总进度</text>
      <text class="overall-card__value">{{overallPct}}<text class="overall-card__pct">%</text></text>
    </view>
    <view class="overall-card__track">
      <view class="overall-card__fill" style="width: {{overallPct}}%"></view>
    </view>
    <text class="overall-card__hint">{{totalText}} / 1220h · 距最近一科 {{nextDaysRemaining}} 天</text>
  </view>

  <!--
    v0.11 subject distribution donut. Only renders when at least
    one subject has minutes; the donut + legend together replace
    what would otherwise be a flat list of all-zeros.
  -->
  <view wx:if="{{donut.hasData}}" class="donut-card">
    <view class="donut-card__visual">
      <view class="donut-card__ring" style="{{donut.style}}">
        <view class="donut-card__hole">
          <text class="donut-card__center-label">{{donut.centerLabel}}</text>
          <text class="donut-card__center-sub">{{donut.centerSub}}</text>
        </view>
      </view>
    </view>
    <view class="donut-card__legend">
      <view wx:for="{{donut.segments}}" wx:key="subject" class="donut-card__legend-row">
        <view class="donut-card__legend-dot" style="background:{{item.color}};"></view>
        <text class="donut-card__legend-name">{{item.subject}}</text>
        <text class="donut-card__legend-percent">{{item.percent}}%</text>
      </view>
    </view>
  </view>

  <!--
    v0.15 — slimmed subject cards. Each row now reads as one line
    plus a progress bar: 科目名 + 倒计时角标 + 进度百分比 + 进度条
    + 单行已学/目标. The standalone exam-date line was redundant
    with the countdown chip, so it's been removed.
  -->
  <view class="subject-list">
    <view
      wx:for="{{subjects}}"
      wx:key="subject"
      class="subject-card {{item.reached ? 'is-reached' : ''}}"
    >
      <view class="subject-card__head">
        <view class="subject-card__name-wrap">
          <text class="subject-card__name">{{item.subject}}</text>
          <text wx:if="{{item.daysRemaining > 0}}" class="subject-card__countdown {{item.daysRemaining <= 30 ? 'is-urgent' : ''}}">{{item.daysRemaining}} 天</text>
        </view>
        <text class="subject-card__pct {{item.reached ? 'is-reached' : ''}}">{{item.progressPct}}%</text>
      </view>
      <view class="subject-card__track">
        <view
          class="subject-card__fill {{item.reached ? 'is-reached' : ''}}"
          style="width: {{item.progressPct}}%"
        ></view>
      </view>
      <text class="subject-card__hours">{{item.totalText}} / {{item.targetText}}</text>
    </view>
  </view>

  <text wx:if="{{anyFallback}}" class="subjects-footnote">* 倒计时暂以上一年公告时间为参考，待官方公布后会自动更新</text>
</view>
