<view class="page-shell settings-page">
  <view class="settings-section">
    <view class="settings-section__title">学习目标</view>
    <view class="settings-section__hint">为每日 / 每周的专注时长设定目标。0 = 不设。</view>
    <view class="settings-section__body">
      <view wx:for="{{goalRows}}" wx:key="key" class="settings-row">
        <view class="settings-row__text">
          <text class="settings-row__label">{{item.label}}</text>
          <text class="settings-row__desc">{{item.description}}</text>
        </view>
        <view class="settings-row__stepper">
          <view
            class="settings-row__step {{!item.canDecrement ? 'is-disabled' : ''}}"
            data-key="{{item.key}}"
            data-dir="down"
            bindtap="onStepperTap"
          >−</view>
          <view class="settings-row__value-wrap">
            <text class="settings-row__value">{{item.displayValue}}</text>
            <text wx:if="{{item.unit}}" class="settings-row__unit">{{item.unit}}</text>
          </view>
          <view
            class="settings-row__step {{!item.canIncrement ? 'is-disabled' : ''}}"
            data-key="{{item.key}}"
            data-dir="up"
            bindtap="onStepperTap"
          >+</view>
        </view>
      </view>
    </view>
  </view>

  <!--
    v0.23 — section order rearranged by usage frequency:
      goals (every settings visit) → reminder (set once) → audio
      (occasional pick) → share (rare, used to be top-level menu).
    The reminder section moved up because it's the most actionable
    toggle on the page; audio went down because most users pick once
    and forget.
  -->

  <view class="settings-section">
    <view class="settings-section__title">每日提醒</view>
    <view class="settings-section__hint">每天 20:30 微信提醒一次，需要授权一次性订阅。</view>
    <view class="settings-section__body">
      <view class="reminder-row">
        <view class="reminder-row__text">
          <text class="reminder-row__label">20:30 学习提醒</text>
          <text class="reminder-row__desc">{{reminder.statusLabel}}</text>
        </view>
        <view
          class="reminder-row__switch {{reminder.enabled ? 'is-on' : ''}} {{reminder.busy ? 'is-busy' : ''}}"
          bindtap="onTapReminderToggle"
        >
          <view class="reminder-row__switch-knob"></view>
        </view>
      </view>
      <view
        wx:if="{{reminder.enabled && reminder.credits < 2 && reminder.hasOpenid}}"
        class="reminder-refill"
        bindtap="onTapReminderRefill"
      >立刻续订一次提醒额度</view>
    </view>
  </view>

  <view class="settings-section">
    <view class="settings-section__title">学习音景</view>
    <view class="settings-section__hint">专注开始时自动循环播放，结束自动停止。</view>
    <view class="settings-section__body settings-section__body--audio">
      <view
        wx:for="{{audioScenes}}"
        wx:key="key"
        class="audio-scene {{item.active ? 'is-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onTapAudioScene"
      >
        <text class="audio-scene__emoji">{{item.emoji}}</text>
        <view class="audio-scene__text">
          <text class="audio-scene__label">{{item.label}}</text>
          <text class="audio-scene__desc">{{item.description}}</text>
        </view>
        <view wx:if="{{item.active}}" class="audio-scene__check">✓</view>
      </view>
    </view>
  </view>

  <!--
    v0.23 — 公开学习页 demoted from the main profile menu (a daily-
    touch surface) to a row in 学习设置 (a settings surface). It's
    a one-time toggle for users who want to share their progress;
    daily users won't visit it once it's set.
  -->
  <view class="settings-section">
    <view class="settings-section__title">其他</view>
    <view class="settings-section__body">
      <view class="settings-link-row" bindtap="onTapOpenShare">
        <view class="settings-link-row__text">
          <text class="settings-link-row__label">公开学习页</text>
          <text class="settings-link-row__desc">生成可分享的学习主页链接</text>
        </view>
        <text class="settings-link-row__chevron">›</text>
      </view>
    </view>
  </view>

  <view class="settings-reset" bindtap="onResetTap">恢复默认设置</view>

  <view class="settings-foot">设置仅保存在当前设备。已记录的学习数据存于云端，不受设置影响。</view>
</view>
