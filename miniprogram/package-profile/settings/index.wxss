/* Second polish pass — settings as quiet controls. */
.settings-section {
  border-radius: 28rpx;
}

.settings-section__title {
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(21, 89, 70, 0.08);
}

.settings-row,
.reminder-row,
.settings-link-row {
  transition: background 160ms cubic-bezier(0.2, 0.8, 0.3, 1);
}

.settings-row:active,
.reminder-row:active,
.settings-link-row:active,
.audio-scene:active {
  background: rgba(21, 89, 70, 0.04);
}

.settings-row__stepper {
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
}

.reminder-row__switch {
  transition:
    background 220ms cubic-bezier(0.2, 0.8, 0.3, 1),
    transform 100ms cubic-bezier(0.2, 0.8, 0.3, 1);
}

.reminder-row__switch:active {
  transform: scale(0.97);
}

.audio-scene {
  background: linear-gradient(180deg, #FFFFFF 0%, #F7FBF8 100%);
}

.audio-scene.is-active {
  background: linear-gradient(180deg, #F2FAF6 0%, #E8F3EE 100%);
}
