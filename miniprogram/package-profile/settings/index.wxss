.settings-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.settings-section {
  padding: 26rpx 28rpx 8rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.06);
}

.settings-section__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

/* v0.26.1 — .settings-section__hint removed. Section titles + row
   labels already tell the user what's going on; the secondary
   explainer was visual noise. */

.settings-section__body {
  margin-top: 14rpx;
}

.settings-section__body--audio {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.audio-scene {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(46, 169, 133, 0.04);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  transition: all 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.audio-scene.is-active {
  background: rgba(46, 169, 133, 0.14);
  border-color: rgba(46, 169, 133, 0.32);
}

.audio-scene:active {
  transform: scale(0.985);
}

.audio-scene__emoji {
  font-size: 32rpx;
  line-height: 1;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.audio-scene__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.audio-scene__label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.audio-scene__desc {
  font-size: 18rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  opacity: 0.75;
}

.audio-scene__check {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--mint-600);
  width: 32rpx;
  text-align: center;
}

.settings-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(46, 169, 133, 0.08);
}

.settings-row:first-child {
  border-top: none;
}

.settings-row__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.settings-row__label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.settings-row__desc {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  line-height: 1.45;
}

.settings-row__stepper {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

/* Plus/Minus buttons. Tap target stays generous; visual size is
   moderate so the value can take the spotlight. */
.settings-row__step {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--mint-600);
  background: rgba(46, 169, 133, 0.1);
  border: 1rpx solid rgba(46, 169, 133, 0.16);
  transition: all 0.18s cubic-bezier(0.2, 0.8, 0.3, 1);
  line-height: 1;
}

.settings-row__step:active {
  transform: scale(0.92);
  background: rgba(46, 169, 133, 0.18);
}

.settings-row__step.is-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.settings-row__value-wrap {
  min-width: 120rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.settings-row__value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1;
}

.settings-row__unit {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

/* v0.20 — daily reminder row. Mirrors the settings-row layout but
   uses a custom toggle switch (chosen over wx <switch> for visual
   consistency with the rest of the mint-themed UI). */
.reminder-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 14rpx 6rpx 18rpx;
}

.reminder-row__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.reminder-row__label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.reminder-row__desc {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  opacity: 0.78;
  line-height: 1.5;
}

.reminder-row__switch {
  position: relative;
  width: 76rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.18);
  transition: background 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
  flex-shrink: 0;
}

/* v0.42.1 — bindtap is on the 76×44rpx switch itself; the mint pill size is
   intentional (v0.32 note), so expand only the tap HIT AREA to ~88rpx via a
   transparent ::after. Zero visual change; parent is position:relative. */
.reminder-row__switch::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 88rpx;
  height: 88rpx;
}

.reminder-row__switch.is-on {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
}

.reminder-row__switch.is-busy {
  opacity: 0.55;
}

.reminder-row__switch:active {
  opacity: 0.85;
}

.reminder-row__switch-knob {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.18);
  transition: transform 0.26s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.reminder-row__switch.is-on .reminder-row__switch-knob {
  transform: translateX(32rpx);
}

/* Refill hint button — only shows when credits are low. */
.reminder-refill {
  margin: 4rpx 0 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(229, 167, 75, 0.12);
  border: 1rpx solid rgba(229, 167, 75, 0.3);
  color: #a05a00;
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  text-align: center;
}

.reminder-refill:active {
  background: rgba(229, 167, 75, 0.2);
}

.settings-reset {
  text-align: center;
  padding: 22rpx;
  border-radius: 999rpx;
  background: rgba(229, 123, 123, 0.08);
  color: #c2562b;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  border: 1rpx solid rgba(229, 123, 123, 0.18);
}

.settings-reset:active {
  background: rgba(229, 123, 123, 0.14);
}

/* v0.23 — generic "link row" used by the demoted 公开学习页 entry.
   Style intentionally lighter than .settings-row so it reads as a
   "secondary nav" not a "toggle/value". */
.settings-link-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 6rpx;
}

.settings-link-row__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.settings-link-row__label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.settings-link-row__desc {
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.78;
  letter-spacing: 0.2rpx;
}

.settings-link-row__chevron {
  font-size: 32rpx;
  color: var(--text-sub);
  opacity: 0.45;
}

.settings-link-row:active {
  background: rgba(46, 169, 133, 0.04);
  border-radius: 12rpx;
}

/* v0.26.1 — .settings-foot removed alongside the foot-disclaimer
   wxml. Nobody reads "设置仅保存在当前设备" caveats; if a setting
   matters cross-device we should sync it server-side, not paper
   over it with footer text. */

