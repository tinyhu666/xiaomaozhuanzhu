.settings-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.settings-section {
  padding: 26rpx 28rpx 8rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.06);
}

.settings-section__title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.settings-section__hint {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  line-height: 1.5;
}

.settings-section__body {
  margin-top: 18rpx;
}

.settings-section__body--audio {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.audio-scene {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(46, 169, 133, 0.04);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  transition: all 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.audio-scene.is-active {
  background: rgba(46, 169, 133, 0.14);
  border-color: rgba(46, 169, 133, 0.32);
}

.audio-scene:active {
  transform: scale(0.985);
}

.audio-scene__emoji {
  font-size: 32rpx;
  line-height: 1;
  width: 48rpx;
  text-align: center;
  flex-shrink: 0;
}

.audio-scene__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.audio-scene__label {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.audio-scene__desc {
  font-size: 18rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  opacity: 0.75;
}

.audio-scene__check {
  font-size: 22rpx;
  font-weight: 800;
  color: var(--mint-600);
  width: 32rpx;
  text-align: center;
}

.settings-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(46, 169, 133, 0.08);
}

.settings-row:first-child {
  border-top: none;
}

.settings-row__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.settings-row__label {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.settings-row__desc {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  line-height: 1.45;
}

.settings-row__stepper {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
}

/* Plus/Minus buttons. Tap target stays generous; visual size is
   moderate so the value can take the spotlight. */
.settings-row__step {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--mint-600);
  background: rgba(46, 169, 133, 0.1);
  border: 1rpx solid rgba(46, 169, 133, 0.16);
  transition: all 0.18s cubic-bezier(0.2, 0.8, 0.3, 1);
  line-height: 1;
}

.settings-row__step:active {
  transform: scale(0.92);
  background: rgba(46, 169, 133, 0.18);
}

.settings-row__step.is-disabled {
  opacity: 0.35;
  pointer-events: none;
}

.settings-row__value-wrap {
  min-width: 120rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.settings-row__value {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  line-height: 1;
}

.settings-row__unit {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

.settings-reset {
  text-align: center;
  padding: 22rpx;
  border-radius: 999rpx;
  background: rgba(229, 123, 123, 0.08);
  color: #c2562b;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  border: 1rpx solid rgba(229, 123, 123, 0.18);
}

.settings-reset:active {
  background: rgba(229, 123, 123, 0.14);
}

.settings-foot {
  margin-top: 8rpx;
  text-align: center;
  font-size: 20rpx;
  color: var(--text-sub);
  opacity: 0.65;
  letter-spacing: 0.2rpx;
  line-height: 1.5;
  padding: 0 24rpx;
}
