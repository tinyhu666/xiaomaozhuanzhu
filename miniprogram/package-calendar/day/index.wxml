<view class="page-shell">
  <view class="hero-card">
    <view class="badge">{{date}}</view>
    <view class="title" style="margin-top: 18rpx;">当天累计 {{totalText}}</view>
    <view class="subtitle">点开每次记录，可以回头看自己当时学了什么、卡在哪里。</view>
  </view>

  <block wx:if="{{sessions.length}}">
    <view wx:for="{{sessions}}" wx:key="id" class="surface-card" style="margin-top: 20rpx;">
      <view style="display: flex; align-items: center; justify-content: space-between;">
        <view class="section-title" style="margin-bottom: 0;">{{item.subjectText}}</view>
        <view class="badge">{{item.totalMinutes}} 分钟</view>
      </view>
      <view class="subtitle">{{item.summary}}</view>
      <view class="tag-list" style="margin-top: 18rpx;">
        <view wx:for="{{item.tags}}" wx:key="*this" class="tag-chip">{{item}}</view>
      </view>
      <view class="photo-grid" style="margin-top: 18rpx;">
        <image
          wx:for="{{item.photos}}"
          wx:key="objectKey"
          wx:for-item="photo"
          wx:for-index="photoIndex"
          src="{{photo.url}}"
          mode="aspectFill"
          class="photo-item"
          data-session-index="{{index}}"
          data-photo-index="{{photoIndex}}"
          bindtap="previewImage"
        />
      </view>
    </view>
  </block>

  <view wx:else class="surface-card" style="margin-top: 24rpx;">
    <view class="empty-state">这一天还没有完成的打卡记录。</view>
  </view>
</view>
