<view class="page-shell day-page">
  <view class="day-hero">
    <text class="day-hero__date">{{date}}</text>
    <text class="day-hero__total">当天累计 {{totalText}}</text>
  </view>

  <!-- v0.32.7 — load-error state with retry, distinct from the empty
       (no-records) state so a network failure doesn't read as "you
       didn't study". -->
  <view wx:if="{{loadState === 'error'}}" class="day-session day-session--empty">
    <view class="empty-state">加载失败，请检查网络后重试。</view>
    <view class="day-retry" bindtap="retryLoad">重新加载</view>
  </view>

  <block wx:elif="{{sessions.length}}">
    <view wx:for="{{sessions}}" wx:key="id" class="day-session">
      <view class="day-session__head">
        <text class="day-session__subject">{{item.subject || '未选择科目'}}</text>
        <text class="day-session__duration">{{item.totalMinutes}} 分钟</text>
      </view>
      <view wx:if="{{item.summary}}" class="day-session__summary">{{item.summary}}</view>
      <view wx:if="{{item.tags.length}}" class="tag-list day-session__tags">
        <view wx:for="{{item.tags}}" wx:key="*this" class="tag-chip">{{item}}</view>
      </view>
      <view wx:if="{{item.photos.length}}" class="photo-grid day-session__photos">
        <image
          wx:for="{{item.photos}}"
          wx:key="objectKey"
          wx:for-item="photo"
          wx:for-index="photoIndex"
          src="{{photo.url}}"
          mode="aspectFill"
          class="photo-item"
          data-session-index="{{index}}"
          data-photo-index="{{photoIndex}}"
          bindtap="previewImage"
        />
      </view>
    </view>
  </block>

  <view wx:elif="{{loadState === 'loaded'}}" class="day-session day-session--empty">
    <view class="empty-state">这一天还没有完成的打卡记录。</view>
  </view>
</view>
