.tab-shell {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  /* v0.25.4 — was repeat(4, ...) from when we had 4 tabs (首页 / 日历
     / 动态 / 我的). v0.22 trimmed to 3 tabs but this rule kept the
     4-column grid, so 3 items sat in columns 1-3 and the right
     edge had an empty phantom column making tabs look left-shifted. */
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  border: 1rpx solid #D2E1DA;
  box-shadow: 0 12rpx 32rpx -4rpx rgba(20, 60, 50, 0.08);
  z-index: 100;
  transition: transform 0.28s cubic-bezier(0.2, 0.8, 0.3, 1),
              opacity 0.22s ease;
}

/* v0.25.4 — focus-mode hide. Pages call
   this.getTabBar().setData({ hidden: true }) when they want the
   custom tab bar out of the way (e.g. home's full-screen focus
   view, where the floating tab bar was covering the 暂停/结束
   buttons). Translate-down + fade keeps a brief animation hint
   that lets the user know it's a temporary hide, not a crash. */
.tab-shell.is-hidden {
  transform: translateY(calc(100% + 60rpx));
  opacity: 0;
  pointer-events: none;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  border-radius: 999rpx;
  color: #5E7D75;
  transition: transform 100ms cubic-bezier(0.2, 0.8, 0.3, 1),
              background 220ms cubic-bezier(0.2, 0.8, 0.3, 1),
              color 220ms cubic-bezier(0.2, 0.8, 0.3, 1);
}

.tab-item:active {
  transform: scale(0.97);
}

.tab-item.is-active {
  background: #155946;
  color: #FFFFFF;
}

.tab-label {
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0;
  text-align: center;
}

@media (prefers-reduced-motion: reduce) {
  .tab-shell,
  .tab-item {
    transition: none !important;
  }
}

/* Second polish pass — quieter floating control. */
.tab-shell {
  left: 40rpx;
  right: 40rpx;
  padding: 6rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(247, 251, 248, 0.98) 100%);
  border-color: rgba(21, 89, 70, 0.13);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 22rpx 48rpx -28rpx rgba(15, 44, 34, 0.48);
}

.tab-item {
  min-height: 76rpx;
}

.tab-item.is-active {
  background: linear-gradient(180deg, #1B6651 0%, #155946 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.12),
    0 12rpx 24rpx -18rpx rgba(21, 89, 70, 0.72);
}
