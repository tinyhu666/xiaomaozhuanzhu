.tab-shell {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  padding: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 56rpx rgba(46, 169, 133, 0.16);
  backdrop-filter: blur(20rpx);
  z-index: 100;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #6a8b82;
  transition: all 0.2s ease;
}

.tab-item.is-active {
  background: linear-gradient(135deg, rgba(99, 203, 168, 0.18) 0%, rgba(46, 169, 133, 0.22) 100%);
  color: #238167;
}

.tab-label {
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}
