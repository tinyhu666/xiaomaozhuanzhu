.tab-shell {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  display: grid;
  /* v0.25.4 — was repeat(4, ...) from when we had 4 tabs (首页 / 日历
     / 动态 / 我的). v0.22 trimmed to 3 tabs but this rule kept the
     4-column grid, so 3 items sat in columns 1-3 and the right
     edge had an empty phantom column making tabs look left-shifted. */
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  padding: 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 24rpx 56rpx rgba(46, 169, 133, 0.16);
  backdrop-filter: blur(20rpx);
  z-index: 100;
  transition: transform 0.28s cubic-bezier(0.2, 0.8, 0.3, 1),
              opacity 0.22s ease;
}

/* v0.25.4 — focus-mode hide. Pages call
   this.getTabBar().setData({ hidden: true }) when they want the
   custom tab bar out of the way (e.g. home's full-screen focus
   view, where the floating tab bar was covering the 暂停/结束
   buttons). Translate-down + fade keeps a brief animation hint
   that lets the user know it's a temporary hide, not a crash. */
.tab-shell.is-hidden {
  transform: translateY(calc(100% + 60rpx));
  opacity: 0;
  pointer-events: none;
}

.tab-item {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 999rpx;
  color: #6a8b82;
  transition: all 0.2s ease;
}

.tab-item.is-active {
  background: linear-gradient(135deg, rgba(99, 203, 168, 0.18) 0%, rgba(46, 169, 133, 0.22) 100%);
  color: #238167;
}

.tab-label {
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
}

/* v0.28.1 — dark mode: floating glass tab bar on dark bg. */
@media (prefers-color-scheme: dark) {
  .tab-shell {
    background: rgba(42, 47, 45, 0.88);
    box-shadow: 0 24rpx 56rpx rgba(0, 0, 0, 0.36);
    border: 1rpx solid rgba(232, 239, 236, 0.06);
  }
  .tab-item {
    color: #8FA59C;
  }
  .tab-item.is-active {
    background: linear-gradient(135deg, rgba(46, 169, 133, 0.22) 0%, rgba(46, 169, 133, 0.32) 100%);
    color: #4dc6a0;
  }
}
