.profile-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.profile-card,
.auth-card,
.status-card {
  padding: 28rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(46, 169, 133, 0.08);
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.profile-card__avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(233, 244, 239, 0.8);
}

.profile-card__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--mint-600);
  font-size: 38rpx;
  font-weight: 700;
  background: linear-gradient(135deg, rgba(99, 203, 168, 0.16) 0%, rgba(46, 169, 133, 0.22) 100%);
}

.profile-card__content {
  flex: 1;
  min-width: 0;
}

.profile-card__name,
.profile-card__hint,
.auth-card__badge,
.auth-card__title,
.auth-card__desc,
.status-card__title,
.status-card__desc {
  display: block;
}

.profile-card__name {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.profile-card__hint,
.auth-card__desc,
.status-card__desc {
  margin-top: 10rpx;
  color: var(--text-sub);
  font-size: 24rpx;
  line-height: 1.7;
}

.auth-card {
  background:
    radial-gradient(circle at top right, rgba(94, 195, 157, 0.16), transparent 42%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 251, 245, 0.96) 100%);
}

.auth-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 700;
}

.auth-card__title,
.status-card__title {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 28rpx;
}

.auth-avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 220rpx;
  padding: 0;
  border: 0;
  border-radius: 28rpx;
  background: rgba(233, 244, 239, 0.88);
  overflow: hidden;
}

.auth-avatar-picker::after {
  border: 0;
}

.auth-avatar-picker__preview {
  width: 100%;
  height: 100%;
}

.auth-avatar-picker__placeholder {
  color: var(--mint-600);
  font-size: 28rpx;
  font-weight: 600;
}

.auth-input {
  width: 100%;
  height: 96rpx;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid rgba(46, 169, 133, 0.1);
  box-sizing: border-box;
}

.auth-card__button {
  width: 100%;
}
