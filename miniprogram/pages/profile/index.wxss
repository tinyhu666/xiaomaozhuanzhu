.profile-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

/* Staggered fade-up — each child card slides up by 14rpx and fades
   in. Cubic-bezier matches the rest of the app's standard curve. */
@keyframes profile-fade-up {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.profile-page > view,
.profile-page > .profile-version {
  animation: profile-fade-up 0.42s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.profile-page > view:nth-child(1) { animation-delay: 0.04s; }
.profile-page > view:nth-child(2) { animation-delay: 0.1s; }
.profile-page > view:nth-child(3) { animation-delay: 0.16s; }
.profile-page > view:nth-child(4) { animation-delay: 0.22s; }
.profile-page > view:nth-child(5) { animation-delay: 0.28s; }
.profile-page > view:nth-child(6) { animation-delay: 0.34s; }
.profile-page > .profile-version { animation-delay: 0.4s; }

/* ============================================================
   Hero — avatar + nickname.
   ============================================================ */
.profile-hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 26rpx;
  padding: 30rpx 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.2), transparent 38%),
    linear-gradient(180deg, #ffffff 0%, #f6fbf8 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
    0 10rpx 28rpx -6rpx rgba(46, 169, 133, 0.08);
}

.profile-hero__avatar-wrap {
  position: relative;
  width: 124rpx;
  height: 124rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #c2ead2 0%, #6fc99a 100%);
  box-shadow: 0 6rpx 18rpx rgba(46, 169, 133, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-hero__avatar-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.profile-hero__avatar-placeholder {
  font-size: 60rpx;
  line-height: 1;
}

/* Invisible full-area tap target (open-type=chooseAvatar). v0.18.1
   dropped the bottom "换头像" strip — it overlapped the lower third
   of the avatar image and read as a green smear on faces. We now
   render a small 📷 chip in the corner instead (sibling element). */
.profile-hero__avatar-btn {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent !important;
  background-color: transparent !important;
  border-radius: 50%;
  line-height: 0;
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  outline: none;
  z-index: 2;
}

.profile-hero__avatar-btn::after {
  border: none;
  outline: none;
}

.profile-hero__avatar-btn:active {
  background: transparent !important;
  background-color: transparent !important;
  opacity: 0.92;
}

/* v0.26.1 — the .profile-hero__avatar-badge corner chip was deleted.
   It sat inside an `overflow:hidden + border-radius:50%` wrapper, so
   the circular mask clipped the square badge into a triangular green
   sliver that users read as an "unknown obstruction". The avatar's
   full-area chooseAvatar button still owns the tap target. */

.profile-hero__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.profile-hero__nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  background: transparent;
  padding: 4rpx 0;
}

.profile-hero__hint {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  opacity: 0.78;
}

/* ============================================================
   Stat grid — 2×2. Each tile carries label / big value / optional
   caption. A 6rpx colored left strip differentiates the four
   "tone" themes (mint / blue / amber / rose).
   ============================================================ */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-tile {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 22rpx 22rpx 20rpx 26rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 18rpx -4rpx rgba(46, 169, 133, 0.05);
  overflow: hidden;
}

.stat-tile::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  width: 4rpx;
}

.stat-tile--mint::before  { background: linear-gradient(180deg, #5fc491 0%, #2ea985 100%); }
.stat-tile--blue::before  { background: linear-gradient(180deg, #8aa6f0 0%, #4a6ed9 100%); }
.stat-tile--amber::before { background: linear-gradient(180deg, #ffb86b 0%, #e57b2b 100%); }
.stat-tile--rose::before  { background: linear-gradient(180deg, #f3a0a0 0%, #d96e6e 100%); }

.stat-tile__label {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.stat-tile__value {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
  line-height: 1;
}

.stat-tile__unit {
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 4rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
}

.stat-tile__caption {
  font-size: 18rpx;
  color: var(--text-sub);
  opacity: 0.7;
  letter-spacing: 0.2rpx;
}

/* ============================================================
   Insights — single-line head + 24-bar sparkline. Bars use a
   stagger-grow animation (controlled by inline animation-delay
   on each .insights-card__bar so first-render feels alive).
   ============================================================ */
.insights-card {
  position: relative;
  padding: 22rpx 26rpx 20rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 20rpx -4rpx rgba(46, 169, 133, 0.06);
}

.insights-card__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.insights-card__title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.insights-card__peak {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--mint-600);
  letter-spacing: 0.2rpx;
  font-feature-settings: "tnum" 1;
}

.insights-card__chart {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 96rpx;
  padding: 0 2rpx;
}

@keyframes insights-bar-grow {
  from { transform: scaleY(0); opacity: 0; }
  to { transform: scaleY(1); opacity: 1; }
}

.insights-card__bar {
  flex: 1;
  min-height: 3rpx;
  border-radius: 3rpx 3rpx 0 0;
  background: rgba(46, 169, 133, 0.2);
  transform-origin: bottom;
  animation: insights-bar-grow 0.52s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.insights-card__bar.is-peak {
  background: linear-gradient(180deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 2rpx 10rpx rgba(46, 169, 133, 0.3);
}

/* ============================================================
   Quote — minimal italic block, no card chrome. Decorative.
   ============================================================ */
.profile-quote {
  padding: 4rpx 8rpx;
}

.profile-quote__en {
  display: block;
  font-family: Georgia, "Times New Roman", "PingFang SC", serif;
  font-size: 28rpx;
  font-weight: 600;
  font-style: italic;
  line-height: 1.5;
  color: #155946;
  letter-spacing: 0.2rpx;
}

.profile-quote__zh {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.6;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

/* ============================================================
   Menu list — staggered fade-in for each item gives a sense of
   "page is composing itself" without being noisy.
   ============================================================ */
.menu-list {
  border-radius: 26rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 22rpx -4rpx rgba(46, 169, 133, 0.06);
  overflow: hidden;
}

@keyframes menu-item-slide {
  from { opacity: 0; transform: translateX(-12rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 26rpx;
  border-top: 1rpx solid rgba(46, 169, 133, 0.06);
  transition: background 0.18s ease;
  animation: menu-item-slide 0.4s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.menu-item:first-child { border-top: none; }
.menu-item:nth-child(1) { animation-delay: 0.42s; }
.menu-item:nth-child(2) { animation-delay: 0.48s; }
.menu-item:nth-child(3) { animation-delay: 0.54s; }
.menu-item:nth-child(4) { animation-delay: 0.6s; }
.menu-item:nth-child(5) { animation-delay: 0.66s; }
.menu-item:nth-child(6) { animation-delay: 0.72s; }

.menu-item:active {
  background: rgba(46, 169, 133, 0.06);
}

.menu-item__icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: rgba(46, 169, 133, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
}

.menu-item__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3rpx;
  min-width: 0;
}

.menu-item__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.menu-item__hint {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  opacity: 0.75;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-item__chevron {
  font-size: 32rpx;
  color: var(--text-sub);
  opacity: 0.45;
}

.profile-version {
  display: block;
  margin-top: 8rpx;
  text-align: center;
  font-size: 18rpx;
  color: rgba(94, 125, 117, 0.5);
  letter-spacing: 1rpx;
}

/* ============================================================
   v0.18 — Monthly summary modal. Fires once per calendar month
   on the first visit to 我的 after the month rolls over. The card
   sits above a translucent backdrop; tap anywhere outside the
   card to dismiss. Visual language matches the cat-reveal modal
   on the session-complete page (same curve, same border radius)
   so the two "moment" surfaces feel related.
   ============================================================ */
@keyframes monthly-modal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes monthly-modal-pop {
  0%   { opacity: 0; transform: scale(0.85) translateY(40rpx); }
  60%  { transform: scale(1.02) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes monthly-value-rise {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.monthly-modal {
  position: fixed;
  inset: 0;
  z-index: 240;
  background: rgba(20, 60, 50, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: monthly-modal-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.monthly-modal__card {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 44rpx 36rpx 32rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.42), transparent 62%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.2);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(46, 169, 133, 0.32);
  animation: monthly-modal-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.monthly-modal__head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.monthly-modal__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--mint-600);
  padding: 4rpx 16rpx;
  background: rgba(46, 169, 133, 0.12);
  border-radius: 999rpx;
}

.monthly-modal__title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.6rpx;
  margin-top: 8rpx;
}

.monthly-modal__hero {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 18rpx;
  animation: monthly-value-rise 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) 0.18s backwards;
}

.monthly-modal__value {
  font-size: 96rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  letter-spacing: 0.5rpx;
  background: linear-gradient(135deg, #2ea985 0%, #63cba8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.monthly-modal__unit {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 0.5rpx;
}

.monthly-modal__sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  text-align: center;
}

.monthly-modal__detail-grid {
  display: flex;
  width: 100%;
  gap: 14rpx;
  margin-top: 28rpx;
}

.monthly-modal__detail {
  flex: 1;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  align-items: flex-start;
}

.monthly-modal__detail-label {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.monthly-modal__detail-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.monthly-modal__detail-caption {
  font-size: 20rpx;
  color: var(--mint-600);
  letter-spacing: 0.2rpx;
  font-feature-settings: "tnum" 1;
}

.monthly-modal__encouragement {
  margin-top: 26rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.monthly-modal__cta {
  margin-top: 26rpx;
  width: 100%;
  padding: 20rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 6rpx 16rpx rgba(46, 169, 133, 0.28);
  transition: transform 0.16s ease;
}

.monthly-modal__cta:active {
  transform: scale(0.97);
}

/* ============================================================
   v0.19 — Weekly recap modal. Same visual language as monthly,
   but the centerpiece is a 7-bar Mon..Sun chart instead of the
   single big number. Compacter overall — the recap horizon is
   shorter so the moment is smaller too.
   ============================================================ */
@keyframes weekly-modal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes weekly-modal-pop {
  0%   { opacity: 0; transform: scale(0.86) translateY(36rpx); }
  60%  { transform: scale(1.02) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes weekly-bar-rise {
  from { transform: scaleY(0); opacity: 0; }
  to { transform: scaleY(1); opacity: 1; }
}

.weekly-modal {
  position: fixed;
  inset: 0;
  z-index: 235;
  background: rgba(20, 60, 50, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: weekly-modal-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.weekly-modal__card {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 40rpx 32rpx 30rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.36), transparent 62%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.2);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(46, 169, 133, 0.28);
  animation: weekly-modal-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.weekly-modal__head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.weekly-modal__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--mint-600);
  padding: 4rpx 16rpx;
  background: rgba(46, 169, 133, 0.12);
  border-radius: 999rpx;
}

.weekly-modal__title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  margin-top: 8rpx;
  font-feature-settings: "tnum" 1;
}

.weekly-modal__hero {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 14rpx;
}

.weekly-modal__value {
  font-size: 82rpx;
  font-weight: 800;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  letter-spacing: 0.5rpx;
  background: linear-gradient(135deg, #2ea985 0%, #63cba8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}

.weekly-modal__unit {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 0.5rpx;
}

.weekly-modal__sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.weekly-modal__chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10rpx;
  width: 100%;
  height: 160rpx;
  margin-top: 26rpx;
  padding: 0 4rpx;
}

.weekly-modal__bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  height: 100%;
}

.weekly-modal__bar {
  width: 100%;
  border-radius: 6rpx 6rpx 0 0;
  background: rgba(46, 169, 133, 0.2);
  transform-origin: bottom;
  animation: weekly-bar-rise 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  margin-top: auto;
}

.weekly-modal__bar.is-peak {
  background: linear-gradient(180deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 2rpx 10rpx rgba(46, 169, 133, 0.3);
}

.weekly-modal__bar-col:nth-child(1) .weekly-modal__bar { animation-delay: 0.05s; }
.weekly-modal__bar-col:nth-child(2) .weekly-modal__bar { animation-delay: 0.12s; }
.weekly-modal__bar-col:nth-child(3) .weekly-modal__bar { animation-delay: 0.19s; }
.weekly-modal__bar-col:nth-child(4) .weekly-modal__bar { animation-delay: 0.26s; }
.weekly-modal__bar-col:nth-child(5) .weekly-modal__bar { animation-delay: 0.33s; }
.weekly-modal__bar-col:nth-child(6) .weekly-modal__bar { animation-delay: 0.40s; }
.weekly-modal__bar-col:nth-child(7) .weekly-modal__bar { animation-delay: 0.47s; }

.weekly-modal__bar-label {
  font-size: 18rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  opacity: 0.7;
}

.weekly-modal__subjects {
  display: flex;
  width: 100%;
  gap: 14rpx;
  margin-top: 22rpx;
}

.weekly-modal__subject {
  flex: 1;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weekly-modal__subject-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.weekly-modal__subject-minutes {
  font-size: 20rpx;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.2rpx;
}

.weekly-modal__suggestion {
  margin-top: 22rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.weekly-modal__cta {
  margin-top: 22rpx;
  width: 100%;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
