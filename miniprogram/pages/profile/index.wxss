.profile-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.profile-card,
.metric-card,
.auth-card {
  padding: 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(46, 169, 133, 0.08);
}

.profile-card {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.profile-card__avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.profile-card__avatar--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(99, 203, 168, 0.16) 0%, rgba(46, 169, 133, 0.22) 100%);
  color: var(--mint-600);
  font-size: 34rpx;
  font-weight: 700;
}

.profile-card__content {
  min-width: 0;
  flex: 1;
}

.profile-card__name,
.profile-card__hint {
  display: block;
}

.profile-card__name {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.profile-card__hint {
  margin-top: 10rpx;
  color: var(--text-sub);
  font-size: 24rpx;
  line-height: 1.6;
}

.auth-card {
  background:
    radial-gradient(circle at top right, rgba(94, 195, 157, 0.16), transparent 42%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 251, 245, 0.96) 100%);
}

.auth-card__badge,
.auth-card__title,
.auth-card__desc {
  display: block;
}

.auth-card__badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  min-width: 132rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 700;
}

.auth-card__title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.auth-card__desc {
  margin-top: 14rpx;
  color: var(--text-sub);
  font-size: 24rpx;
  line-height: 1.7;
}

.auth-card__button,
.profile-actions__button {
  width: 100%;
  margin-top: 28rpx;
}

.metric-card--primary {
  background:
    radial-gradient(circle at top right, rgba(94, 195, 157, 0.16), transparent 42%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 251, 245, 0.96) 100%);
}

.metric-card__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
}

.metric-card__label,
.metric-card__value,
.metric-card__sub {
  display: block;
}

.metric-card__label {
  font-size: 24rpx;
  color: var(--text-sub);
}

.metric-card__value {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.metric-card__value--small {
  font-size: 42rpx;
}

.metric-card__sub {
  font-size: 24rpx;
  color: var(--text-sub);
}

.metric-card__sub--spaced {
  margin-top: 10rpx;
}

.subject-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.subject-row__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.subject-row__name {
  font-size: 26rpx;
  font-weight: 700;
}

.subject-row__value {
  font-size: 24rpx;
  color: var(--mint-600);
  font-weight: 700;
}

.subject-row__track {
  margin-top: 10rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
}

.subject-row__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
}

.profile-actions {
  margin-top: 4rpx;
}
