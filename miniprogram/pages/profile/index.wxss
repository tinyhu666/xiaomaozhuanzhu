/* v0.30.3 — full WXSS rewrite of the upper page (hero / stat grid /
   menu / version) per docs/design-handoff/screen-profile.jsx. Modal
   sections at the bottom of this file are preserved (the user has
   not flagged them and they use a coherent visual language for
   their once-per-period moment). */

.profile-page {
  /* v0.30.3 — .page-shell (from app.wxss) already provides
     28rpx side padding and `calc(200rpx + env(safe-area-inset-bottom))`
     bottom clearance for the custom tab bar. Don't redeclare padding
     here or we lose the bottom safe-area space and the version line
     gets clipped behind the tab bar. */
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  background: transparent;
  min-height: 100vh;
  box-sizing: border-box;
}

@keyframes profile-fade-up {
  from { opacity: 0; transform: translateY(12rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.profile-page > view,
.profile-page > .profile-version {
  animation: profile-fade-up 0.4s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.profile-page > view:nth-child(1) { animation-delay: 0.04s; }
.profile-page > view:nth-child(2) { animation-delay: 0.10s; }
.profile-page > view:nth-child(3) { animation-delay: 0.16s; }
.profile-page > .profile-version { animation-delay: 0.22s; }

/* ============================================================
   Hero — avatar + nickname. Flat layout (no card chrome) per design:
   the page bg already provides the surface; chrome here would compete
   with the stat tiles below.
   ============================================================ */
.profile-hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 4rpx 8rpx;
}

.profile-hero__avatar-wrap {
  position: relative;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background: #ECF5F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-hero__avatar-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.profile-hero__avatar-placeholder {
  font-size: 52rpx;
  line-height: 1;
  color: #155946;
}

/* Invisible full-area tap target (open-type=chooseAvatar). v0.18.1
   dropped the bottom "换头像" strip — it overlapped the lower third
   of the avatar image and read as a green smear on faces. We now
   render a small 📷 chip in the corner instead (sibling element). */
.profile-hero__avatar-btn {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent !important;
  background-color: transparent !important;
  border-radius: 50%;
  line-height: 0;
  -webkit-tap-highlight-color: transparent;
  -webkit-touch-callout: none;
  outline: none;
  z-index: 2;
}

.profile-hero__avatar-btn::after {
  border: none;
  outline: none;
}

.profile-hero__avatar-btn:active {
  background: transparent !important;
  background-color: transparent !important;
  opacity: 0.92;
}

/* v0.26.1 — the .profile-hero__avatar-badge corner chip was deleted.
   It sat inside an `overflow:hidden + border-radius:50%` wrapper, so
   the circular mask clipped the square badge into a triangular green
   sliver that users read as an "unknown obstruction". The avatar's
   full-area chooseAvatar button still owns the tap target. */

.profile-hero__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.profile-hero__nickname {
  /* v0.31.1 — pinned height + line-height so the WeChat <input>
     vertical center is deterministic. Without these, the input's
     line-box height varies between iOS/Android, causing the input
     to render slightly above/below the avatar's center on real
     devices. 56rpx ≈ 40rpx font × 1.4 line-height. */
  font-size: var(--fs-t1);
  font-weight: 800;
  color: #1F2624;
  letter-spacing: -0.4rpx;
  background: transparent;
  padding: 0;
  height: 56rpx;
  line-height: 56rpx;
}

.profile-hero__hint {
  font-size: var(--fs-caption);
  color: #5E7D75;
  letter-spacing: 0.2rpx;
}

/* ============================================================
   Stat grid — 2×2. v0.30.3 simplified per design: dropped the
   "tone" left-accent strips (mint/blue/amber/rose) — they made each
   tile shout for attention; the design wants a calm primary-color
   number doing the work. All tiles now use the shared .card-v2
   surface from app.wxss.
   ============================================================ */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-tile {
  /* Inherits .card-v2 visual treatment from app.wxss via class match;
     we add the tighter padding + the value-row baseline alignment. */
  background: #FFFFFF;
  border-radius: var(--r-lg);
  border: 1rpx solid #D2E1DA;
  padding: 22rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

/* Stale tone-strip pseudo: blank background so any lingering
   .stat-tile--mint/blue/amber/rose classes in legacy view-model output
   render without the accent bar. */
.stat-tile::before { content: none; }
.stat-tile--mint::before,
.stat-tile--blue::before,
.stat-tile--amber::before,
.stat-tile--rose::before { background: transparent; }

.stat-tile__label {
  font-size: var(--fs-caption);
  color: #5E7D75;
  letter-spacing: 0.2rpx;
}

.stat-tile__value {
  font-size: 48rpx;
  font-weight: 800;
  color: #155946;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.5rpx;
  line-height: 1;
  /* baseline alignment with the unit suffix */
  display: inline-flex;
  align-items: baseline;
  gap: 6rpx;
}

.stat-tile__unit {
  font-size: var(--fs-caption);
  font-weight: 600;
  margin-left: 0;
  color: #5E7D75;
  letter-spacing: 0;
}

.stat-tile__caption {
  font-size: 20rpx;
  color: #98ABA4;
  letter-spacing: 0.2rpx;
}

/* v0.30.3 — .insights-card and .profile-quote styles fully removed.
   .insights-card was an unused subtree left over from v0.23's pattern-
   chart deletion (the WXML block was deleted, but the WXSS stayed
   because removing it last cycle felt risky). The new profile design
   doesn't have an insights surface at all, so this is dead code we can
   finally drop. */

/* ============================================================
   Menu list — single .card-v2 surface containing 4 rows separated
   by hairline strokes. v0.30.3 dropped the per-item slide-in stagger
   animation (it competed with the page-level fade) and the gradient
   card chrome (replaced with a clean .card-v2 surface).
   ============================================================ */
.menu-list {
  background: #FFFFFF;
  border: 1rpx solid #D2E1DA;
  border-radius: var(--r-lg);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-top: 1rpx solid #E3EBE7;
  transition: background var(--d-1) var(--ease-std);
  min-height: 96rpx;
  box-sizing: border-box;
}

.menu-item:first-child { border-top: none; }

.menu-item:active {
  background: #ECF5F0;
}

.menu-item__icon {
  /* Soft mint square per design (32×32 px ≈ 64rpx). The icon glyph is
     a single emoji, so the square sits comfortably above the 88rpx
     touch row without dominating. */
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #ECF5F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
  color: #155946;
}

.menu-item__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  min-width: 0;
}

.menu-item__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2624;
  letter-spacing: 0;
}

.menu-item__hint {
  font-size: var(--fs-caption);
  color: #5E7D75;
  letter-spacing: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-item__chevron {
  font-size: 32rpx;
  color: #98ABA4;
  line-height: 1;
}

.profile-version {
  display: block;
  margin-top: 16rpx;
  text-align: center;
  font-size: 20rpx;
  color: #98ABA4;
  letter-spacing: 0.5rpx;
}

/* ============================================================
   v0.18 — Monthly summary modal. Fires once per calendar month
   on the first visit to 我的 after the month rolls over. The card
   sits above a translucent backdrop; tap anywhere outside the
   card to dismiss. Visual language matches the cat-reveal modal
   on the session-complete page (same curve, same border radius)
   so the two "moment" surfaces feel related.
   ============================================================ */
@keyframes monthly-modal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes monthly-modal-pop {
  0%   { opacity: 0; transform: scale(0.85) translateY(40rpx); }
  60%  { transform: scale(1.02) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes monthly-value-rise {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.monthly-modal {
  position: fixed;
  inset: 0;
  z-index: 240;
  background: rgba(20, 60, 50, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: monthly-modal-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.monthly-modal__card {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 44rpx 36rpx 32rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.42), transparent 62%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.2);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(46, 169, 133, 0.32);
  animation: monthly-modal-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.monthly-modal__head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.monthly-modal__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--mint-600);
  padding: 4rpx 16rpx;
  background: rgba(46, 169, 133, 0.12);
  border-radius: 999rpx;
}

.monthly-modal__title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.6rpx;
  margin-top: 8rpx;
}

.monthly-modal__hero {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 18rpx;
  animation: monthly-value-rise 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) 0.18s backwards;
}

.monthly-modal__value {
  font-size: 96rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  letter-spacing: 0.5rpx;
  background: linear-gradient(135deg, #2ea985 0%, #63cba8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.monthly-modal__unit {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 0.5rpx;
}

.monthly-modal__sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  text-align: center;
}

.monthly-modal__detail-grid {
  display: flex;
  width: 100%;
  gap: 14rpx;
  margin-top: 28rpx;
}

.monthly-modal__detail {
  flex: 1;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  align-items: flex-start;
}

.monthly-modal__detail-label {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.monthly-modal__detail-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.monthly-modal__detail-caption {
  font-size: 20rpx;
  color: var(--mint-600);
  letter-spacing: 0.2rpx;
  font-feature-settings: "tnum" 1;
}

.monthly-modal__encouragement {
  margin-top: 26rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.monthly-modal__cta {
  margin-top: 26rpx;
  width: 100%;
  padding: 20rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 6rpx 16rpx rgba(46, 169, 133, 0.28);
  transition: transform 0.16s ease;
}

.monthly-modal__cta:active {
  transform: scale(0.97);
}

/* ============================================================
   v0.19 — Weekly recap modal. Same visual language as monthly,
   but the centerpiece is a 7-bar Mon..Sun chart instead of the
   single big number. Compacter overall — the recap horizon is
   shorter so the moment is smaller too.
   ============================================================ */
@keyframes weekly-modal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes weekly-modal-pop {
  0%   { opacity: 0; transform: scale(0.86) translateY(36rpx); }
  60%  { transform: scale(1.02) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes weekly-bar-rise {
  from { transform: scaleY(0); opacity: 0; }
  to { transform: scaleY(1); opacity: 1; }
}

.weekly-modal {
  position: fixed;
  inset: 0;
  z-index: 235;
  background: rgba(20, 60, 50, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: weekly-modal-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.weekly-modal__card {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 40rpx 32rpx 30rpx;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.36), transparent 62%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.2);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(46, 169, 133, 0.28);
  animation: weekly-modal-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.weekly-modal__head {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.weekly-modal__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: var(--mint-600);
  padding: 4rpx 16rpx;
  background: rgba(46, 169, 133, 0.12);
  border-radius: 999rpx;
}

.weekly-modal__title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  margin-top: 8rpx;
  font-feature-settings: "tnum" 1;
}

.weekly-modal__hero {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 14rpx;
}

.weekly-modal__value {
  font-size: 82rpx;
  font-weight: 800;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  letter-spacing: 0.5rpx;
  background: linear-gradient(135deg, #2ea985 0%, #63cba8 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  color: transparent;
}

.weekly-modal__unit {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 0.5rpx;
}

.weekly-modal__sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.weekly-modal__chart {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 10rpx;
  width: 100%;
  height: 160rpx;
  margin-top: 26rpx;
  padding: 0 4rpx;
}

.weekly-modal__bar-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  height: 100%;
}

.weekly-modal__bar {
  width: 100%;
  border-radius: 6rpx 6rpx 0 0;
  background: rgba(46, 169, 133, 0.2);
  transform-origin: bottom;
  animation: weekly-bar-rise 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  margin-top: auto;
}

.weekly-modal__bar.is-peak {
  background: linear-gradient(180deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 2rpx 10rpx rgba(46, 169, 133, 0.3);
}

.weekly-modal__bar-col:nth-child(1) .weekly-modal__bar { animation-delay: 0.05s; }
.weekly-modal__bar-col:nth-child(2) .weekly-modal__bar { animation-delay: 0.12s; }
.weekly-modal__bar-col:nth-child(3) .weekly-modal__bar { animation-delay: 0.19s; }
.weekly-modal__bar-col:nth-child(4) .weekly-modal__bar { animation-delay: 0.26s; }
.weekly-modal__bar-col:nth-child(5) .weekly-modal__bar { animation-delay: 0.33s; }
.weekly-modal__bar-col:nth-child(6) .weekly-modal__bar { animation-delay: 0.40s; }
.weekly-modal__bar-col:nth-child(7) .weekly-modal__bar { animation-delay: 0.47s; }

.weekly-modal__bar-label {
  font-size: 18rpx;
  color: var(--text-sub);
  letter-spacing: 0.2rpx;
  opacity: 0.7;
}

.weekly-modal__subjects {
  display: flex;
  width: 100%;
  gap: 14rpx;
  margin-top: 22rpx;
}

.weekly-modal__subject {
  flex: 1;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weekly-modal__subject-name {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.weekly-modal__subject-minutes {
  font-size: 20rpx;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.2rpx;
}

.weekly-modal__suggestion {
  margin-top: 22rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-sub);
  text-align: center;
  letter-spacing: 0.3rpx;
}

.weekly-modal__cta {
  margin-top: 22rpx;
  width: 100%;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 6rpx 16rpx rgba(46, 169, 133, 0.28);
  transition: transform 0.16s ease;
}

.weekly-modal__cta:active {
  transform: scale(0.97);
}
