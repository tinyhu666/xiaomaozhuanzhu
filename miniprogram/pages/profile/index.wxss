.profile-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ----- Hero (avatar + nickname) ----- */
.profile-hero {
  position: relative;
  display: flex;
  align-items: center;
  gap: 26rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.18), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.1);
}

/*
 * WeChat <button> elements ship with hard-coded width/min-width rules
 * that override CSS even when we set width: 132rpx — that's what made
 * the avatar render as a wide ellipse on iOS. Fix: a fixed-size
 * <view> wrapper controls the visual circle (with overflow:hidden),
 * and a transparent absolute-positioned button sits on top purely as
 * the chooseAvatar tap target.
 */
.profile-hero__avatar-wrap {
  position: relative;
  width: 132rpx;
  height: 132rpx;
  flex-shrink: 0;
  border-radius: 50%;
  overflow: hidden;
  background: linear-gradient(135deg, #c2ead2 0%, #6fc99a 100%);
  box-shadow: 0 8rpx 20rpx rgba(46, 169, 133, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-hero__avatar-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.profile-hero__avatar-placeholder {
  font-size: 64rpx;
  line-height: 1;
}

.profile-hero__avatar-btn {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  border: none;
  background: transparent;
  border-radius: 50%;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  line-height: 1;
}

.profile-hero__avatar-btn::after {
  border: none;
}

.profile-hero__avatar-edit {
  width: 100%;
  padding: 6rpx 0 8rpx;
  font-size: 18rpx;
  color: #fff;
  background: rgba(34, 129, 104, 0.85);
  text-align: center;
  letter-spacing: 1rpx;
}

/* Daily quote — small editorial card moved here from home in v0.9.4
   so the home page stays focused on actions and the profile page
   carries the daily-personality content. Compact compared to the
   home version: no large mark glyph, smaller English line, no side
   rail — just enough to feel hand-crafted without dominating. */
.profile-quote {
  position: relative;
  padding: 22rpx 26rpx 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 38%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 18rpx -4rpx rgba(46, 169, 133, 0.06);
}

.profile-quote__chip {
  display: inline-flex;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  border: 1rpx solid rgba(46, 169, 133, 0.16);
  font-size: 18rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 1.2rpx;
  margin-bottom: 14rpx;
}

.profile-quote__en {
  display: block;
  font-family: Georgia, "Times New Roman", "PingFang SC", serif;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #155946;
  letter-spacing: 0.2rpx;
}

.profile-quote__zh {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 400;
  line-height: 1.65;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

.profile-hero__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.profile-hero__nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  background: transparent;
  padding: 4rpx 0;
}

.profile-hero__hint {
  font-size: 20rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

/* ----- Stat grid 4 tiles ----- */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.stat-tile {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 24rpx 24rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 8rpx 24rpx -4rpx rgba(46, 169, 133, 0.06);
}

.stat-tile__value {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
  line-height: 1;
}

.stat-tile__unit {
  font-size: 26rpx;
  font-weight: 600;
  margin-left: 4rpx;
  color: var(--mint-500);
}

.stat-tile__label {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

/* (Exam countdown card removed from 我的 in v0.9.4 — it now lives on
   the home page as the prominent hero countdown.) */

/* ----- Menu list ----- */
.menu-list {
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 8rpx 24rpx -4rpx rgba(46, 169, 133, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 26rpx 28rpx;
  border-top: 1rpx solid rgba(46, 169, 133, 0.08);
  transition: background 0.15s ease;
}

.menu-item:first-child {
  border-top: none;
}

.menu-item:active {
  background: rgba(46, 169, 133, 0.06);
}

.menu-item__icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 16rpx;
  background: rgba(46, 169, 133, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.menu-item__body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.menu-item__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.menu-item__hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.menu-item__chevron {
  font-size: 32rpx;
  color: var(--text-sub);
  opacity: 0.55;
}

.profile-version {
  display: block;
  margin-top: 12rpx;
  text-align: center;
  font-size: 20rpx;
  color: rgba(94, 125, 117, 0.55);
  letter-spacing: 1rpx;
}
