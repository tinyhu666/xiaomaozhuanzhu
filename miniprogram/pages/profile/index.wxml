<view class="page-shell profile-page">
  <view class="profile-card">
    <image
      wx:if="{{profile && profile.avatarUrl}}"
      class="profile-card__avatar"
      src="{{profile.avatarUrl}}"
      mode="aspectFill"
    />
    <view wx:else class="profile-card__avatar profile-card__avatar--placeholder">我</view>

    <view class="profile-card__content">
      <text class="profile-card__name">{{profile ? (profile.nickname || 'CPA考生') : 'CPA考生'}}</text>
      <text class="profile-card__hint">微信昵称和头像会同步到这里，学习成果也会持续累积。</text>
    </view>
  </view>

  <view class="metric-card metric-card--primary">
    <text class="metric-card__label">累计学习时长</text>
    <text class="metric-card__value">{{totalMinutesText}}</text>
  </view>

  <view class="metric-card">
    <view class="metric-card__header">
      <text class="metric-card__label">各科总时长</text>
      <text class="metric-card__sub">{{subjectRows.length}}科</text>
    </view>

    <view wx:if="{{subjectRows.length}}" class="subject-list">
      <view wx:for="{{subjectRows}}" wx:key="subject" class="subject-row">
        <view class="subject-row__top">
          <text class="subject-row__name">{{item.subject}}</text>
          <text class="subject-row__value">{{item.durationText}}</text>
        </view>
        <view class="subject-row__track">
          <view class="subject-row__fill" style="{{item.barStyle}}"></view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">还没有按科目累积出学习记录</view>
  </view>

  <view class="metric-card">
    <text class="metric-card__label">最长学习日</text>
    <text class="metric-card__value metric-card__value--small">{{bestDayDateText}}</text>
    <text class="metric-card__sub metric-card__sub--spaced">{{bestDayDurationText}}</text>
  </view>

  <view class="profile-actions">
    <button class="cta-button profile-actions__button" bindtap="syncWechatProfile">同步微信资料</button>
  </view>
</view>
