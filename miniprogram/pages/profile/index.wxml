<view class="page-shell profile-page">
  <!--
    Hero — the official WeChat "登录 / 完善资料" pattern: tap the
    avatar to choose from your WeChat photos (open-type=chooseAvatar);
    tap the nickname row to pull your WeChat nickname into the input
    (type=nickname). These are the only two APIs WeChat still allows
    for self-served profile capture since 2022, so there is no
    cleaner / one-click path possible. We just make the two tap
    targets visually obvious and stop adding extra CTAs.
  -->
  <view class="profile-hero">
    <view class="profile-hero__avatar-wrap">
      <image
        wx:if="{{profile.avatarUrl}}"
        class="profile-hero__avatar-img"
        src="{{profile.avatarUrl}}"
        mode="aspectFill"
      />
      <text wx:else class="profile-hero__avatar-placeholder">🐱</text>
      <button
        class="profile-hero__avatar-btn"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
        aria-label="选择头像"
      >
        <text class="profile-hero__avatar-edit">{{profile.avatarUrl ? '换头像' : '设头像'}}</text>
      </button>
    </view>
    <view class="profile-hero__body">
      <input
        class="profile-hero__nickname"
        type="nickname"
        placeholder="点此设置昵称"
        value="{{profile.nickname}}"
        focus="{{nicknameFocus}}"
        bindblur="onNicknameBlur"
      />
      <text class="profile-hero__hint">点头像换头像 · 点昵称栏从微信导入</text>
    </view>
  </view>

  <!-- Daily quote — small, persistent personality on the profile page
       (moved out of home in v0.9.3 to keep home action-focused). -->
  <view class="profile-quote">
    <view class="profile-quote__chip">{{quoteDateLabel}}</view>
    <text class="profile-quote__en">{{quoteEn}}</text>
    <text class="profile-quote__zh">{{quoteZh}}</text>
  </view>

  <view class="stat-grid">
    <view class="stat-tile">
      <text class="stat-tile__value">{{totalText}}</text>
      <text class="stat-tile__label">累计学习</text>
    </view>
    <view class="stat-tile">
      <text class="stat-tile__value">{{completedCount}}</text>
      <text class="stat-tile__label">完成打卡</text>
    </view>
    <view class="stat-tile">
      <text class="stat-tile__value">{{currentStreak}}<text class="stat-tile__unit">天</text></text>
      <text class="stat-tile__label">当前连签</text>
    </view>
    <view class="stat-tile">
      <text class="stat-tile__value">{{longestStreak}}<text class="stat-tile__unit">天</text></text>
      <text class="stat-tile__label">最长连签</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="openBadges">
      <view class="menu-item__icon">🏆</view>
      <view class="menu-item__body">
        <text class="menu-item__title">徽章</text>
        <text class="menu-item__hint">{{badgeProgressLabel}}</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openSubjects">
      <view class="menu-item__icon">📚</view>
      <view class="menu-item__body">
        <text class="menu-item__title">六科进度</text>
        <text class="menu-item__hint">{{subjectsHint}}</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openShare">
      <view class="menu-item__icon">🔗</view>
      <view class="menu-item__body">
        <text class="menu-item__title">公开学习页</text>
        <text class="menu-item__hint">{{shareHint}}</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
  </view>

  <text class="profile-version">小猫专注 · v{{appVersion}}</text>
</view>
