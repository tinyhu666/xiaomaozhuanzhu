<view class="page-shell profile-page">
  <!--
    Hero — official WeChat profile-capture pattern (chooseAvatar +
    type=nickname). The verbose hint line was dropped in v0.15;
    the two tap targets are clear enough without further explanation.
  -->
  <view class="profile-hero">
    <view class="profile-hero__avatar-wrap">
      <image
        wx:if="{{profile.avatarUrl}}"
        class="profile-hero__avatar-img"
        src="{{profile.avatarUrl}}"
        mode="aspectFill"
      />
      <text wx:else class="profile-hero__avatar-placeholder">🐱</text>
      <!-- Full-area tap target stays for "tap anywhere on the avatar
           to change". The visible affordance shrinks to a small 📷
           chip in the bottom-right corner so it stops covering the
           user's face on small avatars (v0.18.1 fix). -->
      <button
        class="profile-hero__avatar-btn"
        hover-class="none"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
      ></button>
      <view class="profile-hero__avatar-badge">
        <text class="profile-hero__avatar-badge-icon">📷</text>
      </view>
    </view>
    <view class="profile-hero__body">
      <input
        class="profile-hero__nickname"
        type="nickname"
        placeholder="点此设置昵称"
        value="{{profile.nickname}}"
        focus="{{nicknameFocus}}"
        bindblur="onNicknameBlur"
      />
      <text wx:if="{{!profile.nickname}}" class="profile-hero__hint">支持一键导入微信昵称</text>
    </view>
  </view>

  <!--
    Compact 2×2 stat grid — merged the "personal records" row in
    v0.15. Each tile carries label + value + tiny caption (for
    records) or no caption (for cumulative totals). Removed the
    separate insights title text from the old 3-section layout.
  -->
  <view class="stat-grid">
    <view wx:for="{{statTiles}}" wx:key="key" class="stat-tile stat-tile--{{item.tone}}">
      <text class="stat-tile__label">{{item.label}}</text>
      <text class="stat-tile__value">{{item.value}}<text wx:if="{{item.unit}}" class="stat-tile__unit">{{item.unit}}</text></text>
      <text wx:if="{{item.caption}}" class="stat-tile__caption">{{item.caption}}</text>
    </view>
  </view>

  <!--
    Insights — 24h focus pattern. Compacted in v0.15: smaller title
    block (no separate "title + sub" rows), thinner bars, peak hour
    callout pinned on the right. Only renders when there's data.
  -->
  <view wx:if="{{insights.hasData}}" class="insights-card">
    <view class="insights-card__head">
      <text class="insights-card__title">学习时段</text>
      <text class="insights-card__peak">{{insights.peakHourLabel}} · {{insights.peakWeekdayLabel}}</text>
    </view>
    <view class="insights-card__chart">
      <view
        wx:for="{{insights.bars}}"
        wx:key="index"
        class="insights-card__bar {{item.isPeak ? 'is-peak' : ''}}"
        style="height: {{item.height}}%; animation-delay: {{index * 18}}ms;"
      ></view>
    </view>
  </view>

  <view class="profile-quote">
    <text class="profile-quote__en">{{quoteEn}}</text>
    <text class="profile-quote__zh">— {{quoteZh}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="openGarden">
      <view class="menu-item__icon">🐱</view>
      <view class="menu-item__body">
        <text class="menu-item__title">小猫花园</text>
        <text class="menu-item__hint">每完成一次专注收一只小猫</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openBadges">
      <view class="menu-item__icon">🏆</view>
      <view class="menu-item__body">
        <text class="menu-item__title">徽章</text>
        <text class="menu-item__hint">{{badgeProgressLabel}}</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openSubjects">
      <view class="menu-item__icon">📚</view>
      <view class="menu-item__body">
        <text class="menu-item__title">六科进度</text>
        <text class="menu-item__hint">{{subjectsHint}}</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openSettings">
      <view class="menu-item__icon">⚙️</view>
      <view class="menu-item__body">
        <text class="menu-item__title">学习设置</text>
        <text class="menu-item__hint">目标 · 番茄钟</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openPoster">
      <view class="menu-item__icon">🎴</view>
      <view class="menu-item__body">
        <text class="menu-item__title">学习日报</text>
        <text class="menu-item__hint">生成可分享的打卡卡片</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
    <view class="menu-item" bindtap="openShare">
      <view class="menu-item__icon">🔗</view>
      <view class="menu-item__body">
        <text class="menu-item__title">公开学习页</text>
        <text class="menu-item__hint">{{shareHint}}</text>
      </view>
      <text class="menu-item__chevron">›</text>
    </view>
  </view>

  <text class="profile-version">小猫专注 · v{{appVersion}}</text>

  <!--
    v0.19 — weekly recap modal. Fires Sun 18:00 / Mon ≤ 06:00 / with
    catch-up Tue-Sat if the prior week wasn't shown yet. Storage-gated
    (cpa.weeklyRecap.lastSeen). Visual language matches the monthly
    modal but compacter — 7-bar weekly chart is the centerpiece.
  -->
  <view wx:if="{{weeklyRecap}}" class="weekly-modal" bindtap="onTapWeeklyDismiss">
    <view class="weekly-modal__card" catchtap="onTapWeeklyContent">
      <view class="weekly-modal__head">
        <text class="weekly-modal__eyebrow">本周小结</text>
        <text class="weekly-modal__title">{{weeklyRecap.rangeLabel}}</text>
      </view>

      <view class="weekly-modal__hero">
        <text class="weekly-modal__value">{{weeklyRecap.totalMinutes}}</text>
        <text class="weekly-modal__unit">分钟</text>
      </view>
      <text class="weekly-modal__sub">{{weeklyRecap.sessionCount}} 次专注 · {{weeklyRecapChangeText}}</text>

      <view class="weekly-modal__chart">
        <view
          wx:for="{{weeklyRecapBars}}"
          wx:key="label"
          class="weekly-modal__bar-col"
        >
          <view class="weekly-modal__bar {{item.isPeak ? 'is-peak' : ''}}" style="height: {{item.heightPercent}}%"></view>
          <text class="weekly-modal__bar-label">{{item.label}}</text>
        </view>
      </view>

      <view wx:if="{{weeklyRecap.topSubjects.length}}" class="weekly-modal__subjects">
        <view wx:for="{{weeklyRecap.topSubjects}}" wx:key="name" class="weekly-modal__subject">
          <text class="weekly-modal__subject-name">{{item.name}}</text>
          <text class="weekly-modal__subject-minutes">{{item.minutes}} 分钟</text>
        </view>
      </view>

      <text class="weekly-modal__suggestion">{{weeklyRecap.suggestion}}</text>

      <view class="weekly-modal__cta" bindtap="onTapWeeklyDismiss">下周继续</view>
    </view>
  </view>

  <!--
    v0.18 — monthly summary modal. Fires once per calendar month on
    the first time the user opens 我的 after a new month begins.
    Storage-gated; see utils/monthly.ts. The card is a one-shot
    "look back" moment — no actions beyond dismiss.
  -->
  <view wx:if="{{monthlySummary}}" class="monthly-modal" bindtap="onTapMonthlyDismiss">
    <view class="monthly-modal__card" catchtap="onTapMonthlyContent">
      <view class="monthly-modal__head">
        <text class="monthly-modal__eyebrow">月度小结</text>
        <text class="monthly-modal__title">{{monthlySummary.monthLabel}}</text>
      </view>

      <view class="monthly-modal__hero">
        <text class="monthly-modal__value">{{monthlySummary.totalMinutes}}</text>
        <text class="monthly-modal__unit">分钟</text>
      </view>
      <text class="monthly-modal__sub">完成 {{monthlySummary.sessionCount}} 次专注 · {{monthlyChangeText}}</text>

      <view class="monthly-modal__detail-grid">
        <view wx:if="{{monthlySummary.bestDay}}" class="monthly-modal__detail">
          <text class="monthly-modal__detail-label">最佳一天</text>
          <text class="monthly-modal__detail-value">{{monthlySummary.bestDay.dateLabel}}</text>
          <text class="monthly-modal__detail-caption">{{monthlySummary.bestDay.minutes}} 分钟</text>
        </view>
        <view wx:if="{{monthlySummary.topSubject}}" class="monthly-modal__detail">
          <text class="monthly-modal__detail-label">主攻科目</text>
          <text class="monthly-modal__detail-value">{{monthlySummary.topSubject.name}}</text>
          <text class="monthly-modal__detail-caption">{{monthlySummary.topSubject.minutes}} 分钟</text>
        </view>
      </view>

      <text class="monthly-modal__encouragement">{{monthlySummary.encouragement}}</text>

      <view class="monthly-modal__cta" bindtap="onTapMonthlyDismiss">继续努力</view>
    </view>
  </view>
</view>
