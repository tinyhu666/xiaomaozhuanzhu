<view class="page-shell profile-page">
  <view class="profile-card">
    <image
      wx:if="{{(profile && profile.avatarUrl) || avatarDraftUrl}}"
      class="profile-card__avatar"
      src="{{(profile && profile.avatarUrl) || avatarDraftUrl}}"
      mode="aspectFill"
    />
    <view wx:else class="profile-card__avatar profile-card__avatar--placeholder">我</view>

    <view class="profile-card__content">
      <text class="profile-card__name">
        {{profile && profile.nickname ? profile.nickname : (nicknameDraft || '微信未登录')}}
      </text>
      <text class="profile-card__hint">
        {{needsProfile ? '登录后将使用微信昵称和头像完成个人信息同步。' : '个人信息已同步，昵称和头像均来自微信用户信息。'}}
      </text>
    </view>
  </view>

  <view wx:if="{{needsProfile}}" class="auth-card">
    <view class="auth-card__badge">微信登录</view>
    <text class="auth-card__title">这里只保留个人信息展示和微信登录</text>
    <text class="auth-card__desc">
      {{pendingStartAfterAuth ? '完成登录后会自动回到首页，并继续开始这次计时。' : '登录后会同步微信昵称与头像，用于个人信息展示与学习记录。'}}
    </text>

    <view class="auth-form">
      <button class="auth-avatar-picker" open-type="chooseAvatar" bindchooseavatar="handleChooseAvatar">
        <image wx:if="{{avatarDraftUrl}}" class="auth-avatar-picker__preview" src="{{avatarDraftUrl}}" mode="aspectFill" />
        <view wx:else class="auth-avatar-picker__placeholder">选择微信头像</view>
      </button>

      <input
        class="auth-input"
        type="nickname"
        maxlength="20"
        placeholder="请输入微信昵称"
        value="{{nicknameDraft}}"
        bindinput="handleNicknameInput"
        bindnicknamereview="handleNicknameReview"
      />

      <button class="cta-button auth-card__button" loading="{{authLoading}}" disabled="{{authLoading}}" bindtap="submitWechatLogin">
        {{authButtonText}}
      </button>
    </view>
  </view>

  <view wx:else class="status-card">
    <text class="status-card__title">个人信息</text>
    <text class="status-card__desc">昵称和头像已经同步完成，当前页面仅保留资料展示。</text>
  </view>
</view>
