<view class="page-shell">
  <view class="hero-card">
    <view class="badge">个人公开主页</view>
    <view class="title" style="margin-top: 18rpx;">把坚持学习的证据分享出去</view>
    <view class="subtitle">分享后，别人登录小程序就能看到你的热力日历、照片和近期总结。</view>
  </view>

  <view class="stats-grid" style="margin-top: 24rpx;">
    <view class="stat-card">
      <view class="stat-value">{{totalMinutesText}}</view>
      <view class="stat-label">累计学习</view>
    </view>
    <view class="stat-card">
      <view class="stat-value">{{streakText}}</view>
      <view class="stat-label">当前连续</view>
    </view>
  </view>

  <view class="surface-card" style="margin-top: 20rpx;">
    <view style="display: flex; align-items: center; justify-content: space-between;">
      <view>
        <view class="section-title" style="margin-bottom: 6rpx;">公开主页</view>
        <view class="subtitle" style="margin-top: 0;">打开后，别人可以看到你的学习成果。</view>
      </view>
      <switch checked="{{profile && profile.isPublic}}" color="#2ea985" bindchange="handlePublicChange" />
    </view>
  </view>

  <view class="surface-card" style="margin-top: 20rpx;">
    <view class="section-title">分享路径</view>
    <view class="subtitle" style="margin-top: 0;">{{sharePath}}</view>
    <view style="display: flex; gap: 16rpx; margin-top: 24rpx;">
      <button class="ghost-button" style="flex: 1;" bindtap="copySharePath">复制路径</button>
      <button class="cta-button" style="flex: 1;" bindtap="previewPublicPage">预览主页</button>
    </view>
  </view>
</view>

