<view class="page-shell news-page">
  <view class="news-hero">
    <view class="news-hero__title">考试动态</view>
    <view class="news-hero__subtitle">CPA 报名 / 大纲 / 备考资料 · 来源：中注协 + 编辑精选</view>
  </view>

  <view class="news-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="news-tab {{activeCategory === item.key ? 'is-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSwitchTab"
    >{{item.label}}</view>
  </view>

  <view wx:if="{{loading && items.length === 0}}" class="news-skeleton">
    <view class="news-skeleton__row" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <view wx:elif="{{!loading && errorMessage}}" class="news-empty news-empty--error">
    <view class="news-empty__icon">⚠️</view>
    <view class="news-empty__title">加载失败</view>
    <view class="news-empty__text">{{errorMessage}}</view>
    <view class="news-empty__hint">下拉页面试试重新加载</view>
  </view>

  <view wx:elif="{{!loading && items.length === 0}}" class="news-empty">
    <view class="news-empty__icon">📭</view>
    <view class="news-empty__title">还没有内容</view>
    <view class="news-empty__hint">下拉刷新看看，或切换其他分类</view>
  </view>

  <view wx:else class="news-list">
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="news-row"
      data-id="{{item.id}}"
      bindtap="onTapItem"
      hover-class="news-row--hover"
      hover-stay-time="120"
    >
      <view class="news-row__header">
        <text class="news-row__cat news-row__cat--{{item.category}}">{{item.categoryLabel}}</text>
        <text class="news-row__date">{{item.dateText}}</text>
      </view>
      <view class="news-row__title">{{item.title}}</view>
      <view wx:if="{{item.summary}}" class="news-row__summary">{{item.summary}}</view>
    </view>

    <view wx:if="{{loadingMore}}" class="news-foot">加载中…</view>
    <view wx:elif="{{!nextBefore && items.length > 0}}" class="news-foot">— 没有更多了 —</view>
  </view>
</view>
