.news-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* Hero ------------------------------------------------------------ */
.news-hero {
  position: relative;
  padding: 32rpx 32rpx 28rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.22), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.1);
}

.news-hero__title {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.5rpx;
}

.news-hero__subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

/* Tabs ------------------------------------------------------------ */
.news-tabs {
  display: flex;
  gap: 12rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
}

.news-tab {
  flex: 1;
  padding: 16rpx 0;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-sub);
  border-radius: 999rpx;
  transition: all 0.18s ease;
}

.news-tab.is-active {
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 6rpx 18rpx rgba(46, 169, 133, 0.24);
}

/* Skeleton / empty ------------------------------------------------ */
.news-skeleton {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.news-skeleton__row {
  height: 132rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, rgba(46, 169, 133, 0.06) 0%, rgba(46, 169, 133, 0.12) 50%, rgba(46, 169, 133, 0.06) 100%);
  background-size: 200% 100%;
  animation: news-shimmer 1.4s linear infinite;
}

@keyframes news-shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

.news-empty {
  padding: 72rpx 0;
  text-align: center;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx dashed rgba(46, 169, 133, 0.18);
}

.news-empty__icon {
  font-size: 64rpx;
  margin-bottom: 14rpx;
}

.news-empty__text {
  font-size: 26rpx;
  color: var(--text-sub);
}

/* List ------------------------------------------------------------ */
.news-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.news-row {
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 18rpx -4rpx rgba(46, 169, 133, 0.06);
  transition: transform 0.15s ease, box-shadow 0.18s ease;
}

.news-row:active {
  transform: scale(0.985);
  box-shadow: 0 3rpx 8rpx rgba(46, 169, 133, 0.06);
}

.news-row__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.news-row__cat {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.news-row__cat--announce { background: rgba(229, 158, 87, 0.18); color: #b56823; }
.news-row__cat--outline  { background: rgba(94, 116, 200, 0.18); color: #3a4a92; }
.news-row__cat--news     { background: rgba(46, 169, 133, 0.18); color: #1d7e63; }

.news-row__date {
  font-size: 20rpx;
  color: var(--text-sub);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.news-row__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.45;
  letter-spacing: 0.2rpx;
}

.news-foot {
  padding: 20rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.7;
}
