.calendar-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

@keyframes calendar-fade-up {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.calendar-page > view {
  animation: calendar-fade-up 0.45s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.calendar-page > view:nth-child(1) { animation-delay: 0.04s; }
.calendar-page > view:nth-child(2) { animation-delay: 0.1s; }
.calendar-page > view:nth-child(3) { animation-delay: 0.16s; }

.calendar-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calendar-hero__center {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.calendar-hero__title,
.calendar-hero__meta {
  display: block;
}

.calendar-hero__title {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 0.4rpx;
  font-feature-settings: "tnum" 1;
}

.calendar-hero__meta {
  margin-top: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.calendar-hero__nav {
  flex: 0 0 auto;
  padding: 0 24rpx;
  height: 58rpx;
  line-height: 58rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.94) 0%, rgba(245, 252, 248, 0.94) 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 4rpx 12rpx rgba(46, 169, 133, 0.06);
  color: var(--mint-600);
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.4rpx;
  text-align: center;
  white-space: nowrap;
  transition: transform 0.15s ease, background 0.2s ease;
}

.calendar-hero__nav--hover {
  background: rgba(46, 169, 133, 0.16);
  transform: scale(0.97);
}

.calendar-board,
.day-panel {
  position: relative;
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.16), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 1rpx 2rpx rgba(20, 60, 50, 0.03),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.08);
}

.calendar-board__weekdays {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  text-align: center;
}

.calendar-board__grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.calendar-board__cell {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  padding: 8rpx 4rpx;
  border-radius: 20rpx;
  background: #f0f6f3;
  border: 2rpx solid #d8e8e0;
  box-sizing: border-box;
  transition: background 0.25s ease, border-color 0.25s ease, transform 0.15s ease;
}

.calendar-board__cell:active {
  transform: scale(0.94);
}

.calendar-board__cell.is-faded {
  opacity: 0.32;
}

.calendar-board__cell.is-selected {
  outline: 4rpx solid rgba(46, 169, 133, 0.32);
}

.calendar-board__cell.is-today {
  border-color: var(--mint-600);
  border-width: 3rpx;
}

.calendar-board__cell.is-today .calendar-board__day {
  font-weight: 800;
}

/* Subtle vertical gradient on each heat level so cells look "filled
   in" rather than flat-colored — gives the heat-map a designed feel. */
.calendar-board__cell.level-1 {
  background: linear-gradient(180deg, #c2ead2 0%, #a4dcc0 100%);
  border-color: #8fd1ad;
}

.calendar-board__cell.level-2 {
  background: linear-gradient(180deg, #80d3a4 0%, #5fc491 100%);
  border-color: #4eb27e;
}

.calendar-board__cell.level-3 {
  background: linear-gradient(180deg, #3fb693 0%, #228168 100%);
  border-color: #228168;
}

.calendar-board__cell.level-4 {
  background: linear-gradient(180deg, #258266 0%, #135a43 100%);
  border-color: #135a43;
}

.calendar-board__cell.level-5 {
  background: linear-gradient(180deg, #115239 0%, #073323 100%);
  border-color: #073323;
}

.calendar-board__cell.level-3 .calendar-board__day,
.calendar-board__cell.level-3 .calendar-board__minutes,
.calendar-board__cell.level-4 .calendar-board__day,
.calendar-board__cell.level-4 .calendar-board__minutes,
.calendar-board__cell.level-5 .calendar-board__day,
.calendar-board__cell.level-5 .calendar-board__minutes {
  color: #ffffff;
}

.calendar-board__day {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.calendar-board__minutes {
  margin-top: 4rpx;
  font-size: 18rpx;
  font-weight: 500;
  line-height: 1;
  color: var(--text-sub);
  opacity: 0.85;
}

.calendar-board__legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

/* v0.23 — horizontal compact legend: "少 □ □ □ ▣ ▣ ▣ 多" in one row.
   Drops the per-tier text label since the gradient already reads
   intuitively (most heat-map UIs use this pattern, à la GitHub). */
.calendar-board__legend--horizontal {
  gap: 8rpx;
  margin-top: 18rpx;
  flex-wrap: nowrap;
}

.calendar-board__legend--horizontal .calendar-board__legend-swatch {
  width: 24rpx;
  height: 24rpx;
}

.calendar-board__legend-label {
  font-size: 18rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  line-height: 1;
  margin: 0 6rpx;
  opacity: 0.7;
}

.calendar-board__legend-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.calendar-board__legend-swatch {
  width: 32rpx;
  height: 32rpx;
  border-radius: 6rpx;
  border: 2rpx solid rgba(46, 169, 133, 0.18);
  box-sizing: border-box;
}

.calendar-board__legend-swatch.level-0 {
  background: #f0f6f3;
  border-color: #d8e8e0;
}

.calendar-board__legend-swatch.level-1 {
  background: #b3e3c7;
  border-color: #8fd1ad;
}

.calendar-board__legend-swatch.level-2 {
  background: #6fc99a;
  border-color: #4eb27e;
}

.calendar-board__legend-swatch.level-3 {
  background: #2ea985;
  border-color: #228168;
}

.calendar-board__legend-swatch.level-4 {
  background: #1a7558;
  border-color: #135a43;
}

.calendar-board__legend-swatch.level-5 {
  background: #0a4631;
  border-color: #073323;
}

.calendar-board__legend-text {
  font-size: 20rpx;
  color: var(--text-sub);
  line-height: 1;
}

.day-panel__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.day-panel__date,
.day-panel__meta,
.day-panel__total {
  display: block;
}

.day-panel__date {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 0.4rpx;
  font-feature-settings: "tnum" 1;
}

.day-panel__meta {
  margin-top: 8rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  letter-spacing: 0.3rpx;
}

.day-panel__total {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.day-panel__sessions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.session-item {
  position: relative;
  padding: 24rpx 22rpx 22rpx 30rpx;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(46, 169, 133, 0.06) 0%, rgba(46, 169, 133, 0.03) 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.5);
}

/* Slim left rail with subtle gradient. */
.session-item::before {
  content: "";
  position: absolute;
  left: 14rpx;
  top: 26rpx;
  bottom: 26rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, var(--mint-400) 0%, var(--mint-500) 100%);
  opacity: 0.7;
}

.session-item__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.session-item__subject {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.session-item__duration {
  font-size: 24rpx;
  font-weight: 800;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.session-item__summary {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
  opacity: 0.86;
}

.session-item__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.session-item__tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.session-item__photos {
  white-space: nowrap;
  margin-top: 18rpx;
}

.session-item__photo {
  display: inline-block;
  width: 148rpx;
  height: 148rpx;
  margin-right: 10rpx;
  border-radius: 16rpx;
  background: rgba(46, 169, 133, 0.06);
  transition: transform 0.18s ease;
}

.session-item__photo:active {
  transform: scale(0.97);
}

/* v0.26 — empty-month hint card. Sits between the hero and the heat
   grid when the month has no recorded sessions. Soft mint background
   so it doesn't shout; sits compact in one stack. */
.calendar-empty-month {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 22rpx 28rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.18), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.08);
  margin-bottom: 12rpx;
}

.calendar-empty-month__icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.calendar-empty-month__text {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.calendar-empty-month__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  opacity: 0.8;
  letter-spacing: 0.2rpx;
}

/* GPT image2 redesign pass */
.calendar-page {
  gap: 24rpx;
}

.calendar-hero {
  padding: 8rpx 0 4rpx;
}

.calendar-hero__title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1F2624;
}

.calendar-hero__meta {
  color: #5E7D75;
  font-size: 22rpx;
}

.calendar-hero__nav {
  /* v0.32.5 — height 56→76rpx + wider padding. 上月/下月 is primary
     calendar navigation; 56rpx (≈28pt) was below the comfortable
     tap-target floor and easy to miss. 76rpx (≈38pt) + 28rpx side
     padding gives a reliable hit area. */
  min-width: 96rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ECF5F0;
  border: 1rpx solid #DCEAE3;
  box-shadow: none;
  color: #155946;
  font-size: 24rpx;
  text-align: center;
}

.calendar-board,
.day-panel,
.calendar-empty-month {
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #D2E1DA;
  box-shadow: 0 2rpx 8rpx rgba(20, 60, 50, 0.04);
}

.calendar-board {
  padding: 24rpx;
}

/* v0.42.1 — column layout removed here. This redesign-era block used
   `display:flex; flex-wrap:wrap` + `width: calc(14.285% - 8rpx)`, which on
   rpx rounding overflowed by a sub-pixel and wrapped the 7th column (日
   stacked under 一). The robust `display:grid; repeat(7, 1fr)` rule above
   is now the single source of column layout. Visual-only rules stay. */
.calendar-board__weekdays text {
  color: #5E7D75;
  font-size: 20rpx;
  text-align: center;
}

.calendar-board__grid {
  margin-top: 16rpx;
}

.calendar-board__cell {
  height: 88rpx;
  border-radius: 16rpx;
  border: 1rpx solid #DCEAE3;
  background: #ECF5F0;
}

.calendar-board__cell.level-1 { background: #C8E4D5; border-color: #B5D9C7; }
.calendar-board__cell.level-2 { background: #95CDB1; border-color: #7FBF9E; }
.calendar-board__cell.level-3 { background: #5CB489; border-color: #4A9B74; }
.calendar-board__cell.level-4 { background: #2E9869; border-color: #277E59; }
.calendar-board__cell.level-5 { background: #155946; border-color: #155946; }

.calendar-board__cell.is-selected {
  outline: 4rpx solid rgba(21, 89, 70, 0.24);
}

.calendar-board__cell.is-today {
  border-color: #155946;
}

.calendar-board__day {
  color: #1F2624;
  font-size: 24rpx;
  font-weight: 600;
}

.calendar-board__minutes {
  color: #5E7D75;
  font-size: 18rpx;
}

.calendar-board__legend--horizontal {
  margin-top: 14rpx;
}

.calendar-board__legend-swatch {
  border-radius: 4rpx;
}

.day-panel {
  padding: 24rpx;
}

.day-panel__date {
  color: #1F2624;
  font-size: 32rpx;
}

.day-panel__total {
  color: #155946;
  font-size: 32rpx;
}

.session-item {
  padding: 22rpx 22rpx 22rpx 24rpx;
  border-radius: 16rpx;
  background: #F8FCFA;
  border: 1rpx solid #E3EBE7;
  box-shadow: none;
}

.session-item::before {
  background: #155946;
}

.session-item__subject,
.session-item__summary {
  color: #1F2624;
}

.session-item__duration,
.session-item__tag {
  color: #155946;
}

.calendar-empty-month {
  padding: 24rpx;
}

.calendar-empty-month__text {
  color: #1F2624;
  font-size: 26rpx;
  font-weight: 600;
}

/* Second polish pass — heatmap as study-time intensity map. */
@keyframes heat-cell-enter {
  from {
    opacity: 0;
    transform: translateY(8rpx) scale(0.96);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes selected-heat-pulse {
  0% { box-shadow: 0 0 0 0 rgba(21, 89, 70, 0.18); }
  100% { box-shadow: 0 0 0 10rpx rgba(21, 89, 70, 0); }
}

.calendar-page {
  gap: 28rpx;
}

.calendar-hero {
  padding: 4rpx 0 0;
}

.calendar-hero__title {
  font-size: 42rpx;
  letter-spacing: 0;
}

.calendar-hero__nav {
  background: linear-gradient(180deg, #F8FCFA 0%, #EAF4EF 100%);
  border-color: rgba(21, 89, 70, 0.12);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
  transition:
    transform 100ms cubic-bezier(0.2, 0.8, 0.3, 1),
    background 220ms cubic-bezier(0.2, 0.8, 0.3, 1);
}

.calendar-board {
  padding: 28rpx 24rpx 24rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 252, 250, 0.98) 100%);
  border-color: rgba(21, 89, 70, 0.13);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 18rpx 44rpx -34rpx rgba(15, 44, 34, 0.42);
}

.calendar-board__summary {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-bottom: 22rpx;
  border-bottom: 1rpx solid rgba(21, 89, 70, 0.08);
}

.calendar-board__title,
.calendar-board__subtitle,
.calendar-board__peak {
  display: block;
}

.calendar-board__title {
  color: #1F2624;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.calendar-board__subtitle {
  margin-top: 6rpx;
  color: #5E7D75;
  font-size: 20rpx;
  font-weight: 400;
  line-height: 1.35;
}

.calendar-board__peak {
  color: #155946;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.1;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

.calendar-board__weekdays {
  margin-top: 24rpx;
}

.calendar-board__grid {
  margin-top: 14rpx;
}

/* v0.42.1 — see note above: dropped the flex/percentage-width column
   layout that wrapped the 7th column. CSS grid (repeat(7,1fr)) handles it. */
.calendar-board__weekdays text {
  color: rgba(31, 38, 36, 0.46);
  font-size: 18rpx;
  font-weight: 600;
}

.calendar-board__cell {
  position: relative;
  align-items: flex-start;
  justify-content: space-between;
  height: 76rpx;
  /* row spacing comes from the grid `gap` now (was margin-bottom under flex) */
  padding: 10rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(21, 89, 70, 0.08);
  background: linear-gradient(180deg, #F1F6F3 0%, #E7F0EB 100%);
  overflow: visible;
  animation: heat-cell-enter 360ms cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  transition:
    transform 100ms cubic-bezier(0.2, 0.8, 0.3, 1),
    border-color 220ms cubic-bezier(0.2, 0.8, 0.3, 1),
    background 220ms cubic-bezier(0.2, 0.8, 0.3, 1);
}

.calendar-board__cell:active {
  transform: scale(0.96);
}

.calendar-board__cell::before {
  content: "";
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  top: 7rpx;
  height: 1rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.55);
}

.calendar-board__cell.level-1 {
  background: linear-gradient(180deg, #DCEFE5 0%, #CBE6D8 100%);
  border-color: rgba(130, 184, 159, 0.34);
}

.calendar-board__cell.level-2 {
  background: linear-gradient(180deg, #B6DEC8 0%, #95CDB1 100%);
  border-color: rgba(92, 180, 137, 0.34);
}

.calendar-board__cell.level-3 {
  background: linear-gradient(180deg, #78C79C 0%, #55AC82 100%);
  border-color: rgba(46, 152, 105, 0.42);
}

.calendar-board__cell.level-4 {
  background: linear-gradient(180deg, #359D70 0%, #207452 100%);
  border-color: rgba(21, 89, 70, 0.56);
}

.calendar-board__cell.level-5 {
  background: linear-gradient(180deg, #1E6B51 0%, #0D3F2D 100%);
  border-color: rgba(8, 49, 35, 0.72);
}

.calendar-board__cell.is-selected {
  outline: 0;
}

.calendar-board__cell.is-selected::after {
  content: "";
  position: absolute;
  left: -6rpx;
  right: -6rpx;
  top: -6rpx;
  bottom: -6rpx;
  border: 2rpx solid #155946;
  border-radius: 18rpx;
  pointer-events: none;
  animation: selected-heat-pulse 1200ms cubic-bezier(0.2, 0.8, 0.3, 1) infinite;
}

.calendar-board__cell.is-today {
  border-color: #155946;
}

.calendar-board__cell.is-today::after {
  content: "";
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #155946;
}

.calendar-board__cell.is-selected.is-today::after {
  left: -6rpx;
  right: -6rpx;
  top: -6rpx;
  bottom: -6rpx;
  width: auto;
  height: auto;
  border-radius: 18rpx;
  background: transparent;
}

.calendar-board__day {
  color: rgba(31, 38, 36, 0.78);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
}

.calendar-board__minutes {
  align-self: flex-end;
  color: rgba(31, 38, 36, 0.58);
  font-size: 17rpx;
  font-weight: 800;
  line-height: 1;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.calendar-board__cell.level-3 .calendar-board__day,
.calendar-board__cell.level-3 .calendar-board__minutes,
.calendar-board__cell.level-4 .calendar-board__day,
.calendar-board__cell.level-4 .calendar-board__minutes,
.calendar-board__cell.level-5 .calendar-board__day,
.calendar-board__cell.level-5 .calendar-board__minutes {
  color: #FFFFFF;
}

.calendar-board__legend--horizontal {
  justify-content: space-between;
  gap: 0;
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(21, 89, 70, 0.08);
}

.calendar-board__legend-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 58rpx;
}

.calendar-board__legend-step text {
  color: rgba(94, 125, 117, 0.88);
  font-size: 17rpx;
  font-weight: 600;
  line-height: 1;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.calendar-board__legend--horizontal .calendar-board__legend-swatch {
  width: 30rpx;
  height: 18rpx;
  border-radius: 5rpx;
  border-width: 1rpx;
}

.calendar-board__legend-swatch.level-0 { background: linear-gradient(180deg, #F1F6F3 0%, #E7F0EB 100%); border-color: rgba(21, 89, 70, 0.08); }
.calendar-board__legend-swatch.level-1 { background: linear-gradient(180deg, #DCEFE5 0%, #CBE6D8 100%); border-color: rgba(130, 184, 159, 0.34); }
.calendar-board__legend-swatch.level-2 { background: linear-gradient(180deg, #B6DEC8 0%, #95CDB1 100%); border-color: rgba(92, 180, 137, 0.34); }
.calendar-board__legend-swatch.level-3 { background: linear-gradient(180deg, #78C79C 0%, #55AC82 100%); border-color: rgba(46, 152, 105, 0.42); }
.calendar-board__legend-swatch.level-4 { background: linear-gradient(180deg, #359D70 0%, #207452 100%); border-color: rgba(21, 89, 70, 0.56); }
.calendar-board__legend-swatch.level-5 { background: linear-gradient(180deg, #1E6B51 0%, #0D3F2D 100%); border-color: rgba(8, 49, 35, 0.72); }

.day-panel {
  padding: 28rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 252, 250, 0.98) 100%);
  border-color: rgba(21, 89, 70, 0.12);
  box-shadow: 0 18rpx 44rpx -34rpx rgba(15, 44, 34, 0.38);
}

.day-panel__date {
  font-size: 34rpx;
  letter-spacing: 0;
}

.day-panel__total {
  font-size: 36rpx;
  color: #155946;
  text-shadow: 0 10rpx 30rpx rgba(21, 89, 70, 0.12);
}

.session-item {
  padding: 24rpx 22rpx 22rpx 34rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F7FBF8 100%);
  border-color: rgba(21, 89, 70, 0.10);
}

.session-item::before {
  left: 16rpx;
  top: 24rpx;
  bottom: 24rpx;
  width: 3rpx;
  background: linear-gradient(180deg, #2EA985 0%, #155946 100%);
  opacity: 1;
}

.session-item__duration {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #ECF5F0;
}

@media (prefers-reduced-motion: reduce) {
  .calendar-board__cell,
  .calendar-board__cell.is-selected::after {
    animation: none !important;
  }
}

/* v0.34 — A1 补录 entry pill (right-aligned under the month nav). */
.calendar-makeup {
  display: flex;
  justify-content: flex-end;
  margin-top: -4rpx;
  margin-bottom: 4rpx;
}
.calendar-makeup__btn {
  display: inline-flex;
  align-items: center;
  /* v0.42.1 — 60rpx was below the project's 76rpx secondary-control tap
     floor (cf. .calendar-hero__nav, v0.32.5). padding stays 0 28rpx. */
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #ecf5f0;
  border: 1rpx solid #dceae3;
  color: #155946;
  font-size: 24rpx;
  font-weight: 600;
}
.calendar-makeup__btn--hover {
  background: #dceae3;
}
