.calendar-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.calendar-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.calendar-hero__center {
  flex: 1;
  min-width: 0;
  text-align: center;
}

.calendar-hero__title,
.calendar-hero__meta {
  display: block;
}

.calendar-hero__title {
  font-size: 34rpx;
  font-weight: 700;
}

.calendar-hero__meta {
  margin-top: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.calendar-hero__nav {
  flex: 0 0 auto;
  padding: 0 28rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  white-space: nowrap;
}

.calendar-hero__nav--hover {
  background: rgba(46, 169, 133, 0.2);
}

.calendar-board,
.day-panel {
  padding: 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(46, 169, 133, 0.08);
}

.calendar-board__weekdays {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  text-align: center;
}

.calendar-board__grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 18rpx;
}

.calendar-board__cell {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 22rpx;
  background: rgba(46, 169, 133, 0.04);
}

.calendar-board__cell.is-faded {
  opacity: 0.28;
}

.calendar-board__cell.is-selected {
  outline: 4rpx solid rgba(46, 169, 133, 0.18);
}

.calendar-board__cell.level-1 {
  background: rgba(46, 169, 133, 0.14);
}

.calendar-board__cell.level-2 {
  background: rgba(46, 169, 133, 0.24);
}

.calendar-board__cell.level-3 {
  background: rgba(46, 169, 133, 0.45);
}

.calendar-board__cell.level-4 {
  background: #2ea985;
}

.calendar-board__cell.level-3 .calendar-board__day,
.calendar-board__cell.level-4 .calendar-board__day {
  color: #ffffff;
}

.calendar-board__day {
  font-size: 24rpx;
  font-weight: 600;
}

.day-panel__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.day-panel__date,
.day-panel__meta,
.day-panel__total {
  display: block;
}

.day-panel__date {
  font-size: 34rpx;
  font-weight: 700;
}

.day-panel__meta {
  margin-top: 8rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.day-panel__total {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--mint-600);
}

.day-panel__sessions {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.session-item {
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(46, 169, 133, 0.05);
}

.session-item__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.session-item__subject {
  font-size: 26rpx;
  font-weight: 700;
}

.session-item__duration {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--mint-600);
}

.session-item__summary {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-main);
}

.session-item__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.session-item__tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 20rpx;
}

.session-item__photos {
  white-space: nowrap;
  margin-top: 16rpx;
}

.session-item__photo {
  display: inline-block;
  width: 144rpx;
  height: 144rpx;
  margin-right: 12rpx;
  border-radius: 20rpx;
  background: rgba(46, 169, 133, 0.08);
}
