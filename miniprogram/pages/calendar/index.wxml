<view class="page-shell calendar-page">
  <view class="calendar-hero">
    <view class="calendar-hero__nav" hover-class="calendar-hero__nav--hover" bindtap="handlePrevMonth">上月</view>
    <view class="calendar-hero__center">
      <text class="calendar-hero__title">{{monthTitle}}</text>
      <text class="calendar-hero__meta">本月 {{monthTotalText}}</text>
    </view>
    <view class="calendar-hero__nav" hover-class="calendar-hero__nav--hover" bindtap="handleNextMonth">下月</view>
  </view>

  <!--
    v0.26 — empty-month hint. When totalMinutes for this month is 0
    we surface a small message above the grid so the all-gray board
    reads as "no data yet" instead of "broken". Tapping any future
    day in the grid still works, but tapping is unlikely to help
    discoverability — the friendly text spells it out.
  -->
  <view wx:if="{{monthIsEmpty}}" class="calendar-empty-month">
    <text class="calendar-empty-month__icon">🐾</text>
    <text class="calendar-empty-month__text">本月还没有打卡记录</text>
    <text class="calendar-empty-month__sub">回到首页开始一次专注吧</text>
  </view>

  <view class="calendar-board">
    <view class="calendar-board__weekdays">
      <text>一</text>
      <text>二</text>
      <text>三</text>
      <text>四</text>
      <text>五</text>
      <text>六</text>
      <text>日</text>
    </view>

    <view class="calendar-board__grid">
      <view
        wx:for="{{grid}}"
        wx:key="date"
        class="calendar-board__cell level-{{item.heatLevel}} {{item.inMonth ? '' : 'is-faded'}} {{selectedDate === item.date ? 'is-selected' : ''}} {{item.isToday ? 'is-today' : ''}}"
        data-date="{{item.date}}"
        data-inmonth="{{item.inMonth}}"
        bindtap="openDay"
      >
        <text class="calendar-board__day">{{item.day}}</text>
        <text wx:if="{{item.totalMinutes > 0}}" class="calendar-board__minutes">{{item.heatLabel}}</text>
      </view>
    </view>

    <!-- v0.23 — legend collapsed from 6-row vertical to 1-row
         horizontal strip. Same information, fraction of the vertical
         space. The user only reads it once to calibrate the heat
         colors anyway. -->
    <view class="calendar-board__legend calendar-board__legend--horizontal">
      <text class="calendar-board__legend-label">少</text>
      <view class="calendar-board__legend-swatch level-0"></view>
      <view class="calendar-board__legend-swatch level-1"></view>
      <view class="calendar-board__legend-swatch level-2"></view>
      <view class="calendar-board__legend-swatch level-3"></view>
      <view class="calendar-board__legend-swatch level-4"></view>
      <view class="calendar-board__legend-swatch level-5"></view>
      <text class="calendar-board__legend-label">多</text>
    </view>
  </view>

  <!-- v0.23 — day-panel only renders when a date is actually selected.
       The default "--" placeholder was busywork. -->
  <view wx:if="{{selectedDate}}" class="day-panel">
    <view class="day-panel__header">
      <view>
        <text class="day-panel__date">{{selectedDateText}}</text>
        <text class="day-panel__meta">{{selectedDetail ? (selectedDetail.sessionCount + '次学习') : '0次学习'}}</text>
      </view>
      <text class="day-panel__total">{{selectedTotalText}}</text>
    </view>

    <view wx:if="{{selectedDetail && selectedDetail.sessions.length}}" class="day-panel__sessions">
      <view wx:for="{{selectedDetail.sessions}}" wx:key="id" class="session-item">
        <view class="session-item__top">
          <text class="session-item__subject">{{item.subject || '学习记录'}}</text>
          <text class="session-item__duration">{{item.totalMinutes}}m</text>
        </view>
        <text class="session-item__summary">{{item.summary}}</text>
        <view wx:if="{{item.tags.length}}" class="session-item__tags">
          <text wx:for="{{item.tags}}" wx:key="*this" wx:for-item="tag" class="session-item__tag">{{tag}}</text>
        </view>
        <scroll-view wx:if="{{item.photos.length}}" class="session-item__photos" scroll-x="true" enable-flex="true">
          <image
            wx:for="{{item.photos}}"
            wx:key="objectKey"
            wx:for-item="photo"
            wx:for-index="photoIndex"
            class="session-item__photo"
            src="{{photo.tempUrl || photo.fileId}}"
            mode="aspectFill"
            data-session-id="{{item.id}}"
            data-photo-index="{{photoIndex}}"
            bindtap="previewSessionPhoto"
          />
        </scroll-view>
      </view>
    </view>

    <view wx:else class="empty-state">这一天还没有完成打卡</view>
  </view>
</view>
