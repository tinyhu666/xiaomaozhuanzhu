<view class="page-shell home-page">
  <view class="quote-card">
    <text class="quote-card__en">{{quoteEn}}</text>
    <text class="quote-card__zh">{{quoteZh}}</text>
  </view>

  <view class="timer-card">
    <view class="timer-card__head">
      <text class="timer-card__status">
        {{activeSession ? (activeSession.status === 'paused' ? '已暂停' : '专注中') : '准备开始'}}
      </text>
      <view class="timer-card__meta">
        <text>今日 {{todayMinutesText}}</text>
        <text>连续 {{streakText}}</text>
      </view>
    </view>

    <text class="timer-card__clock">{{timerText}}</text>

    <button
      wx:if="{{actions[0] === 'start'}}"
      class="cta-button timer-card__primary"
      bindtap="handleStart"
      loading="{{actionLoading}}"
      disabled="{{actionLoading}}"
    >
      开始
    </button>

    <view wx:else class="timer-card__actions">
      <button
        wx:if="{{actions[0] === 'pause'}}"
        class="ghost-button timer-card__secondary"
        bindtap="handlePause"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >
        暂停
      </button>
      <button
        wx:if="{{actions[0] === 'resume'}}"
        class="ghost-button timer-card__secondary"
        bindtap="handleResume"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >
        继续
      </button>
      <button
        class="cta-button timer-card__secondary"
        bindtap="handleComplete"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >
        结束
      </button>
    </view>
  </view>

  <view class="mini-calendar">
    <view class="mini-calendar__header" bindtap="openCalendar">
      <view>
        <text class="mini-calendar__title">当月热力</text>
        <text class="mini-calendar__month">{{monthLabel}}</text>
      </view>
      <text class="mini-calendar__total">{{monthTotalText}}</text>
    </view>

    <view class="mini-calendar__weekdays">
      <text>一</text>
      <text>二</text>
      <text>三</text>
      <text>四</text>
      <text>五</text>
      <text>六</text>
      <text>日</text>
    </view>

    <view class="mini-calendar__grid">
      <view
        wx:for="{{monthGrid}}"
        wx:key="date"
        class="mini-calendar__cell level-{{item.heatLevel}} {{item.inMonth ? '' : 'is-faded'}}"
        data-date="{{item.date}}"
        data-inmonth="{{item.inMonth}}"
        bindtap="handlePreviewDay"
      >
        <text class="mini-calendar__day">{{item.day}}</text>
      </view>
    </view>
  </view>
</view>
