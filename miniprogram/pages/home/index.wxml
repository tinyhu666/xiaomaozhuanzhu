<view class="page-shell home-page">
  <view wx:if="{{makeup}}" class="makeup-banner">
    <view class="makeup-banner__text">
      <text class="makeup-banner__title">昨天没打卡，今天还能补回来</text>
      <text class="makeup-banner__sub">补签后连签可恢复到 {{makeup.streakIfRecovered}} 天，每 7 天可用一次</text>
    </view>
    <button class="cta-button makeup-banner__btn" loading="{{makeupLoading}}" disabled="{{makeupLoading}}" bindtap="handleMakeup">补签</button>
  </view>

  <view class="quote-card">
    <text class="quote-card__en">{{quoteEn}}</text>
    <text class="quote-card__zh">{{quoteZh}}</text>
  </view>

  <view class="timer-card">
    <view class="timer-card__head">
      <view class="timer-card__status-wrap">
        <text class="timer-card__status">{{activeSession ? (activeSession.status === 'paused' ? '已暂停' : '专注中') : '准备开始'}}</text>
        <text wx:if="{{activeSession && activeSession.status === 'paused' && pausedMinutes > 0}}" class="timer-card__pause-hint">已暂停 {{pausedMinutes}} 分钟</text>
      </view>
      <view class="timer-card__meta">
        <text>今日 {{todayMinutesText}}</text>
        <text>连续 {{streakText}}</text>
      </view>
    </view>

    <text class="timer-card__clock">{{timerText}}</text>

    <button
      wx:if="{{actions[0] === 'start'}}"
      class="cta-button timer-card__primary"
      bindtap="handleStart"
      loading="{{actionLoading}}"
      disabled="{{actionLoading}}"
    >{{actionLoading ? (actionLoadingLabel || '正在开始…') : '开始'}}</button>

    <view wx:else class="timer-card__actions">
      <button
        wx:if="{{actions[0] === 'pause'}}"
        class="ghost-button timer-card__secondary"
        bindtap="handlePause"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >{{actionLoading ? (actionLoadingLabel || '正在暂停…') : '暂停'}}</button>
      <button
        wx:if="{{actions[0] === 'resume'}}"
        class="ghost-button timer-card__secondary"
        bindtap="handleResume"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >{{actionLoading ? (actionLoadingLabel || '正在继续…') : '继续'}}</button>
      <button
        class="cta-button timer-card__secondary"
        bindtap="handleComplete"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >{{actionLoading ? (actionLoadingLabel || '正在结束…') : '结束'}}</button>
    </view>
  </view>

  <view class="goal-card">
    <view class="goal-card__head">
      <view class="goal-card__title-wrap">
        <text class="goal-card__title">今日目标</text>
        <text class="goal-card__sub">建议每天专注 1.5 小时</text>
      </view>
      <text class="goal-card__value {{goalReached ? 'is-reached' : ''}}">{{goalText}}</text>
    </view>
    <view class="goal-card__track">
      <view class="goal-card__fill {{goalReached ? 'is-reached' : ''}}" style="width: {{goalProgress}}%"></view>
    </view>
    <text wx:if="{{goalReached}}" class="goal-card__hint">🎉 今日目标已达成，继续保持！</text>
  </view>

  <view wx:if="{{weekly}}" class="weekly-card">
    <view class="weekly-card__header">
      <view class="weekly-card__title-wrap">
        <text class="weekly-card__title">本周复盘</text>
        <text class="weekly-card__range">{{weekly.weekRangeText}}</text>
      </view>
      <text class="weekly-card__total">{{weekly.thisWeekText}}</text>
    </view>
    <text class="weekly-card__change weekly-card__change--{{weekly.changeDirection}}">{{weekly.changeText}}</text>
    <view class="weekly-card__rows">
      <view class="weekly-card__row">
        <text class="weekly-card__row-label">最长一天</text>
        <text class="weekly-card__row-value">{{weekly.bestDayText}}</text>
      </view>
      <view class="weekly-card__row">
        <text class="weekly-card__row-label">主要科目</text>
        <text class="weekly-card__row-value">{{weekly.topSubjectText}}</text>
      </view>
      <view class="weekly-card__row">
        <text class="weekly-card__row-label">上周</text>
        <text class="weekly-card__row-value">{{weekly.lastWeekText}}</text>
      </view>
    </view>
  </view>

  <view class="mini-calendar">
    <view class="mini-calendar__header" bindtap="openCalendar">
      <view>
        <text class="mini-calendar__title">当月热力</text>
        <text class="mini-calendar__month">{{monthLabel}}</text>
      </view>
      <text class="mini-calendar__total">{{monthTotalText}}</text>
    </view>

    <view class="mini-calendar__weekdays">
      <text>一</text>
      <text>二</text>
      <text>三</text>
      <text>四</text>
      <text>五</text>
      <text>六</text>
      <text>日</text>
    </view>

    <view class="mini-calendar__grid">
      <view
        wx:for="{{monthGrid}}"
        wx:key="date"
        class="mini-calendar__cell level-{{item.heatLevel}} {{item.inMonth ? '' : 'is-faded'}} {{item.isToday ? 'is-today' : ''}}"
        data-date="{{item.date}}"
        data-inmonth="{{item.inMonth}}"
        bindtap="handlePreviewDay"
      >
        <text class="mini-calendar__day">{{item.day}}</text>
      </view>
    </view>
  </view>

  <text class="home-version">v{{appVersion}}</text>
</view>
