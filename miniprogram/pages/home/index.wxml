<!--
  v0.30 — full structural rewrite to match the Claude-Design handoff
  (docs/design-handoff/screen-home.jsx). Previous versions did only
  palette swaps; this one rebuilds the layout itself.

  Two top-level branches: idle (when activeSession is null) and
  focus mode (when activeSession is non-null). Same WXML file but
  the two blocks are visually disjoint per design intent.
  All existing event handlers + data bindings are preserved verbatim
  so the TS / store layer doesn't need any changes.
-->
<view class="home-page {{activeSession ? 'is-focus-mode' : ''}}">

  <!--
    ============ IDLE STATE ============
    Header → exam hero (no card) → timer card → goal card → 6-科 grid.
    Total visible blocks ≤ 4 per design rules.
  -->
  <block wx:if="{{!activeSession}}">
    <!-- Header bar: app title + streak chip -->
    <view class="home-header page-pad">
      <text class="home-header__title">小猫专注</text>
      <view wx:if="{{streakDays > 0}}" class="home-header__streak">
        <text class="home-header__flame">🔥</text>
        <text class="home-header__streak-num num">{{streakText}}</text>
      </view>
    </view>

    <!-- Makeup nudge: only when server flags a recoverable streak. -->
    <view wx:if="{{makeup}}" class="makeup-banner page-pad fade-up">
      <view class="makeup-banner__text">
        <text class="makeup-banner__title">昨天没打卡，今天可以补</text>
        <text class="makeup-banner__sub caption">补签后连签恢复到 {{makeup.streakIfRecovered}} 天，每 7 天可用一次</text>
      </view>
      <button class="btn-v2 btn-v2--primary makeup-banner__btn" loading="{{makeupLoading}}" disabled="{{makeupLoading}}" bindtap="handleMakeup">补签</button>
    </view>

    <!-- Exam countdown — full-bleed text, no card chrome. -->
    <view wx:if="{{nextExam}}" class="exam-hero page-pad fade-up exam-hero--{{nextExam.urgency}}">
      <text class="exam-hero__eyebrow micro">下一科 · {{nextExam.subject}}</text>
      <view class="exam-hero__row">
        <text class="exam-hero__num num">{{nextExam.daysRemaining}}</text>
        <text class="exam-hero__unit">天</text>
      </view>
      <text class="exam-hero__date caption">距 {{nextExam.dateLabel}}{{nextExam.fallback ? '（参考）' : ''}}</text>
    </view>

    <!-- Timer card — idle.
         Big number = today's cumulative (todayMinutesText), per design.
         Caption is a generic motivation line; CTA opens focus mode. -->
    <view class="page-pad fade-up">
      <view class="timer-card-v2 card-v2">
        <text class="timer-card-v2__eyebrow micro">今日已专注</text>
        <text class="timer-card-v2__big num">{{todayMinutesText}}</text>
        <text class="timer-card-v2__caption caption">{{goalReached ? '今日目标已达成' : '点下方按钮开始下一段专注'}}</text>
        <button
          class="btn-v2 btn-v2--primary timer-card-v2__cta"
          bindtap="handleStart"
          loading="{{actionLoading}}"
          disabled="{{actionLoading}}"
        >{{actionLoading ? (actionLoadingLabel || '正在开始…') : '开始专注'}}</button>
      </view>
    </view>

    <!-- Today goal card — title + value, progress bar, optional challenge. -->
    <view class="page-pad fade-up">
      <view class="goal-card-v2 card-v2">
        <view class="goal-card-v2__head">
          <text class="goal-card-v2__title">今日目标</text>
          <text class="goal-card-v2__value num {{goalReached ? 'is-reached' : ''}}">{{goalText}}</text>
        </view>
        <view class="bar goal-card-v2__bar">
          <view class="bar__fill {{goalReached ? 'is-reached' : ''}}" style="width: {{goalProgress}}%"></view>
        </view>
        <view wx:if="{{dailyChallenge}}" class="goal-card-v2__challenge {{dailyChallenge.completed ? 'is-done' : ''}}" bindtap="onTapChallengeHint">
          <text class="goal-card-v2__challenge-icon">{{dailyChallenge.completed ? '✓' : '🎯'}}</text>
          <text class="goal-card-v2__challenge-text">挑战 {{dailyChallenge.targetMinutes}} 分</text>
          <text wx:if="{{dailyChallenge.completed}}" class="goal-card-v2__challenge-done caption">已完成</text>
        </view>
        <view wx:if="{{weeklyGoal.visible}}" class="goal-card-v2__weekly">
          <text class="caption">本周 {{weeklyGoal.text}}</text>
          <view class="bar goal-card-v2__weekly-bar">
            <view class="bar__fill {{weeklyGoal.reached ? 'is-reached' : ''}}" style="width: {{weeklyGoal.progress}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- Six-subject grid — 2×3 mini bars. -->
    <view wx:if="{{subjectsCard.visible}}" class="page-pad fade-up">
      <view class="subjects-card-v2" bindtap="openSubjectsPage">
        <view class="subjects-card-v2__head">
          <text class="subjects-card-v2__title">六科进度</text>
          <text class="subjects-card-v2__hint caption">查看 ›</text>
        </view>
        <view class="subjects-card-v2__grid card-v2">
          <view wx:for="{{subjectsCard.items}}" wx:key="subject" class="subjects-card-v2__row">
            <view class="subjects-card-v2__row-head">
              <text class="subjects-card-v2__row-name">{{item.subject}}</text>
              <text class="subjects-card-v2__row-value num caption">{{item.valueText}}</text>
            </view>
            <view class="bar">
              <view class="bar__fill {{item.reached ? 'is-reached' : ''}}" style="width: {{item.percent}}%"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <!--
    ============ FOCUS MODE ============
    Full viewport: meta row → centered Display clock → bottom buttons.
    Always dark (regardless of system theme) by design — it's a
    deliberate sensory shift, not a theme.
  -->
  <view wx:if="{{activeSession}}" class="focus-mode">

    <!-- Atmospheric halo behind the clock -->
    <view class="focus-mode__halo"></view>

    <!--
      Top meta row: today + streak.
      v0.30.2 — was a single <text class="caption"> with an embedded
      num span + middle-dot + CJK, which caused baseline drift between
      the tabular-nums digits and PingFang CJK on real devices. Now
      each pair is its own inline-flex wrapper with align-items:
      baseline and each token sits in its own <text>, per
      ui-review-checklist §1A.
    -->
    <view class="focus-mode__meta">
      <view class="focus-mode__meta-pair">
        <text class="num focus-mode__meta-strong">{{todayMinutesText}}</text>
        <text class="focus-mode__meta-label">· 今日</text>
      </view>
      <text class="focus-mode__divider">|</text>
      <view class="focus-mode__meta-pair">
        <text class="num focus-mode__meta-strong">{{streakText}}</text>
        <text class="focus-mode__meta-label">连签</text>
      </view>
    </view>

    <!-- Central display: subject (optional) + clock + status -->
    <view class="focus-mode__center">
      <text wx:if="{{activeSession.subject}}" class="focus-mode__subject micro">{{activeSession.subject}}</text>
      <text class="focus-mode__clock num {{activeSession.status === 'paused' ? 'is-paused' : 'is-running'}}">{{timerText}}</text>
      <!--
        v0.31.2 — status caption simplified to just "已暂停" when paused.
        Previously appended pause-duration ("· 3 分钟") which read like
        the focus duration; semantically inverted and confusing.
        The big clock above already shows the cumulative focus time
        (frozen on pause), so the duration the user actually cares
        about is right there at hero size.
      -->
      <text class="focus-mode__status caption">
        {{activeSession.status === 'paused' ? '已暂停' : (activeSession.mode === 'pomodoro' ? pomodoroPhaseLabel : '专注中')}}
      </text>
      <!-- Pomodoro dots — legacy session display -->
      <view wx:if="{{activeSession.mode === 'pomodoro'}}" class="focus-mode__cycles">
        <view
          wx:for="{{pomodoroCycleDots}}"
          wx:key="index"
          class="focus-mode__cycle-dot {{item.done ? 'is-done' : ''}}"
        ></view>
      </view>
    </view>

    <!-- Bottom actions: pause/resume (ghost) + end (primary accent) -->
    <view class="focus-mode__actions">
      <button
        wx:if="{{actions[0] === 'pause'}}"
        class="btn-v2 btn-v2--ghost focus-mode__btn"
        bindtap="handlePause"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >{{actionLoading ? (actionLoadingLabel || '正在暂停…') : '暂停'}}</button>
      <button
        wx:if="{{actions[0] === 'resume'}}"
        class="btn-v2 btn-v2--ghost focus-mode__btn"
        bindtap="handleResume"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >{{actionLoading ? (actionLoadingLabel || '正在继续…') : '继续'}}</button>
      <button
        class="btn-v2 btn-v2--primary focus-mode__btn focus-mode__btn--end"
        bindtap="handleComplete"
        loading="{{actionLoading}}"
        disabled="{{actionLoading}}"
      >{{actionLoading ? (actionLoadingLabel || '正在结束…') : '结束'}}</button>
    </view>
  </view>

</view>
