.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.quote-card {
  position: relative;
  padding: 28rpx 36rpx 36rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(143, 217, 190, 0.35), transparent 44%),
    radial-gradient(circle at 8% 92%, rgba(94, 195, 157, 0.22), transparent 40%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(228, 248, 240, 0.94) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.14);
  box-shadow:
    0 18rpx 44rpx rgba(46, 169, 133, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6);
  overflow: hidden;
}

/* Two giant serif quote glyphs at opposite corners frame the line
   like a literary pull-quote — open mark top-left, close mark
   bottom-right (flipped via scaleY). Both are pure decoration so we
   keep them watermark-light and pointer-events: none. */
.quote-card__mark {
  position: absolute;
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 700;
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.quote-card__mark--open {
  top: -36rpx;
  left: 8rpx;
  font-size: 240rpx;
  color: rgba(46, 169, 133, 0.16);
}

.quote-card__mark--close {
  bottom: -110rpx;
  right: 8rpx;
  font-size: 200rpx;
  color: rgba(46, 169, 133, 0.1);
  transform: rotate(180deg);
}

/* Cat-paw mascot, slightly tilted, in the top-right corner. */
.quote-card__paw {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 36rpx;
  opacity: 0.82;
  transform: rotate(-14deg);
}

/* Three small mint sparkles scattered around the card to suggest a
   gentle "magic" feel without distracting from the actual quote. */
.quote-card__sparkle {
  position: absolute;
  color: var(--mint-500);
  pointer-events: none;
  user-select: none;
  line-height: 1;
}

.quote-card__sparkle--a {
  top: 28rpx;
  right: 110rpx;
  font-size: 22rpx;
  opacity: 0.55;
}

.quote-card__sparkle--b {
  bottom: 64rpx;
  left: 36rpx;
  font-size: 18rpx;
  opacity: 0.4;
}

.quote-card__sparkle--c {
  bottom: 36rpx;
  right: 60rpx;
  font-size: 26rpx;
  opacity: 0.35;
}

/* Small chip header above the quote — sets context ("今日金句") and
   gives the card a clear vertical anchor before the big text. */
.quote-card__chip {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 18rpx 6rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(46, 169, 133, 0.16) 0%, rgba(143, 217, 190, 0.18) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.22);
  margin-bottom: 18rpx;
}

.quote-card__chip-icon {
  font-size: 18rpx;
  color: var(--mint-600);
  transform: translateY(-1rpx);
}

.quote-card__chip-text {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 2rpx;
}

/* English line gets a left-to-right mint gradient via -webkit-text-
   fill-color: transparent + background-clip: text. WeChat MP runs on
   WebKit so this works; the solid color: var(--mint-600) is a
   fallback for any renderer that doesn't honor background-clip. */
.quote-card__en {
  position: relative;
  display: block;
  font-family: Georgia, "Times New Roman", "PingFang SC", serif;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.24;
  letter-spacing: 0.2rpx;
  color: var(--mint-600);
  background: linear-gradient(135deg, #155946 0%, #2ea985 55%, #5ec39d 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Tiny mint accent bar separating English and Chinese — gives the
   card a deliberate, designed feel. */
.quote-card__divider {
  position: relative;
  width: 64rpx;
  height: 4rpx;
  margin: 20rpx 0 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--mint-500) 0%, rgba(143, 217, 190, 0.6) 100%);
  box-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.quote-card__zh {
  position: relative;
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-main);
  letter-spacing: 0.6rpx;
  opacity: 0.78;
}

.timer-card {
  position: relative;
  padding: 32rpx 28rpx 32rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(94, 195, 157, 0.22), transparent 40%),
    radial-gradient(circle at 8% 92%, rgba(143, 217, 190, 0.18), transparent 38%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 251, 245, 0.96) 100%);
  box-shadow: 0 24rpx 54rpx rgba(46, 169, 133, 0.14);
  overflow: hidden;
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* Status pill: gradient mint background, leading dot indicator + text.
   Uses ::before for the dot so we don't need extra DOM nodes. */
.timer-card__status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 22rpx 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(46, 169, 133, 0.14) 0%, rgba(143, 217, 190, 0.18) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.2);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
  box-sizing: border-box;
}

.timer-card__status::before {
  content: "";
  display: block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--mint-500);
  box-shadow: 0 0 0 3rpx rgba(46, 169, 133, 0.16);
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

/* Tabular figures + subtle gradient text + soft drop-shadow for the
   big timer. Tabular numerals keep the digits perfectly aligned as
   they tick up so the layout doesn't wobble per second. */
.timer-card__clock {
  display: block;
  margin-top: 42rpx;
  font-size: 100rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 2rpx;
  text-align: center;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  color: #155946;
  background: linear-gradient(180deg, #1a624f 0%, #155946 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.5);
}

.timer-card__hint {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  opacity: 0.85;
}

.timer-card__primary {
  margin-top: 38rpx;
}

.timer-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

.goal-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 253, 250, 0.92) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    0 14rpx 36rpx rgba(46, 169, 133, 0.08),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  position: relative;
  margin-top: 20rpx;
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(46, 169, 133, 0.08);
}

/* Progress fill: gradient with an inner top-edge highlight to simulate
   a glossy ribbon, plus a subtle outer glow when achievement is hit. */
.goal-card__fill {
  position: relative;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #8fd9be 0%, #2ea985 100%);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.45);
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.goal-card__fill.is-reached {
  background: linear-gradient(135deg, #6fc99a 0%, #2ea985 60%, #1a7558 100%);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.5),
    0 0 16rpx rgba(46, 169, 133, 0.4);
}

.goal-card__hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
}

.makeup-banner {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 230, 191, 0.85) 0%, rgba(255, 207, 138, 0.95) 100%);
  border: 2rpx solid rgba(229, 158, 87, 0.32);
  box-shadow: 0 16rpx 36rpx rgba(229, 158, 87, 0.18);
}

.makeup-banner__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.makeup-banner__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b3f15;
}

.makeup-banner__sub {
  font-size: 22rpx;
  color: #8a5a2b;
  line-height: 1.5;
}

.makeup-banner__btn {
  flex-shrink: 0;
  min-height: 72rpx;
  height: 72rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #f4a93f 0%, #e58932 100%);
  box-shadow: 0 12rpx 28rpx rgba(229, 137, 50, 0.32);
}

.weekly-card {
  padding: 28rpx;
  border-radius: 32rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 253, 250, 0.92) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    0 14rpx 36rpx rgba(46, 169, 133, 0.08),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.7);
}

.weekly-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.weekly-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weekly-card__title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.weekly-card__range {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.weekly-card__total {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.weekly-card__change {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.weekly-card__change--up {
  color: var(--mint-600);
}

.weekly-card__change--down {
  color: #c2654a;
}

.weekly-card__change--flat {
  color: var(--text-sub);
}

.weekly-card__bars {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  align-items: end;
  margin-top: 24rpx;
  padding: 4rpx 4rpx 0;
}

.weekly-card__bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.weekly-card__bar-value {
  font-size: 16rpx;
  line-height: 1;
  height: 22rpx;
  color: var(--text-sub);
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.2rpx;
  opacity: 0.85;
}

.weekly-card__bar-track {
  position: relative;
  width: 30rpx;
  height: 100rpx;
  border-radius: 10rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  box-shadow: inset 0 1rpx 2rpx rgba(46, 169, 133, 0.06);
}

.weekly-card__bar-fill {
  width: 100%;
  min-height: 0;
  background: linear-gradient(180deg, #6fc99a 0%, #2ea985 100%);
  border-top-left-radius: 8rpx;
  border-top-right-radius: 8rpx;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.35);
  transition: height 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.weekly-card__bar.is-today .weekly-card__bar-track {
  background: rgba(46, 169, 133, 0.14);
  box-shadow:
    0 0 0 3rpx rgba(46, 169, 133, 0.24),
    inset 0 1rpx 2rpx rgba(46, 169, 133, 0.1);
}

.weekly-card__bar.is-today .weekly-card__bar-fill {
  background: linear-gradient(180deg, #2ea985 0%, #0a4631 100%);
}

.weekly-card__bar.is-today .weekly-card__bar-label {
  color: var(--mint-600);
  font-weight: 800;
}

.weekly-card__bar.is-today .weekly-card__bar-value {
  color: var(--mint-600);
  font-weight: 700;
  opacity: 1;
}

.weekly-card__bar.is-future .weekly-card__bar-track {
  opacity: 0.5;
}

.weekly-card__bar-label {
  font-size: 20rpx;
  color: var(--text-sub);
  line-height: 1;
  letter-spacing: 0.3rpx;
}

.weekly-card__rows {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 2rpx dashed rgba(46, 169, 133, 0.16);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.weekly-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.weekly-card__row-label {
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
}

.weekly-card__row-value {
  flex: 1;
  text-align: right;
  font-weight: 600;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

.home-version {
  display: block;
  margin: 14rpx auto 0;
  text-align: center;
  font-size: 18rpx;
  color: rgba(94, 125, 117, 0.5);
  letter-spacing: 1rpx;
}
