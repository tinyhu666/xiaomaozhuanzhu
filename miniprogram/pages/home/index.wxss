.home-page {
  display: flex;
  flex-direction: column;
  /* v0.21: tightened from 24rpx — same number of cards but less air
     between them lets more fit in a viewport without scroll. */
  gap: 18rpx;
  transition: padding 0.32s cubic-bezier(0.2, 0.8, 0.3, 1);
}

/* ============================================================
   v0.22 — Focus mode. When `is-focus-mode` is on, the page-shell
   collapses to a single tall card filling the viewport: the timer
   becomes the page. Other sections (exam-hero, makeup, goal-card,
   subjects-card) are already wx:if'd off, so this just stretches
   what remains. Tabbar is hidden via wx.hideTabBar from TS so the
   bottom region is the user's button bar, not a 4-icon dock.
   ============================================================ */
.home-page.is-focus-mode {
  position: fixed;
  inset: 0;
  padding: 0;
  margin: 0;
  z-index: 50;
  /* v0.28 — switched from light mint gradient to dark carbon per the
     Claude-Design handoff. Focus mode is now genuinely sensory-different
     from idle. The .focus-halo pseudo-element below adds the atmospheric
     mint glow at the top of the viewport. */
  background: var(--c-bg-dark);
  color: var(--c-text-1-dark);
  justify-content: stretch;
  animation: focus-mode-enter var(--d-3) var(--ease-std);
}

/* Atmospheric halo at the top, fades into the carbon background.
   pseudo-element so we don't touch wxml for this. */
.home-page.is-focus-mode::before {
  content: "";
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 960rpx;
  height: 960rpx;
  pointer-events: none;
  background: radial-gradient(circle at center,
    rgba(46, 169, 133, 0.18) 0%,
    rgba(46, 169, 133, 0) 60%);
  z-index: 0;
}

@keyframes focus-mode-enter {
  0%   { opacity: 0; transform: scale(0.96); }
  100% { opacity: 1; transform: scale(1); }
}

/* Respect user accessibility preference — no animation when they
   asked for none at the OS level. */
@media (prefers-reduced-motion: reduce) {
  .home-page.is-focus-mode {
    animation: none;
  }
}

.home-page.is-focus-mode > .timer-card {
  flex: 1;
  height: 100vh;
  border-radius: 0;
  border: none;
  box-shadow: none;
  background: transparent;
/* Horizontal padding tightened 28→16 to give the enlarged
     clock (160rpx) maximum room. The action buttons in this card sit
     comfortably even at 16rpx side padding. */
  padding: 100rpx 16rpx calc(56rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 1; /* stack above ::before halo */
}

.home-page.is-focus-mode .timer-card__clock {
  /* v0.32.2 — ENLARGED to 144rpx + weight 800. v0.32.1 wrongly shrank
     this to 104rpx (misread "比例失调" as "too big" — it was "数字太
     小"). In a full-screen dark focus view the clock is the hero and
     must command the screen, not float as a tiny number in the void.
     Width check: "00:00:00" ≈ 4.2em (6 tabular digits + 2 narrow
     colons) × 144rpx = 605rpx, fits the 694rpx available (750 − 2×28
     padding) with ~45rpx margin each side. */
/* Pushed to 160rpx (physical max for an 8-char HH:MM:SS
     string). Negative letter-spacing packs the glyphs tighter to buy
     safety margin against overflow. With 16rpx card padding the
     available width is 718rpx; worst-case glyph width (~4.5em ×
     160rpx = 720rpx) minus the -2rpx×7 letter-spacing (~14rpx) lands
     at ~706rpx < 718. Beyond this size the only way bigger is to drop
     the leading "00:" hours — a format change, not a CSS change. */
  font-size: 160rpx;
  font-weight: 800;
  letter-spacing: -2rpx;
  margin-top: auto;
  margin-bottom: auto;
  color: var(--c-text-1-dark);
  background: none;
  -webkit-background-clip: initial;
  background-clip: initial;
  -webkit-text-fill-color: var(--c-text-1-dark);
  animation: focus-clock-breathe 4s ease-in-out infinite;
}

/* Stop the breathing animation when the session is paused so the
   stillness reads as "you stepped away." `.timer-card.is-paused`
   is bound from the wxml — see the class string in the template.
   (We can't use CSS :has() because WeChat's CSS engine doesn't
   support it reliably across older base library versions.) */
.home-page.is-focus-mode .timer-card.is-paused .timer-card__clock {
  animation: none;
  opacity: 0.7;
}

@keyframes focus-clock-breathe {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.86; transform: scale(0.985); }
}

.home-page.is-focus-mode .timer-card__hint {
  display: none;
}

/* v0.28 — focus mode meta row + status pill restyled for dark bg.
   Text colors switch to the dark-mode tokens; the status pill loses
   its solid mint background and becomes a thin caption. */
.home-page.is-focus-mode .timer-card__meta {
  font-size: var(--fs-caption);
  color: var(--c-text-2-dark);
}

.home-page.is-focus-mode .timer-card__streak,
.home-page.is-focus-mode .timer-card__meta text {
  color: var(--c-text-2-dark);
}

.home-page.is-focus-mode .timer-card__status {
  background: rgba(46, 169, 133, 0.18);
  color: var(--c-accent);
}

.home-page.is-focus-mode .timer-card__status.is-running {
  background: rgba(46, 169, 133, 0.28);
}

.home-page.is-focus-mode .timer-card__status.is-paused {
  background: rgba(229, 158, 87, 0.18);
  color: #f0b274;
}

.home-page.is-focus-mode .timer-card__status-dot {
  background: var(--c-accent);
}

.home-page.is-focus-mode .timer-card__status-dot::after {
  background: var(--c-accent);
}

.home-page.is-focus-mode .timer-card__pause-hint {
  color: var(--c-text-2-dark);
}

.home-page.is-focus-mode .timer-card__actions {
  margin-top: auto;
  padding-top: 40rpx;
}

/* v0.28 — buttons in focus mode swap to dark-mode treatment:
   ghost gets a light-on-transparent border, primary uses the accent
   mint (more readable on carbon than the dark primary). */
.home-page.is-focus-mode .ghost-button {
  color: var(--c-text-1-dark);
  background: transparent;
  border: 2rpx solid rgba(232, 239, 236, 0.32);
  box-shadow: none;
}

.home-page.is-focus-mode .ghost-button:active {
  background: rgba(232, 239, 236, 0.06);
}

.home-page.is-focus-mode .cta-button {
  /* v0.32.1 — was a mint→deep-green gradient whose bottom stop
     (--c-primary #155946) sat too close to the dark focus bg
     (#1A1F1C), so the lower half of the 结束 button blended into the
     background and read as invisible. Switched to a solid bright mint
     (--c-accent #2EA985) which has clear contrast against the carbon
     bg. Explicit hex + !important so no cascade can wash it out. */
  background: #2EA985 !important;
  background-color: #2EA985 !important;
  color: #ffffff !important;
  box-shadow: 0 8rpx 24rpx rgba(46, 169, 133, 0.32);
}
.home-page.is-focus-mode .cta-button:active {
  background: #25886c !important;
  background-color: #25886c !important;
}

.home-page.is-focus-mode .timer-card__cycles {
  justify-content: center;
}

.home-page.is-focus-mode .timer-card__cycle-dot {
  background: var(--c-stroke-dark);
}
.home-page.is-focus-mode .timer-card__cycle-dot.is-done {
  background: var(--c-accent);
}

/* Staggered fade-up entrance for the major sections so the page
   composes itself top-down rather than appearing all at once.
   `backwards` keeps each child invisible during its delay window. */
@keyframes home-fade-up {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.home-page > view {
  animation: home-fade-up 0.45s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

/* v0.21 density: tightened stagger so the page composes faster
   (0.04→0.02 first, then 0.05 increments instead of 0.06). */
.home-page > view:nth-child(1) { animation-delay: 0.02s; }
.home-page > view:nth-child(2) { animation-delay: 0.07s; }
.home-page > view:nth-child(3) { animation-delay: 0.12s; }
.home-page > view:nth-child(4) { animation-delay: 0.17s; }
.home-page > view:nth-child(5) { animation-delay: 0.22s; }
.home-page > view:nth-child(6) { animation-delay: 0.27s; }

/* v0.21.3 — .picker-card / .picker-chip styles removed along with the
   home-page subject picker. Subject is now chosen on the complete
   page (post-session). The `.timer-card__subject-pill` below is
   still used to surface the picked subject on a running session's
   meta row when present on the server record. */

/* Subject pill that appears in timer card meta when running. */
.timer-card__subject-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  margin-right: 8rpx;
}

/* Sibling pill showing the active ambient scene.
   Same shape as the subject pill but blue palette so the two
   coexist visually without competing. */
.timer-card__audio-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(74, 110, 217, 0.1);
  color: #4a6ed9;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  margin-right: 8rpx;
}

/* Pomodoro cycle dots — sit just below the clock. */
.timer-card__cycles {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.timer-card__cycle-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: rgba(46, 169, 133, 0.16);
  transition: all 0.32s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.timer-card__cycle-dot.is-done {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 2rpx 8rpx rgba(46, 169, 133, 0.3);
  transform: scale(1.1);
}

.timer-card__cycle-extra {
  margin-left: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
}

/* Pomodoro mode overlay: subtle tomato hue so the active state is
   visually distinct from the free-timer mode. */
.timer-card.is-pomodoro {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 159, 90, 0.16), transparent 45%),
    radial-gradient(circle at 0% 100%, rgba(94, 195, 157, 0.12), transparent 45%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border-color: rgba(229, 122, 50, 0.18);
}

/* ============================================================
   Exam-hero — prominent countdown card. v0.18.1 upgrade from
   the v0.13 slim-pill. Big number on the right, subject + date
   on the left, motivation line at the bottom. Four urgency
   tiers still drive the palette + a gentle pulse on the day
   badge for ≤30 days.
   ============================================================ */
.exam-hero {
  display: flex;
  align-items: center;
  /* v0.21 density: 24→18 / 28×30→22×24 */
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.22), transparent 45%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 12rpx 32rpx -6rpx rgba(46, 169, 133, 0.14);
}

.exam-hero__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.exam-hero__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
  color: #1d6f59;
  text-transform: uppercase;
  opacity: 0.85;
}

.exam-hero__subject {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  font-feature-settings: "tnum" 1;
}

.exam-hero__motivation {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.exam-hero__count {
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  /* v0.21 density: 18×24→14×20 */
  padding: 14rpx 20rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(99, 203, 168, 0.18) 0%, rgba(46, 169, 133, 0.22) 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.28);
}

.exam-hero__count-num {
  /* v0.21 density: 84→72 — still readable as the hero number */
  font-size: 72rpx;
  font-weight: 800;
  color: #155946;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.4rpx;
  line-height: 0.95;
}

.exam-hero__count-unit {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d6f59;
  letter-spacing: 0.6rpx;
}

/* Urgency tiers — calm (default mint), soon (≤90, amber),
   urgent (≤30, orange + pulse), imminent (≤7, red + faster pulse). */
.exam-hero--soon {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.28), transparent 50%),
    linear-gradient(180deg, #fff8ec 0%, #ffefcf 100%);
  border-color: rgba(229, 158, 87, 0.32);
}
.exam-hero--soon .exam-hero__eyebrow { color: #8a4d10; }
.exam-hero--soon .exam-hero__count {
  background: linear-gradient(135deg, rgba(255, 207, 138, 0.32) 0%, rgba(229, 158, 87, 0.32) 100%);
  border-color: rgba(229, 158, 87, 0.4);
}
.exam-hero--soon .exam-hero__count-num,
.exam-hero--soon .exam-hero__count-unit { color: #7a3f0a; }

.exam-hero--urgent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 168, 107, 0.32), transparent 50%),
    linear-gradient(180deg, #fff3ea 0%, #ffe2cc 100%);
  border-color: rgba(229, 122, 50, 0.32);
}
.exam-hero--urgent .exam-hero__eyebrow { color: #7a330a; }
.exam-hero--urgent .exam-hero__count {
  background: linear-gradient(135deg, rgba(255, 168, 107, 0.34) 0%, rgba(229, 122, 50, 0.32) 100%);
  border-color: rgba(229, 122, 50, 0.4);
  animation: exam-hero-pulse 2.4s ease-in-out infinite;
}
.exam-hero--urgent .exam-hero__count-num,
.exam-hero--urgent .exam-hero__count-unit { color: #6b2906; }

.exam-hero--imminent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 156, 156, 0.36), transparent 50%),
    linear-gradient(180deg, #fff0f0 0%, #ffd9d9 100%);
  border-color: rgba(217, 80, 80, 0.36);
}
.exam-hero--imminent .exam-hero__eyebrow { color: #7a1a1a; }
.exam-hero--imminent .exam-hero__count {
  background: linear-gradient(135deg, rgba(255, 156, 156, 0.34) 0%, rgba(217, 80, 80, 0.32) 100%);
  border-color: rgba(217, 80, 80, 0.42);
  animation: exam-hero-pulse 1.6s ease-in-out infinite;
}
.exam-hero--imminent .exam-hero__count-num,
.exam-hero--imminent .exam-hero__count-unit { color: #6b0e0e; }

@keyframes exam-hero-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.04); }
}

/* (Quote card + weekly-review removed in v0.9.3 — home is now
   focused on the immediate question "should I start a session now?".
   Heat map / weekly aggregates live in the dedicated tabs.) */

/* Timer is the hero card on this page: more elevation, gentle mesh
   gradient surface, and an ambient glow when a session is running.
   Three shadow layers (inset highlight + small crisp + large soft)
   give the card real "weight" that distinguishes it from secondary
   cards below. */
.timer-card {
  position: relative;
  /* v0.21 density: 40×36→32×30 */
  padding: 32rpx 30rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(143, 217, 190, 0.28), transparent 48%),
    radial-gradient(circle at 6% 92%, rgba(94, 195, 157, 0.16), transparent 44%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.16);
  overflow: hidden;
  transition: box-shadow 0.4s ease, border-color 0.4s ease;
}

/* Active-session ambient: card edge lights up subtly, ring of mint
   glow extends 8rpx beyond the border like a soft halo. */
.timer-card.is-active {
  border-color: rgba(46, 169, 133, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.22),
    0 0 0 8rpx rgba(46, 169, 133, 0.04);
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* Status pill: tinted background + optional pulsing dot. The dot is
   a separate element so we can animate just the dot, not the text. */
.timer-card__status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
  transition: background 0.3s ease;
}

.timer-card__status.is-running {
  background: rgba(46, 169, 133, 0.14);
}

.timer-card__status.is-paused {
  background: rgba(229, 158, 87, 0.12);
  color: #c2782b;
}

/* Pulsing dot for "专注中". Two concentric rings: inner is the solid
   indicator, outer is a fading halo that breathes. */
.timer-card__status-dot {
  position: relative;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--mint-500);
  flex-shrink: 0;
}

.timer-card__status-dot::after {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: var(--mint-500);
  opacity: 0.4;
  animation: pulse-ring 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.6); opacity: 0.5; }
  80%, 100% { transform: scale(1.6); opacity: 0; }
}

.timer-card__status-text {
  display: inline-block;
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.timer-card__streak {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

/* Subtle flame flicker — scale + rotation jitter under 3% so it
   reads as "alive" without yelling for attention. */
.timer-card__flame {
  display: inline-block;
  font-size: 22rpx;
  transform-origin: 50% 80%;
  animation: flame-flicker 1.6s ease-in-out infinite;
}

@keyframes flame-flicker {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.04) rotate(-3deg); }
  50% { transform: scale(0.98) rotate(2deg); }
  75% { transform: scale(1.02) rotate(-1deg); }
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 500;
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

/* Big timer: subtle vertical gradient gives it a "carved" / metallic
   look without being loud. Solid color fallback so the number stays
   readable on renderers that ignore -webkit-background-clip. */
.timer-card__clock {
  display: block;
  /* v0.21 density: 52→36 / 108→96 — still the page hero, but tighter */
  margin-top: 36rpx;
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
  text-align: center;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  color: #155946;
  background: linear-gradient(180deg, #1a624f 0%, #0f4836 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.timer-card__hint {
  display: block;
  /* v0.21 density: 18→14 */
  margin-top: 14rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  opacity: 0.85;
}

.timer-card__primary {
  /* v0.21 density: 38→26 */
  margin-top: 26rpx;
}

.timer-card__actions {
  display: flex;
  gap: 14rpx;
  /* v0.21 density: 36→26 */
  margin-top: 26rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

/* ============================================================
   v0.18.1 — compact six-subject progress card on home. Six rows of
   "subject · bar · minutes / target". Tap anywhere on the card to
   open the dedicated 六科进度 page.
   ============================================================ */
.subjects-card {
  /* v0.21 density: 24×28×22→18×24×18 */
  padding: 18rpx 24rpx 18rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.16), transparent 42%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.75),
    0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.08);
}

.subjects-card__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  /* v0.21 density: 14→10 */
  margin-bottom: 10rpx;
}

.subjects-card__title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.subjects-card__hint {
  font-size: 22rpx;
  color: var(--mint-600);
  letter-spacing: 0.2rpx;
  font-weight: 600;
}

.subjects-card__grid {
  display: flex;
  flex-direction: column;
