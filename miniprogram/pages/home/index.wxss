/* ──────────────────────────────────────────────────────────────────
 * v0.30 — home page styles, full rewrite per Claude-Design handoff
 * (docs/design-handoff/screen-home.jsx). Two top-level sections:
 *   1. IDLE  — header / exam hero (no card) / timer card / goal
 *              card / 6-科 grid
 *   2. FOCUS — full-viewport dark layout with centered Display
 *              clock + bottom buttons
 *
 * Tokens (--c-* / --fs-* / --r-* / --sh-* / --d-* / --ease-*) live
 * in app.wxss; this file only uses them. Legacy class names
 * (.timer-card, .exam-hero, .goal-card, .subjects-card) were
 * RENAMED to *-v2 / *-card-v2 so any stale CSS lurking elsewhere
 * doesn't bleed in. Old class definitions stripped wholesale.
 * ────────────────────────────────────────────────────────────────── */

.home-page {
  min-height: 100%;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
}

/* Stagger entry — each top-level section fades up together. v0.30.2
   stripped the broken `.page-pad:nth-child(N) .fade-up` stagger rule:
   it required `.fade-up` to be a *descendant* of `.page-pad`, but the
   WXML applies both classes to the same element, so the descendant
   selector never matched. Net effect was "stagger never fired" — now
   we just synchronize the fade-in; visually less fussy and matches
   the design's intent of a quiet entry. */
.fade-up { animation: home-fade-up 0.4s var(--ease-std, cubic-bezier(0.2, 0.8, 0.3, 1)) backwards; }
@keyframes home-fade-up {
  from { opacity: 0; transform: translateY(12rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ============================================================
   HEADER (idle only)
   ============================================================ */
.home-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  padding-top: 16rpx;
  padding-bottom: 32rpx;
}

.home-header__title {
  font-size: var(--fs-t1);
  font-weight: 800;
  color: var(--c-text-1);
  letter-spacing: -0.6rpx;
}

.home-header__streak {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  font-size: var(--fs-caption);
  color: var(--c-text-2);
}

.home-header__flame {
  font-size: 24rpx;
  line-height: 1;
}

.home-header__streak-num {
  font-weight: 700;
  color: var(--c-text-1);
}

/* ============================================================
   MAKEUP banner (conditional)
   ============================================================ */
.makeup-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 0;
  padding-bottom: 24rpx;
}

.makeup-banner__text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.makeup-banner__title {
  font-size: var(--fs-body);
  font-weight: 700;
  color: var(--c-text-1);
}

.makeup-banner__btn {
  /* v0.30.2 — was forcing 64rpx (32pt) with !important, below the
     44pt tap-target floor. Restored to the .btn-v2 default height
     (88rpx ≈ 44pt). Kept horizontal padding tight so it still reads
     as a banner-inline CTA rather than a full-width button. */
  flex-shrink: 0;
  padding-left: 32rpx;
  padding-right: 32rpx;
  font-size: var(--fs-caption);
}

/* ============================================================
   EXAM HERO — full-bleed, no card chrome
   ============================================================ */
.exam-hero {
  padding-bottom: 40rpx;
}

.exam-hero__eyebrow {
  display: block;
  margin-bottom: 8rpx;
  color: var(--c-text-2);
}

.exam-hero__row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.exam-hero__num {
  font-size: var(--fs-hero);
  font-weight: 800;
  color: var(--c-primary);
  line-height: 1;
  letter-spacing: -0.5rpx;
}

.exam-hero__unit {
  font-size: var(--fs-body);
  font-weight: 600;
  color: var(--c-text-2);
}

.exam-hero__date {
  display: block;
  margin-top: 6rpx;
  color: var(--c-text-2);
}

/* Urgency tiers — keep palette gentle; design uses primary text on
   bg, no card backgrounds tinted per tier. We just shift the num
   color for soon/urgent/imminent. */
.exam-hero--soon .exam-hero__num     { color: #c2562b; }
.exam-hero--urgent .exam-hero__num   { color: #c2562b; }
.exam-hero--imminent .exam-hero__num { color: var(--c-error); }

/* ============================================================
   TIMER CARD v2 (idle)
   ============================================================ */
.timer-card-v2 {
  padding: 56rpx 40rpx 44rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.timer-card-v2__eyebrow {
  display: block;
  color: var(--c-text-2);
}

.timer-card-v2__big {
  display: block;
  font-size: 96rpx;
  font-weight: 800;
  color: var(--c-text-1);
  line-height: 1;
  letter-spacing: -2rpx;
}

.timer-card-v2__caption {
  display: block;
  color: var(--c-text-2);
  margin-bottom: 16rpx;
}

.timer-card-v2__cta {
  width: 100%;
  min-height: 96rpx;
  height: 96rpx;
  font-size: var(--fs-body);
}

/* ============================================================
   GOAL CARD v2
   ============================================================ */
.goal-card-v2 {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.goal-card-v2__head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 16rpx;
}

.goal-card-v2__title {
  font-size: var(--fs-body);
  font-weight: 700;
  color: var(--c-text-1);
}

.goal-card-v2__value {
  font-size: var(--fs-caption);
  font-weight: 600;
  color: var(--c-text-2);
}

.goal-card-v2__value.is-reached {
  color: var(--c-primary);
  font-weight: 800;
}

.goal-card-v2__bar { /* relies on shared .bar utility */ }

.goal-card-v2__challenge {
  /* v0.30.2 — lifted min-height from ~38rpx (font + padding only) to
     56rpx so the bindtap target reaches the 28pt minimum. Still under
     the 44pt strict floor but the action it triggers is a low-stakes
     toast, not a destructive op. Anything taller would compete
     visually with the main CTA. */
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-height: 56rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--r-pill);
  background: rgba(46, 169, 133, 0.10);
  font-size: var(--fs-caption);
  font-weight: 600;
  color: var(--c-primary);
  align-self: flex-start;
}

.goal-card-v2__challenge.is-done {
  background: var(--c-primary);
  color: #fff;
}

.goal-card-v2__challenge-icon {
  /* v0.30.2 — was line-height: 1; unified with the label's 1.2 so
     ✓ (PingFang glyph, sits high in box) and 🎯 (emoji, sits low)
     don't visually jump when the chip flips to is-done. Same §1A
     rationale as the focus-mode meta + complete-hero pomo fixes. */
  font-size: var(--fs-caption);
  line-height: 1.2;
}

.goal-card-v2__challenge-text {
  line-height: 1.2;
}

.goal-card-v2__challenge-done {
  color: rgba(255, 255, 255, 0.8) !important;
  margin-left: 4rpx;
}

.goal-card-v2__weekly {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 4rpx;
}

.goal-card-v2__weekly-bar { height: 4rpx; }

/* ============================================================
   SIX-SUBJECT GRID v2 (2 columns × 3 rows)
   ============================================================ */
.subjects-card-v2 {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.subjects-card-v2__head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.subjects-card-v2__title {
  font-size: var(--fs-body);
  font-weight: 700;
  color: var(--c-text-1);
}

.subjects-card-v2__hint {
  color: var(--c-text-2);
}

.subjects-card-v2__grid {
  padding: 32rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  row-gap: 28rpx;
  column-gap: 40rpx;
}

.subjects-card-v2__row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.subjects-card-v2__row-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.subjects-card-v2__row-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--c-text-1);
}

.subjects-card-v2__row-value {
  font-size: var(--fs-caption);
  font-weight: 600;
  color: var(--c-text-2);
}

/* ============================================================
   FOCUS MODE — always-dark, full viewport
   ============================================================ */
.focus-mode {
  position: fixed;
  inset: 0;
  z-index: 50;
  background: var(--c-bg-dark);
  color: var(--c-text-1-dark);
  display: flex;
  flex-direction: column;
  animation: focus-mode-enter 0.32s var(--ease-std, cubic-bezier(0.2, 0.8, 0.3, 1));
  padding-top: 88rpx;
  padding-bottom: calc(72rpx + env(safe-area-inset-bottom));
  padding-left: 32rpx;
  padding-right: 32rpx;
}

@keyframes focus-mode-enter {
  0%   { opacity: 0; transform: scale(0.96); }
  100% { opacity: 1; transform: scale(1); }
}

.focus-mode__halo {
  position: absolute;
  top: -240rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 960rpx;
  height: 960rpx;
  pointer-events: none;
  background: radial-gradient(circle at center,
    rgba(46, 169, 133, 0.18) 0%,
    rgba(46, 169, 133, 0) 60%);
}

.focus-mode__meta {
  position: relative;
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 24rpx;
  color: var(--c-text-2-dark);
  font-size: var(--fs-caption);
}

/* v0.30.2 — each token pair is an inline-flex container with
   align-items:baseline so the tabular-nums digit run sits on the
   same baseline as the PingFang CJK label next to it. Pattern from
   ui-review-checklist §1A. */
.focus-mode__meta-pair {
  display: inline-flex;
  align-items: baseline;
  gap: 6rpx;
  line-height: 1.4;
}

.focus-mode__meta-strong {
  color: var(--c-text-1-dark);
  font-weight: 700;
  line-height: 1.4;
}

.focus-mode__meta-label {
  color: var(--c-text-2-dark);
  line-height: 1.4;
}

.focus-mode__divider {
  color: var(--c-text-2-dark);
  opacity: 0.4;
  line-height: 1.4;
}

.focus-mode__center {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.focus-mode__subject {
  color: var(--c-accent);
  letter-spacing: 0.5rpx;
}

.focus-mode__clock {
  font-size: 128rpx;
  font-weight: 800;
  color: var(--c-text-1-dark);
  line-height: 1;
  letter-spacing: 0;
  white-space: nowrap;
}

.focus-mode__clock.is-running {
  animation: focus-clock-breathe 4s ease-in-out infinite;
}

.focus-mode__clock.is-paused {
  opacity: 0.55;
}

@keyframes focus-clock-breathe {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.85; transform: scale(0.985); }
}

.focus-mode__status {
  color: var(--c-text-2-dark);
}

.focus-mode__cycles {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.focus-mode__cycle-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--c-stroke-dark);
}

.focus-mode__cycle-dot.is-done {
  background: var(--c-accent);
}

.focus-mode__actions {
  position: relative;
  display: flex;
  gap: 16rpx;
}

.focus-mode__btn {
  flex: 1;
  min-height: 104rpx;
  height: 104rpx;
  font-size: var(--fs-body);
}

/* Focus-mode buttons: ghost has light border, end-button uses
   accent (brighter than --c-primary, reads on the dark bg). */
.focus-mode .btn-v2--ghost {
  color: var(--c-text-1-dark);
  background: transparent;
  border: 2rpx solid rgba(232, 239, 236, 0.32);
}

.focus-mode .btn-v2--ghost:active {
  background: rgba(232, 239, 236, 0.06);
}

.focus-mode .btn-v2--primary {
  background: var(--c-accent);
  color: #fff;
}

.focus-mode .btn-v2--primary:active {
  background: var(--c-primary);
}

@media (prefers-reduced-motion: reduce) {
  .fade-up,
  .focus-mode,
  .focus-mode__clock.is-running { animation: none !important; }
}

/* v0.31 — cold-start quote overlay styles fully removed (the modal
   itself was deleted from home/index.ts + .wxml because every-launch
   dismiss-tap was daily friction for an app whose value prop is
   "reduce friction to focus"). */

@media (prefers-color-scheme: dark) {
  /* Idle-state titles + exam num lighten in dark mode */
  .home-header__title { color: var(--c-text-1-dark); }
  .home-header__streak { color: var(--c-text-2-dark); }
  .home-header__streak-num { color: var(--c-text-1-dark); }
  .exam-hero__num { color: var(--c-accent); }
  /* v0.30.2 — light-mode tier colors (#c2562b warn / #A0322B error)
     are too dark against --c-bg-dark (#1A1F1C). The .exam-hero--TIER
     selector outranks the flat .exam-hero__num override above, so we
     must restate per-tier shifts here with lighter palette siblings
     for proper WCAG AA contrast on dark. */
  .exam-hero--soon .exam-hero__num,
  .exam-hero--urgent .exam-hero__num   { color: #f0b27a; }
  .exam-hero--imminent .exam-hero__num { color: #f08a85; }
  .exam-hero__eyebrow,
  .exam-hero__unit,
  .exam-hero__date { color: var(--c-text-2-dark); }
  .timer-card-v2__big { color: var(--c-text-1-dark); }
  .timer-card-v2__eyebrow,
  .timer-card-v2__caption { color: var(--c-text-2-dark); }
  .goal-card-v2__title { color: var(--c-text-1-dark); }
  .goal-card-v2__value { color: var(--c-text-2-dark); }
  .goal-card-v2__value.is-reached { color: var(--c-accent); }
  .goal-card-v2__challenge {
    background: rgba(46, 169, 133, 0.18);
    color: var(--c-accent);
  }
  .goal-card-v2__challenge.is-done {
    background: var(--c-accent);
    color: var(--c-bg-dark);
  }
  .subjects-card-v2__title { color: var(--c-text-1-dark); }
  .subjects-card-v2__hint { color: var(--c-text-2-dark); }
  .subjects-card-v2__row-name { color: var(--c-text-1-dark); }
  .subjects-card-v2__row-value { color: var(--c-text-2-dark); }
  .makeup-banner__title { color: var(--c-text-1-dark); }
}
