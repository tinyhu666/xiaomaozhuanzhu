.home-page.is-focus-mode > .timer-card {
  background: transparent !important;
  box-shadow: none !important;
}

.home-page.is-focus-mode .timer-card__clock {
  font-size: 128rpx;
  letter-spacing: 0;
  text-shadow:
    0 0 34rpx rgba(46, 169, 133, 0.10),
    0 22rpx 54rpx rgba(0, 0, 0, 0.26);
}

.home-page.is-focus-mode .ghost-button {
  background: rgba(232, 239, 236, 0.04) !important;
}

.home-page.is-focus-mode .cta-button {
  background: linear-gradient(180deg, #35B994 0%, #2EA985 100%) !important;
  box-shadow: 0 16rpx 40rpx -24rpx rgba(46, 169, 133, 0.78);
}

@media (prefers-reduced-motion: reduce) {
  .exam-hero,
  .timer-card,
  .goal-card,
  .subjects-card {
    animation: none !important;
  }
}
