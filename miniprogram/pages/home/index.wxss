  padding: 24rpx 26rpx 22rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 1rpx 2rpx rgba(20, 60, 50, 0.03),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.08);
}

/* v0.22 — daily challenge collapsed into an inline subtitle on
   goal-card. The earlier dedicated chip + progress track ate a full
   row on home; in practice users glance at the goal bar and the
   "挑战 60分" number is enough information to know whether they've
   cleared the soft floor. Done state turns mint, otherwise a quiet
   sub-text styling that doesn't compete with the goal value.
   The big chip + sub progress track block was deleted. */
/* v0.25.2 — the pill switched from inline-block <text> to
   inline-flex <view>. Mixing symbol marks with Chinese ("挑战") and
   digits in a single <text> caused baseline misalignment because
   emoji glyphs sit taller than CJK characters. inline-flex with
   align-items:center makes the layout glyph-height-agnostic, and a
   small gap separates icon from text instead of relying on a raw
   space character in the template. Vertical padding bumped from
   2rpx to 4rpx so the pill has visible breathing room. */
.goal-card__challenge-inline {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  margin-left: 10rpx;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--mint-600);
  background: rgba(46, 169, 133, 0.1);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
  line-height: 1.4;
  vertical-align: middle;
}

.goal-card__challenge-inline-icon {
  font-size: 20rpx;
  line-height: 1;
  display: inline-flex;
  align-items: center;
}

.goal-card__challenge-inline-text {
  line-height: 1.4;
}

.goal-card__challenge-inline.is-done {
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
}

.goal-card__challenge-inline:active {
  opacity: 0.85;
}

/* v0.22 note: the dedicated challenge chip (.goal-card__challenge,
   its head/emoji/label/target/track/fill children) was removed when
   the challenge collapsed into the inline pill above. Search the git
   history at tag v0.21.x for the previous styling. */

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  position: relative;
  /* v0.21 density: 22→16 / 14→12 */
  margin-top: 16rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(20, 60, 50, 0.06);
}

/* Subtle gradient fill + inset top highlight gives the bar
   "carved" depth without being shiny. */
.goal-card__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(180deg, #4dbe96 0%, #228168 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.32);
  transform-origin: left center;
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  animation: progress-grow 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  animation-delay: 0.3s;
}

@keyframes progress-grow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.goal-card__fill.is-reached {
  background: linear-gradient(180deg, #2ea985 0%, #155946 100%);
}

.goal-card__hint {
  display: block;
  /* v0.21 density: 14→10 */
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
  /* v0.25.3 — text-align:center added after the button-text audit.
     The hint uses a compact completion label; with the label leading the
     line and the underlying progress bar centered, left-aligning
     made the celebration line look misplaced. */
  text-align: center;
}

/* Weekly progress row — sits under the daily bar in the same card.
   Visually quieter (thinner track, smaller text) so the daily metric
   stays the primary focus. */
.goal-card__weekly {
  /* v0.21 density: 18→14 / 16→12 */
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(46, 169, 133, 0.16);
}

.goal-card__weekly-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.goal-card__weekly-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__weekly-value {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.2rpx;
}

.goal-card__weekly-value.is-reached {
  color: var(--mint-600);
}

.goal-card__weekly-track {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  overflow: hidden;
}

.goal-card__weekly-fill {
  height: 100%;
  background: linear-gradient(90deg, #8aa6f0 0%, #4a6ed9 100%);
  border-radius: 999rpx;
  transition: width 0.42s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.goal-card__weekly-fill.is-reached {
  background: linear-gradient(90deg, #63cba8 0%, #2ea985 100%);
}

.makeup-banner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.22), transparent 40%),
    linear-gradient(180deg, rgba(255, 244, 224, 0.94) 0%, rgba(255, 233, 198, 0.92) 100%);
  border: 1rpx solid rgba(229, 158, 87, 0.26);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 32rpx -4rpx rgba(229, 158, 87, 0.16);
}

.makeup-banner__text {
