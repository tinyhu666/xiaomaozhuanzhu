.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Staggered fade-up entrance for the major sections so the page
   composes itself top-down rather than appearing all at once.
   `backwards` keeps each child invisible during its delay window. */
@keyframes home-fade-up {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.home-page > view {
  animation: home-fade-up 0.45s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.home-page > view:nth-child(1) { animation-delay: 0.04s; }
.home-page > view:nth-child(2) { animation-delay: 0.1s; }
.home-page > view:nth-child(3) { animation-delay: 0.16s; }
.home-page > view:nth-child(4) { animation-delay: 0.22s; }
.home-page > view:nth-child(5) { animation-delay: 0.28s; }

/* ============================================================
   Pre-start picker — mode toggle + subject chips. Lives only
   while a session is idle; collapses cleanly once running.
   ============================================================ */
.picker-card {
  position: relative;
  padding: 18rpx 20rpx 20rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.12), transparent 38%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 6rpx 18rpx -4rpx rgba(46, 169, 133, 0.08);
}

/* Mode toggle: pill-style segmented control with active fill. */
.picker-card__modes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.06);
}

.picker-card__mode {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 0;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-sub);
  letter-spacing: 0.4rpx;
  transition: all 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.picker-card__mode.is-active {
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 4rpx 14rpx rgba(46, 169, 133, 0.28);
  transform: translateY(-1rpx);
}

.picker-card__mode-icon {
  font-size: 26rpx;
  line-height: 1;
}

.picker-card__mode-label {
  font-size: 24rpx;
  font-weight: 700;
}

/* v0.15: hint line removed; chip row now sits directly under the
   mode toggle with a tighter margin. */
.picker-card__chip-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.picker-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 0.3rpx;
  color: var(--text-sub);
  background: rgba(46, 169, 133, 0.06);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  transition: all 0.22s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.picker-chip:active {
  transform: scale(0.96);
}

.picker-chip.is-active {
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 18rpx rgba(46, 169, 133, 0.28);
  transform: translateY(-1rpx);
}

/* Subject pill that appears in timer card meta when running. */
.timer-card__subject-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  margin-right: 8rpx;
}

/* Pomodoro cycle dots — sit just below the clock. */
.timer-card__cycles {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.timer-card__cycle-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: rgba(46, 169, 133, 0.16);
  transition: all 0.32s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.timer-card__cycle-dot.is-done {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 2rpx 8rpx rgba(46, 169, 133, 0.3);
  transform: scale(1.1);
}

.timer-card__cycle-extra {
  margin-left: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
}

/* Pomodoro mode overlay: subtle tomato hue so the active state is
   visually distinct from the free-timer mode. */
.timer-card.is-pomodoro {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 159, 90, 0.16), transparent 45%),
    radial-gradient(circle at 0% 100%, rgba(94, 195, 157, 0.12), transparent 45%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border-color: rgba(229, 122, 50, 0.18);
}

/* ============================================================
   Exam-strip — slim contextual banner. Designed in v0.13 to
   replace the previous full-hero countdown card, which fought
   the timer for visual dominance. The new strip lives in the
   "secondary information" register: short, horizontal, single-
   line. Four urgency tiers still drive the palette so the
   imminent-exam signal isn't lost; the day-count badge picks
   up a gentle pulse for ≤30 days.
   ============================================================ */
.exam-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 14rpx 22rpx;
  border-radius: 18rpx;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.6) 0%, rgba(255, 255, 255, 0.35) 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.16);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 4rpx 12rpx -3rpx rgba(46, 169, 133, 0.08);
}

.exam-strip__left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.exam-strip__label {
  font-size: 22rpx;
  font-weight: 700;
  color: #1d6f59;
  letter-spacing: 0.3rpx;
}

.exam-strip__date {
  font-size: 20rpx;
  color: var(--text-sub);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.2rpx;
}

.exam-strip__badge {
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.14);
  border: 1rpx solid rgba(46, 169, 133, 0.22);
}

.exam-strip__badge-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #155946;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.4rpx;
  line-height: 1;
}

.exam-strip__badge-unit {
  font-size: 20rpx;
  font-weight: 700;
  color: #1d6f59;
  letter-spacing: 0.4rpx;
}

/* Urgency tiers — soon (≤90), urgent (≤30), imminent (≤7).
   Each only re-tints the palette; the layout is identical. */
.exam-strip--soon {
  background: linear-gradient(180deg, rgba(255, 245, 224, 0.6) 0%, rgba(255, 230, 192, 0.4) 100%);
  border-color: rgba(229, 158, 87, 0.22);
}
.exam-strip--soon .exam-strip__label,
.exam-strip--soon .exam-strip__badge-num,
.exam-strip--soon .exam-strip__badge-unit { color: #8a4d10; }
.exam-strip--soon .exam-strip__badge {
  background: rgba(229, 158, 87, 0.18);
  border-color: rgba(229, 158, 87, 0.32);
}

.exam-strip--urgent {
  background: linear-gradient(180deg, rgba(255, 233, 217, 0.6) 0%, rgba(255, 210, 168, 0.4) 100%);
  border-color: rgba(229, 122, 50, 0.26);
}
.exam-strip--urgent .exam-strip__label,
.exam-strip--urgent .exam-strip__badge-num,
.exam-strip--urgent .exam-strip__badge-unit { color: #7a330a; }
.exam-strip--urgent .exam-strip__badge {
  background: rgba(229, 122, 50, 0.18);
  border-color: rgba(229, 122, 50, 0.32);
  animation: exam-strip-pulse 2.4s ease-in-out infinite;
}

.exam-strip--imminent {
  background: linear-gradient(180deg, rgba(255, 220, 220, 0.6) 0%, rgba(255, 196, 196, 0.45) 100%);
  border-color: rgba(217, 80, 80, 0.3);
}
.exam-strip--imminent .exam-strip__label,
.exam-strip--imminent .exam-strip__badge-num,
.exam-strip--imminent .exam-strip__badge-unit { color: #7a1a1a; }
.exam-strip--imminent .exam-strip__badge {
  background: rgba(217, 80, 80, 0.18);
  border-color: rgba(217, 80, 80, 0.36);
  animation: exam-strip-pulse 1.6s ease-in-out infinite;
}

@keyframes exam-strip-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.04); }
}

/* (Quote card + weekly-review removed in v0.9.3 — home is now
   focused on the immediate question "should I start a session now?".
   Heat map / weekly aggregates live in the dedicated tabs.) */

/* Timer is the hero card on this page: more elevation, gentle mesh
   gradient surface, and an ambient glow when a session is running.
   Three shadow layers (inset highlight + small crisp + large soft)
   give the card real "weight" that distinguishes it from secondary
   cards below. */
.timer-card {
  position: relative;
  padding: 40rpx 36rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(143, 217, 190, 0.28), transparent 48%),
    radial-gradient(circle at 6% 92%, rgba(94, 195, 157, 0.16), transparent 44%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.16);
  overflow: hidden;
  transition: box-shadow 0.4s ease, border-color 0.4s ease;
}

/* Active-session ambient: card edge lights up subtly, ring of mint
   glow extends 8rpx beyond the border like a soft halo. */
.timer-card.is-active {
  border-color: rgba(46, 169, 133, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.22),
    0 0 0 8rpx rgba(46, 169, 133, 0.04);
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* Status pill: tinted background + optional pulsing dot. The dot is
   a separate element so we can animate just the dot, not the text. */
.timer-card__status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
  transition: background 0.3s ease;
}

.timer-card__status.is-running {
  background: rgba(46, 169, 133, 0.14);
}

.timer-card__status.is-paused {
  background: rgba(229, 158, 87, 0.12);
  color: #c2782b;
}

/* Pulsing dot for "专注中". Two concentric rings: inner is the solid
   indicator, outer is a fading halo that breathes. */
.timer-card__status-dot {
  position: relative;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--mint-500);
  flex-shrink: 0;
}

.timer-card__status-dot::after {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: var(--mint-500);
  opacity: 0.4;
  animation: pulse-ring 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.6); opacity: 0.5; }
  80%, 100% { transform: scale(1.6); opacity: 0; }
}

.timer-card__status-text {
  display: inline-block;
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.timer-card__streak {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

/* Subtle flame flicker — scale + rotation jitter under 3% so it
   reads as "alive" without yelling for attention. */
.timer-card__flame {
  display: inline-block;
  font-size: 22rpx;
  transform-origin: 50% 80%;
  animation: flame-flicker 1.6s ease-in-out infinite;
}

@keyframes flame-flicker {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.04) rotate(-3deg); }
  50% { transform: scale(0.98) rotate(2deg); }
  75% { transform: scale(1.02) rotate(-1deg); }
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 500;
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

/* Big timer: subtle vertical gradient gives it a "carved" / metallic
   look without being loud. Solid color fallback so the number stays
   readable on renderers that ignore -webkit-background-clip. */
.timer-card__clock {
  display: block;
  margin-top: 52rpx;
  font-size: 108rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
  text-align: center;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  color: #155946;
  background: linear-gradient(180deg, #1a624f 0%, #0f4836 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.timer-card__hint {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  opacity: 0.85;
}

.timer-card__primary {
  margin-top: 38rpx;
}

.timer-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

.goal-card {
  position: relative;
  padding: 32rpx 32rpx 30rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 1rpx 2rpx rgba(20, 60, 50, 0.03),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.08);
}

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  position: relative;
  margin-top: 22rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(20, 60, 50, 0.06);
}

/* Subtle gradient fill + inset top highlight gives the bar
   "carved" depth without being shiny. */
.goal-card__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(180deg, #4dbe96 0%, #228168 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.32);
  transform-origin: left center;
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  animation: progress-grow 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  animation-delay: 0.3s;
}

@keyframes progress-grow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.goal-card__fill.is-reached {
  background: linear-gradient(180deg, #2ea985 0%, #155946 100%);
}

.goal-card__hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
}

/* Weekly progress row — sits under the daily bar in the same card.
   Visually quieter (thinner track, smaller text) so the daily metric
   stays the primary focus. */
.goal-card__weekly {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(46, 169, 133, 0.16);
}

.goal-card__weekly-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.goal-card__weekly-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__weekly-value {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.2rpx;
}

.goal-card__weekly-value.is-reached {
  color: var(--mint-600);
}

.goal-card__weekly-track {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  overflow: hidden;
}

.goal-card__weekly-fill {
  height: 100%;
  background: linear-gradient(90deg, #8aa6f0 0%, #4a6ed9 100%);
  border-radius: 999rpx;
  transition: width 0.42s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.goal-card__weekly-fill.is-reached {
  background: linear-gradient(90deg, #63cba8 0%, #2ea985 100%);
}

.makeup-banner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.22), transparent 40%),
    linear-gradient(180deg, rgba(255, 244, 224, 0.94) 0%, rgba(255, 233, 198, 0.92) 100%);
  border: 1rpx solid rgba(229, 158, 87, 0.26);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 32rpx -4rpx rgba(229, 158, 87, 0.16);
}

.makeup-banner__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.makeup-banner__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b3f15;
}

.makeup-banner__sub {
  font-size: 22rpx;
  color: #8a5a2b;
  line-height: 1.5;
}

.makeup-banner__btn {
  flex-shrink: 0;
  min-height: 68rpx;
  height: 68rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  background: linear-gradient(180deg, #ec9a36 0%, #d97a23 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 10rpx 22rpx rgba(229, 137, 50, 0.28);
}

/* .home-version removed in v0.13 — version label no longer rendered
   on the home page (still in 我的 footer for diagnostic purposes). */
