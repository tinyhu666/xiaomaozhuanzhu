.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Staggered fade-up entrance for the major sections so the page
   composes itself top-down rather than appearing all at once.
   `backwards` keeps each child invisible during its delay window. */
@keyframes home-fade-up {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.home-page > view,
.home-page > .home-version {
  animation: home-fade-up 0.45s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

.home-page > view:nth-child(1) { animation-delay: 0.04s; }
.home-page > view:nth-child(2) { animation-delay: 0.1s; }
.home-page > view:nth-child(3) { animation-delay: 0.16s; }
.home-page > view:nth-child(4) { animation-delay: 0.22s; }
.home-page > view:nth-child(5) { animation-delay: 0.28s; }
.home-page > view:nth-child(6) { animation-delay: 0.34s; }
.home-page > .home-version { animation-delay: 0.4s; }

/* ============================================================
   Exam countdown — the most prominent card after the timer.
   Four urgency tiers (calm / soon / urgent / imminent) that shift
   the palette from mint to amber to red as the exam approaches.
   The number pulses gently; the background has a slow ambient
   shimmer; the imminent tier adds a heartbeat ring to demand
   attention. All animations are GPU-cheap (transform + opacity).
   ============================================================ */
.exam-countdown {
  position: relative;
  overflow: hidden;
  padding: 28rpx 32rpx 30rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(46, 169, 133, 0.14);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.55),
    0 14rpx 36rpx -8rpx rgba(46, 169, 133, 0.18);
  /* Default palette — mint (calm/soon shares the base) */
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.35), transparent 45%),
    linear-gradient(180deg, #f3fcf7 0%, #d9f1e6 100%);
}

.exam-countdown__glow {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(94, 195, 157, 0.45), transparent 70%);
  filter: blur(6rpx);
  pointer-events: none;
  animation: exam-pulse 4.5s ease-in-out infinite;
}

@keyframes exam-pulse {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.12); opacity: 1; }
}

.exam-countdown__header {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  z-index: 1;
}

.exam-countdown__pill {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #155946;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid rgba(46, 169, 133, 0.22);
  letter-spacing: 0.4rpx;
}

.exam-countdown__date {
  font-size: 22rpx;
  font-weight: 700;
  color: #155946;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.2rpx;
  opacity: 0.85;
}

.exam-countdown__number-wrap {
  position: relative;
  display: flex;
  align-items: flex-end;
  margin-top: 10rpx;
  padding-bottom: 6rpx;
  z-index: 1;
}

.exam-countdown__number {
  font-size: 132rpx;
  font-weight: 800;
  line-height: 1;
  color: #155946;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: -1rpx;
  /* Tiny breathing animation to draw the eye without being noisy. */
  animation: exam-breath 3.2s ease-in-out infinite;
  transform-origin: bottom left;
  text-shadow: 0 4rpx 14rpx rgba(46, 169, 133, 0.18);
}

@keyframes exam-breath {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}

.exam-countdown__unit {
  margin-left: 12rpx;
  margin-bottom: 14rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #155946;
  opacity: 0.7;
  letter-spacing: 1rpx;
}

.exam-countdown__motivation {
  display: block;
  margin-top: 8rpx;
  position: relative;
  font-size: 24rpx;
  font-weight: 600;
  color: #155946;
  letter-spacing: 0.3rpx;
  line-height: 1.5;
  z-index: 1;
  opacity: 0.92;
}

.exam-countdown__fallback {
  display: block;
  margin-top: 8rpx;
  position: relative;
  font-size: 18rpx;
  color: #155946;
  opacity: 0.55;
  z-index: 1;
}

/* --- Urgency tier overrides ---------------------------------- */

/* soon: ≤ 90 days — warm mint, slightly more saturated */
.exam-countdown--soon {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.32), transparent 45%),
    linear-gradient(180deg, #fff6e6 0%, #ffe6c0 100%);
  border-color: rgba(229, 158, 87, 0.22);
}
.exam-countdown--soon .exam-countdown__glow {
  background: radial-gradient(circle, rgba(229, 158, 87, 0.5), transparent 70%);
}
.exam-countdown--soon .exam-countdown__pill,
.exam-countdown--soon .exam-countdown__date,
.exam-countdown--soon .exam-countdown__number,
.exam-countdown--soon .exam-countdown__unit,
.exam-countdown--soon .exam-countdown__motivation,
.exam-countdown--soon .exam-countdown__fallback {
  color: #8a4d10;
}
.exam-countdown--soon .exam-countdown__pill {
  background: rgba(255, 255, 255, 0.78);
  border-color: rgba(229, 158, 87, 0.28);
}

/* urgent: ≤ 30 days — amber/orange */
.exam-countdown--urgent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 159, 90, 0.35), transparent 45%),
    linear-gradient(180deg, #fff0e0 0%, #ffd2a8 100%);
  border-color: rgba(229, 122, 50, 0.28);
}
.exam-countdown--urgent .exam-countdown__glow {
  background: radial-gradient(circle, rgba(255, 138, 60, 0.55), transparent 70%);
  animation-duration: 3s;
}
.exam-countdown--urgent .exam-countdown__pill,
.exam-countdown--urgent .exam-countdown__date,
.exam-countdown--urgent .exam-countdown__number,
.exam-countdown--urgent .exam-countdown__unit,
.exam-countdown--urgent .exam-countdown__motivation,
.exam-countdown--urgent .exam-countdown__fallback {
  color: #7a330a;
}
.exam-countdown--urgent .exam-countdown__pill {
  background: rgba(255, 255, 255, 0.82);
  border-color: rgba(229, 122, 50, 0.32);
}
.exam-countdown--urgent .exam-countdown__number {
  animation-duration: 2.4s;
}

/* imminent: ≤ 7 days — red, fast pulse, halo ring */
.exam-countdown--imminent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 122, 122, 0.4), transparent 45%),
    linear-gradient(180deg, #ffe6e6 0%, #ffc4c4 100%);
  border-color: rgba(217, 80, 80, 0.32);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.55),
    0 14rpx 36rpx -8rpx rgba(217, 80, 80, 0.28);
}
.exam-countdown--imminent .exam-countdown__glow {
  background: radial-gradient(circle, rgba(229, 80, 80, 0.55), transparent 70%);
  animation-duration: 1.8s;
}
.exam-countdown--imminent .exam-countdown__pill,
.exam-countdown--imminent .exam-countdown__date,
.exam-countdown--imminent .exam-countdown__number,
.exam-countdown--imminent .exam-countdown__unit,
.exam-countdown--imminent .exam-countdown__motivation,
.exam-countdown--imminent .exam-countdown__fallback {
  color: #7a1a1a;
}
.exam-countdown--imminent .exam-countdown__pill {
  background: rgba(255, 255, 255, 0.85);
  border-color: rgba(217, 80, 80, 0.4);
}
.exam-countdown--imminent .exam-countdown__number {
  animation: exam-heartbeat 1.4s ease-in-out infinite;
}
@keyframes exam-heartbeat {
  0%, 30%, 70%, 100% { transform: scale(1); }
  15% { transform: scale(1.08); }
  45% { transform: scale(1.04); }
}

/* Quote card: editorial pull-quote feel. Layered surface with one
   restored watermark glyph + a left-side mint hairline rail (book-
   page mark) + tight typography. Soft shadow + inset highlight
   gives it printed-paper depth. */
.quote-card {
  position: relative;
  padding: 32rpx 36rpx 32rpx 44rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.18), transparent 38%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.8),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.1);
  overflow: hidden;
}

/* Editorial side-rail: thin mint line on the left margin like a
   classical pull-quote indent. */
.quote-card::before {
  content: "";
  position: absolute;
  top: 36rpx;
  bottom: 36rpx;
  left: 22rpx;
  width: 3rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, var(--mint-400) 0%, rgba(143, 217, 190, 0.3) 100%);
  opacity: 0.7;
}

.quote-card__mark {
  position: absolute;
  top: -52rpx;
  right: 24rpx;
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 700;
  font-size: 220rpx;
  line-height: 1;
  color: rgba(46, 169, 133, 0.08);
  pointer-events: none;
  user-select: none;
}

.quote-card__chip {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  border: 1rpx solid rgba(46, 169, 133, 0.16);
  margin-bottom: 18rpx;
}

.quote-card__chip-text {
  font-size: 18rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 1.6rpx;
  font-feature-settings: "tnum" 1;
}

/* English: confident solid color (not the busy 3-stop gradient) */
.quote-card__en {
  position: relative;
  display: block;
  font-family: Georgia, "Times New Roman", "PingFang SC", serif;
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.28;
  letter-spacing: 0.3rpx;
  color: #155946;
}

.quote-card__zh {
  position: relative;
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.7;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
}

/* Timer is the hero card on this page: more elevation, gentle mesh
   gradient surface, and an ambient glow when a session is running.
   Three shadow layers (inset highlight + small crisp + large soft)
   give the card real "weight" that distinguishes it from secondary
   cards below. */
.timer-card {
  position: relative;
  padding: 40rpx 36rpx;
  border-radius: 32rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(143, 217, 190, 0.28), transparent 48%),
    radial-gradient(circle at 6% 92%, rgba(94, 195, 157, 0.16), transparent 44%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.16);
  overflow: hidden;
  transition: box-shadow 0.4s ease, border-color 0.4s ease;
}

/* Active-session ambient: card edge lights up subtly, ring of mint
   glow extends 8rpx beyond the border like a soft halo. */
.timer-card.is-active {
  border-color: rgba(46, 169, 133, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.22),
    0 0 0 8rpx rgba(46, 169, 133, 0.04);
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* Status pill: tinted background + optional pulsing dot. The dot is
   a separate element so we can animate just the dot, not the text. */
.timer-card__status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
  transition: background 0.3s ease;
}

.timer-card__status.is-running {
  background: rgba(46, 169, 133, 0.14);
}

.timer-card__status.is-paused {
  background: rgba(229, 158, 87, 0.12);
  color: #c2782b;
}

/* Pulsing dot for "专注中". Two concentric rings: inner is the solid
   indicator, outer is a fading halo that breathes. */
.timer-card__status-dot {
  position: relative;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--mint-500);
  flex-shrink: 0;
}

.timer-card__status-dot::after {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: var(--mint-500);
  opacity: 0.4;
  animation: pulse-ring 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.6); opacity: 0.5; }
  80%, 100% { transform: scale(1.6); opacity: 0; }
}

.timer-card__status-text {
  display: inline-block;
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.timer-card__streak {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

/* Subtle flame flicker — scale + rotation jitter under 3% so it
   reads as "alive" without yelling for attention. */
.timer-card__flame {
  display: inline-block;
  font-size: 22rpx;
  transform-origin: 50% 80%;
  animation: flame-flicker 1.6s ease-in-out infinite;
}

@keyframes flame-flicker {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.04) rotate(-3deg); }
  50% { transform: scale(0.98) rotate(2deg); }
  75% { transform: scale(1.02) rotate(-1deg); }
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 500;
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

/* Big timer: subtle vertical gradient gives it a "carved" / metallic
   look without being loud. Solid color fallback so the number stays
   readable on renderers that ignore -webkit-background-clip. */
.timer-card__clock {
  display: block;
  margin-top: 52rpx;
  font-size: 108rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
  text-align: center;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  color: #155946;
  background: linear-gradient(180deg, #1a624f 0%, #0f4836 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.timer-card__hint {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  opacity: 0.85;
}

.timer-card__primary {
  margin-top: 38rpx;
}

.timer-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

.goal-card {
  position: relative;
  padding: 32rpx 32rpx 30rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 1rpx 2rpx rgba(20, 60, 50, 0.03),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.08);
}

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  position: relative;
  margin-top: 22rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(20, 60, 50, 0.06);
}

/* Subtle gradient fill + inset top highlight gives the bar
   "carved" depth without being shiny. */
.goal-card__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(180deg, #4dbe96 0%, #228168 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.32);
  transform-origin: left center;
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  animation: progress-grow 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  animation-delay: 0.3s;
}

@keyframes progress-grow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.goal-card__fill.is-reached {
  background: linear-gradient(180deg, #2ea985 0%, #155946 100%);
}

.goal-card__hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
}

.makeup-banner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.22), transparent 40%),
    linear-gradient(180deg, rgba(255, 244, 224, 0.94) 0%, rgba(255, 233, 198, 0.92) 100%);
  border: 1rpx solid rgba(229, 158, 87, 0.26);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 32rpx -4rpx rgba(229, 158, 87, 0.16);
}

.makeup-banner__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.makeup-banner__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b3f15;
}

.makeup-banner__sub {
  font-size: 22rpx;
  color: #8a5a2b;
  line-height: 1.5;
}

.makeup-banner__btn {
  flex-shrink: 0;
  min-height: 68rpx;
  height: 68rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  background: linear-gradient(180deg, #ec9a36 0%, #d97a23 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 10rpx 22rpx rgba(229, 137, 50, 0.28);
}

.weekly-card {
  position: relative;
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 0% 0%, rgba(143, 217, 190, 0.12), transparent 38%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 1rpx 2rpx rgba(20, 60, 50, 0.03),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.08);
}

.weekly-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.weekly-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weekly-card__title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.weekly-card__range {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.weekly-card__total {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.weekly-card__change {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.weekly-card__change--up {
  color: var(--mint-600);
}

.weekly-card__change--down {
  color: #c2654a;
}

.weekly-card__change--flat {
  color: var(--text-sub);
}

.weekly-card__bars {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  align-items: end;
  margin-top: 24rpx;
}

.weekly-card__bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.weekly-card__bar-track {
  width: 26rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: rgba(46, 169, 133, 0.06);
  box-shadow: inset 0 1rpx 2rpx rgba(20, 60, 50, 0.04);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.weekly-card__bar-fill {
  width: 100%;
  min-height: 0;
  background: linear-gradient(180deg, #6fc99a 0%, #2ea985 100%);
  border-top-left-radius: 6rpx;
  border-top-right-radius: 6rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.28);
  transform-origin: bottom center;
  transition: height 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  animation: bar-grow 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

@keyframes bar-grow {
  from { transform: scaleY(0); }
  to { transform: scaleY(1); }
}

/* Stagger each bar so the row builds left-to-right. */
.weekly-card__bar:nth-child(1) .weekly-card__bar-fill { animation-delay: 0.06s; }
.weekly-card__bar:nth-child(2) .weekly-card__bar-fill { animation-delay: 0.12s; }
.weekly-card__bar:nth-child(3) .weekly-card__bar-fill { animation-delay: 0.18s; }
.weekly-card__bar:nth-child(4) .weekly-card__bar-fill { animation-delay: 0.24s; }
.weekly-card__bar:nth-child(5) .weekly-card__bar-fill { animation-delay: 0.30s; }
.weekly-card__bar:nth-child(6) .weekly-card__bar-fill { animation-delay: 0.36s; }
.weekly-card__bar:nth-child(7) .weekly-card__bar-fill { animation-delay: 0.42s; }

.weekly-card__bar.is-today .weekly-card__bar-fill {
  background: linear-gradient(180deg, #2ea985 0%, #0a4631 100%);
}

.weekly-card__bar.is-today .weekly-card__bar-label {
  color: var(--mint-600);
  font-weight: 700;
}

.weekly-card__bar.is-future .weekly-card__bar-track {
  opacity: 0.5;
}

.weekly-card__bar-label {
  font-size: 20rpx;
  color: var(--text-sub);
  line-height: 1;
  font-weight: 500;
}

.weekly-card__rows {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(46, 169, 133, 0.1);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.weekly-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
}

.weekly-card__row-label {
  color: var(--text-sub);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.weekly-card__row-value {
  flex: 1;
  text-align: right;
  font-weight: 500;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
}

.home-version {
  display: block;
  margin: 14rpx auto 0;
  text-align: center;
  font-size: 18rpx;
  color: rgba(94, 125, 117, 0.5);
  letter-spacing: 1rpx;
}
