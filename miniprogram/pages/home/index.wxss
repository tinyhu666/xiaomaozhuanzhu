.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.quote-card {
  position: relative;
  padding: 28rpx 36rpx 36rpx;
  border-radius: 36rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(143, 217, 190, 0.35), transparent 44%),
    radial-gradient(circle at 8% 92%, rgba(94, 195, 157, 0.22), transparent 40%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.97) 0%, rgba(228, 248, 240, 0.94) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.14);
  box-shadow:
    0 18rpx 44rpx rgba(46, 169, 133, 0.12),
    inset 0 2rpx 0 rgba(255, 255, 255, 0.6);
  overflow: hidden;
}

/* Two giant serif quote glyphs at opposite corners frame the line
   like a literary pull-quote — open mark top-left, close mark
   bottom-right (flipped via scaleY). Both are pure decoration so we
   keep them watermark-light and pointer-events: none. */
.quote-card__mark {
  position: absolute;
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 700;
  line-height: 1;
  pointer-events: none;
  user-select: none;
}

.quote-card__mark--open {
  top: -36rpx;
  left: 8rpx;
  font-size: 240rpx;
  color: rgba(46, 169, 133, 0.16);
}

.quote-card__mark--close {
  bottom: -110rpx;
  right: 8rpx;
  font-size: 200rpx;
  color: rgba(46, 169, 133, 0.1);
  transform: rotate(180deg);
}

/* Cat-paw mascot, slightly tilted, in the top-right corner. */
.quote-card__paw {
  position: absolute;
  top: 24rpx;
  right: 28rpx;
  font-size: 36rpx;
  opacity: 0.82;
  transform: rotate(-14deg);
}

/* Small chip header above the quote — sets context ("今日金句") and
   gives the card a clear vertical anchor before the big text. */
.quote-card__chip {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 18rpx 6rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(46, 169, 133, 0.16) 0%, rgba(143, 217, 190, 0.18) 100%);
  border: 2rpx solid rgba(46, 169, 133, 0.22);
  margin-bottom: 18rpx;
}

.quote-card__chip-icon {
  font-size: 18rpx;
  color: var(--mint-600);
  transform: translateY(-1rpx);
}

.quote-card__chip-text {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--mint-600);
  letter-spacing: 2rpx;
}

/* English line gets a left-to-right mint gradient via -webkit-text-
   fill-color: transparent + background-clip: text. WeChat MP runs on
   WebKit so this works; the solid color: var(--mint-600) is a
   fallback for any renderer that doesn't honor background-clip. */
.quote-card__en {
  position: relative;
  display: block;
  font-family: Georgia, "Times New Roman", "PingFang SC", serif;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.24;
  letter-spacing: 0.2rpx;
  color: var(--mint-600);
  background: linear-gradient(135deg, #155946 0%, #2ea985 55%, #5ec39d 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Tiny mint accent bar separating English and Chinese — gives the
   card a deliberate, designed feel. */
.quote-card__divider {
  position: relative;
  width: 64rpx;
  height: 4rpx;
  margin: 20rpx 0 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, var(--mint-500) 0%, rgba(143, 217, 190, 0.6) 100%);
  box-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.6);
}

.quote-card__zh {
  position: relative;
  display: block;
  font-size: 28rpx;
  line-height: 1.7;
  color: var(--text-main);
  letter-spacing: 0.6rpx;
  opacity: 0.78;
}

.timer-card {
  position: relative;
  padding: 32rpx 28rpx 32rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(94, 195, 157, 0.22), transparent 40%),
    radial-gradient(circle at 8% 92%, rgba(143, 217, 190, 0.18), transparent 38%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 251, 245, 0.96) 100%);
  box-shadow: 0 24rpx 54rpx rgba(46, 169, 133, 0.14);
  overflow: hidden;
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.timer-card__status {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
  box-sizing: border-box;
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.timer-card__clock {
  display: block;
  margin-top: 42rpx;
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 2rpx;
  text-align: center;
}

.timer-card__hint {
  display: block;
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
}

.timer-card__primary {
  margin-top: 38rpx;
}

.timer-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

.goal-card {
  padding: 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 16rpx 36rpx rgba(46, 169, 133, 0.06);
}

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
}

.goal-card__value {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  margin-top: 18rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
}

.goal-card__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(135deg, #8fd9be 0%, #2ea985 100%);
  transition: width 0.4s ease;
}

.goal-card__fill.is-reached {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
}

.goal-card__hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
}

.makeup-banner {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, rgba(255, 230, 191, 0.85) 0%, rgba(255, 207, 138, 0.95) 100%);
  border: 2rpx solid rgba(229, 158, 87, 0.32);
  box-shadow: 0 16rpx 36rpx rgba(229, 158, 87, 0.18);
}

.makeup-banner__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.makeup-banner__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b3f15;
}

.makeup-banner__sub {
  font-size: 22rpx;
  color: #8a5a2b;
  line-height: 1.5;
}

.makeup-banner__btn {
  flex-shrink: 0;
  min-height: 72rpx;
  height: 72rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #f4a93f 0%, #e58932 100%);
  box-shadow: 0 12rpx 28rpx rgba(229, 137, 50, 0.32);
}

.weekly-card {
  padding: 26rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 16rpx 36rpx rgba(46, 169, 133, 0.06);
}

.weekly-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.weekly-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weekly-card__title {
  font-size: 28rpx;
  font-weight: 700;
}

.weekly-card__range {
  font-size: 22rpx;
  color: var(--text-sub);
}

.weekly-card__total {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--mint-600);
}

.weekly-card__change {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.weekly-card__change--up {
  color: var(--mint-600);
}

.weekly-card__change--down {
  color: #c2654a;
}

.weekly-card__change--flat {
  color: var(--text-sub);
}

.weekly-card__bars {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  align-items: end;
  margin-top: 22rpx;
  padding: 10rpx 4rpx 0;
}

.weekly-card__bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.weekly-card__bar-track {
  width: 28rpx;
  height: 96rpx;
  border-radius: 8rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.weekly-card__bar-fill {
  width: 100%;
  min-height: 0;
  background: linear-gradient(180deg, #6fc99a 0%, #2ea985 100%);
  border-top-left-radius: 6rpx;
  border-top-right-radius: 6rpx;
  transition: height 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.weekly-card__bar.is-today .weekly-card__bar-track {
  background: rgba(46, 169, 133, 0.14);
  box-shadow: 0 0 0 3rpx rgba(46, 169, 133, 0.22);
}

.weekly-card__bar.is-today .weekly-card__bar-fill {
  background: linear-gradient(180deg, #2ea985 0%, #0a4631 100%);
}

.weekly-card__bar.is-today .weekly-card__bar-label {
  color: var(--mint-600);
  font-weight: 800;
}

.weekly-card__bar.is-future .weekly-card__bar-track {
  opacity: 0.5;
}

.weekly-card__bar-label {
  font-size: 20rpx;
  color: var(--text-sub);
  line-height: 1;
}

.weekly-card__rows {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.weekly-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.weekly-card__row-label {
  color: var(--text-sub);
}

.weekly-card__row-value {
  flex: 1;
  text-align: right;
  font-weight: 600;
  color: var(--text-main);
}

.mini-calendar {
  padding: 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(46, 169, 133, 0.08);
}

.mini-calendar__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.mini-calendar__title,
.mini-calendar__month {
  display: block;
}

.mini-calendar__title {
  font-size: 28rpx;
  font-weight: 700;
}

.mini-calendar__month {
  margin-top: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.mini-calendar__total {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--mint-600);
}

.mini-calendar__weekdays {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 24rpx;
  color: var(--text-sub);
  font-size: 20rpx;
  text-align: center;
}

.mini-calendar__grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
}

/* Heat-map palette: 6 distinct lightness steps with deliberately wider
   gaps on the light end so level-0 and level-1 are never confused.
   Lightness sequence ≈ 96% / 84% / 70% / 50% / 35% / 22%. */
.mini-calendar__cell {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  border-radius: 16rpx;
  background: #f0f6f3;
  border: 2rpx solid #d8e8e0;
  box-sizing: border-box;
  transition: background 0.25s ease, border-color 0.25s ease;
}

.mini-calendar__cell.is-faded {
  opacity: 0.32;
}

.mini-calendar__cell.level-1 {
  background: #b3e3c7;
  border-color: #8fd1ad;
}

.mini-calendar__cell.level-2 {
  background: #6fc99a;
  border-color: #4eb27e;
}

.mini-calendar__cell.level-3 {
  background: #2ea985;
  border-color: #228168;
}

.mini-calendar__cell.level-4 {
  background: #1a7558;
  border-color: #135a43;
}

.mini-calendar__cell.level-5 {
  background: #0a4631;
  border-color: #073323;
}

/* White day number whenever bg is dark enough to lose dark text. */
.mini-calendar__cell.level-3 .mini-calendar__day,
.mini-calendar__cell.level-4 .mini-calendar__day,
.mini-calendar__cell.level-5 .mini-calendar__day {
  color: #ffffff;
}

/* Today indicator: outer ring via box-shadow + bold number. NO transform —
   transform/scale on iOS WeChat can trigger compositing glitches that
   leave the cell content blank. */
.mini-calendar__cell.is-today {
  border-color: var(--mint-600);
  box-shadow:
    0 0 0 3rpx #ffffff,
    0 0 0 6rpx var(--mint-600);
}

.mini-calendar__cell.is-today .mini-calendar__day {
  font-weight: 800;
}

.mini-calendar__day {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1;
}

.mini-calendar__legend {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 22rpx;
  font-size: 20rpx;
  color: var(--text-sub);
}

.mini-calendar__legend-text {
  color: var(--text-sub);
  font-size: 20rpx;
}

.mini-calendar__legend-swatches {
  display: flex;
  gap: 6rpx;
}

.mini-calendar__legend-swatch {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  border: 2rpx solid rgba(46, 169, 133, 0.18);
  box-sizing: border-box;
}

.mini-calendar__legend-swatch.level-0 {
  background: #f0f6f3;
  border-color: #d8e8e0;
}

.mini-calendar__legend-swatch.level-1 {
  background: #b3e3c7;
  border-color: #8fd1ad;
}

.mini-calendar__legend-swatch.level-2 {
  background: #6fc99a;
  border-color: #4eb27e;
}

.mini-calendar__legend-swatch.level-3 {
  background: #2ea985;
  border-color: #228168;
}

.mini-calendar__legend-swatch.level-4 {
  background: #1a7558;
  border-color: #135a43;
}

.mini-calendar__legend-swatch.level-5 {
  background: #0a4631;
  border-color: #073323;
}

.home-version {
  display: block;
  margin: 14rpx auto 0;
  text-align: center;
  font-size: 18rpx;
  color: rgba(94, 125, 117, 0.5);
  letter-spacing: 1rpx;
}
