.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.quote-card {
  padding: 28rpx 28rpx 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
}

.quote-card__en {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.quote-card__zh {
  display: block;
  margin-top: 10rpx;
  color: var(--text-sub);
  font-size: 24rpx;
  line-height: 1.6;
}

.timer-card {
  padding: 32rpx 28rpx 28rpx;
  border-radius: 40rpx;
  background:
    radial-gradient(circle at top right, rgba(94, 195, 157, 0.16), transparent 42%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(237, 251, 245, 0.96) 100%);
  box-shadow: 0 24rpx 54rpx rgba(46, 169, 133, 0.12);
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 22rpx;
  min-width: 148rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  text-align: center;
  box-sizing: border-box;
}

.timer-card__status-label {
  display: block;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.timer-card__clock {
  display: block;
  margin-top: 42rpx;
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1;
  letter-spacing: 2rpx;
  text-align: center;
}

.timer-card__primary {
  margin-top: 38rpx;
}

.timer-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary,
.timer-card__secondary {
  width: 100%;
}

.mini-calendar {
  padding: 26rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 2rpx solid rgba(46, 169, 133, 0.08);
  box-shadow: 0 18rpx 42rpx rgba(46, 169, 133, 0.08);
}

.mini-calendar__header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.mini-calendar__title,
.mini-calendar__month {
  display: block;
}

.mini-calendar__title {
  font-size: 28rpx;
  font-weight: 700;
}

.mini-calendar__month {
  margin-top: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
}

.mini-calendar__total {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--mint-600);
}

.mini-calendar__weekdays {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 24rpx;
  color: var(--text-sub);
  font-size: 20rpx;
  text-align: center;
}

.mini-calendar__grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 14rpx;
}

.mini-calendar__cell {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(46, 169, 133, 0.04);
}

.mini-calendar__cell.is-faded {
  opacity: 0.28;
}

.mini-calendar__cell.level-1 {
  background: rgba(46, 169, 133, 0.14);
}

.mini-calendar__cell.level-2 {
  background: rgba(46, 169, 133, 0.24);
}

.mini-calendar__cell.level-3 {
  background: rgba(46, 169, 133, 0.45);
}

.mini-calendar__cell.level-4 {
  background: #2ea985;
}

.mini-calendar__cell.level-3 .mini-calendar__day,
.mini-calendar__cell.level-4 .mini-calendar__day {
  color: #ffffff;
}

.mini-calendar__day {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-main);
}
