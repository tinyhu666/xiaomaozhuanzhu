.home-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* Quote card: minimal, editorial. One quote glyph as watermark, one
   small date chip, big serif English, supporting Chinese. The
   background is almost-white with a hairline border instead of the
   prior dual-radial-gradient — silence is the point. */
.quote-card {
  position: relative;
  padding: 36rpx 36rpx 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: 0 8rpx 28rpx rgba(46, 169, 133, 0.06);
  overflow: hidden;
}

.quote-card__mark {
  position: absolute;
  top: -42rpx;
  left: 14rpx;
  font-family: Georgia, "Times New Roman", serif;
  font-weight: 700;
  font-size: 220rpx;
  line-height: 1;
  color: rgba(46, 169, 133, 0.1);
  pointer-events: none;
  user-select: none;
}

.quote-card__chip {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  margin-bottom: 16rpx;
}

.quote-card__chip-text {
  font-size: 18rpx;
  font-weight: 600;
  color: var(--mint-600);
  letter-spacing: 1.5rpx;
  font-feature-settings: "tnum" 1;
}

.quote-card__en {
  position: relative;
  display: block;
  font-family: Georgia, "Times New Roman", "PingFang SC", serif;
  font-size: 42rpx;
  font-weight: 600;
  line-height: 1.28;
  letter-spacing: 0.3rpx;
  color: #1a624f;
}

.quote-card__zh {
  position: relative;
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
}

.timer-card {
  position: relative;
  padding: 36rpx 32rpx 36rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: 0 12rpx 36rpx rgba(46, 169, 133, 0.08);
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* Status pill: minimal, just a mint-tinted text on a hairline-bg pill.
   The previous gradient + dot + border combo was visually loud. */
.timer-card__status {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 500;
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

/* Big timer: single solid color, generous whitespace above. No
   gradient, no drop-shadow — premium feels like one confident
   statement instead of multiple effects on top of each other. */
.timer-card__clock {
  display: block;
  margin-top: 56rpx;
  font-size: 104rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
  text-align: center;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  color: #155946;
}

.timer-card__hint {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  opacity: 0.85;
}

.timer-card__primary {
  margin-top: 38rpx;
}

.timer-card__actions {
  display: flex;
  gap: 16rpx;
  margin-top: 36rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

.goal-card {
  padding: 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: 0 8rpx 28rpx rgba(46, 169, 133, 0.06);
}

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  margin-top: 22rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
}

.goal-card__fill {
  height: 100%;
  border-radius: inherit;
  background: var(--mint-500);
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.goal-card__fill.is-reached {
  background: var(--mint-600);
}

.goal-card__hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
}

.makeup-banner {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 240, 219, 0.85);
  border: 1rpx solid rgba(229, 158, 87, 0.22);
  box-shadow: 0 8rpx 24rpx rgba(229, 158, 87, 0.12);
}

.makeup-banner__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.makeup-banner__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b3f15;
}

.makeup-banner__sub {
  font-size: 22rpx;
  color: #8a5a2b;
  line-height: 1.5;
}

.makeup-banner__btn {
  flex-shrink: 0;
  min-height: 64rpx;
  height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  background: linear-gradient(180deg, #ec9a36 0%, #d97a23 100%);
  box-shadow: 0 6rpx 16rpx rgba(229, 137, 50, 0.22);
}

.weekly-card {
  padding: 32rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow: 0 8rpx 28rpx rgba(46, 169, 133, 0.06);
}

.weekly-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.weekly-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weekly-card__title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
}

.weekly-card__range {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.weekly-card__total {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.weekly-card__change {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.weekly-card__change--up {
  color: var(--mint-600);
}

.weekly-card__change--down {
  color: #c2654a;
}

.weekly-card__change--flat {
  color: var(--text-sub);
}

.weekly-card__bars {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
  align-items: end;
  margin-top: 24rpx;
}

.weekly-card__bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.weekly-card__bar-track {
  width: 24rpx;
  height: 90rpx;
  border-radius: 6rpx;
  background: rgba(46, 169, 133, 0.06);
  overflow: hidden;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.weekly-card__bar-fill {
  width: 100%;
  min-height: 0;
  background: var(--mint-400);
  border-top-left-radius: 4rpx;
  border-top-right-radius: 4rpx;
  transition: height 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.weekly-card__bar.is-today .weekly-card__bar-fill {
  background: var(--mint-600);
}

.weekly-card__bar.is-today .weekly-card__bar-label {
  color: var(--mint-600);
  font-weight: 700;
}

.weekly-card__bar.is-future .weekly-card__bar-track {
  opacity: 0.5;
}

.weekly-card__bar-label {
  font-size: 20rpx;
  color: var(--text-sub);
  line-height: 1;
  font-weight: 500;
}

.weekly-card__rows {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(46, 169, 133, 0.1);
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.weekly-card__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
}

.weekly-card__row-label {
  color: var(--text-sub);
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.weekly-card__row-value {
  flex: 1;
  text-align: right;
  font-weight: 500;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
}

.home-version {
  display: block;
  margin: 14rpx auto 0;
  text-align: center;
  font-size: 18rpx;
  color: rgba(94, 125, 117, 0.5);
  letter-spacing: 1rpx;
}
