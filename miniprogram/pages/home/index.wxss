.home-page {
  display: flex;
  flex-direction: column;
  /* v0.21: tightened from 24rpx — same number of cards but less air
     between them lets more fit in a viewport without scroll. */
  gap: 18rpx;
  transition: padding 0.32s cubic-bezier(0.2, 0.8, 0.3, 1);
}

/* ============================================================
   v0.22 — Focus mode. When `is-focus-mode` is on, the page-shell
   collapses to a single tall card filling the viewport: the timer
   becomes the page. Other sections (exam-hero, makeup, goal-card,
   subjects-card) are already wx:if'd off, so this just stretches
   what remains. Tabbar is hidden via wx.hideTabBar from TS so the
   bottom region is the user's button bar, not a 4-icon dock.
   ============================================================ */
.home-page.is-focus-mode {
  position: fixed;
  inset: 0;
  padding: 0;
  margin: 0;
  z-index: 50;
  background:
    radial-gradient(circle at 50% 8%, rgba(143, 217, 190, 0.32), transparent 58%),
    linear-gradient(180deg, #ffffff 0%, #ebf7f1 100%);
  /* Centered single-card stack */
  justify-content: stretch;
}

.home-page.is-focus-mode > .timer-card {
  /* The timer-card fills the entire focus-mode viewport. Border /
     shadow stripped since we're already on a tinted page. The card's
     internal flex layout (head row up top + clock centered + actions
     at bottom) handles spacing. */
  flex: 1;
  height: 100vh;
  border-radius: 0;
  border: none;
  box-shadow: none;
  background: transparent;
  padding: 100rpx 56rpx 56rpx;
  display: flex;
  flex-direction: column;
}

.home-page.is-focus-mode .timer-card__clock {
  /* Hero clock grows from 96rpx to 180rpx — the single most important
     piece of information on the screen during a session. */
  font-size: 180rpx;
  margin-top: auto;
  margin-bottom: auto;
  /* v0.23 — slow breathing glow. 4-second cycle (calm-breath cadence,
     not anxious). Only animates when the session is running, not
     paused — see the .timer-card__status.is-running guard below.
     Pure opacity transform; CPU/GPU cost negligible. */
  animation: focus-clock-breathe 4s ease-in-out infinite;
}

/* Stop the breathing animation when the session is paused so the
   stillness reads as "you stepped away." `.timer-card.is-paused`
   is bound from the wxml — see the class string in the template.
   (We can't use CSS :has() because WeChat's CSS engine doesn't
   support it reliably across older base library versions.) */
.home-page.is-focus-mode .timer-card.is-paused .timer-card__clock {
  animation: none;
  opacity: 0.7;
}

@keyframes focus-clock-breathe {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%      { opacity: 0.86; transform: scale(0.985); }
}

.home-page.is-focus-mode .timer-card__hint {
  display: none;
}

.home-page.is-focus-mode .timer-card__meta {
  /* In focus mode the meta row sits compact at the top, no values
     compete with the clock for the eye. */
  font-size: 22rpx;
}

.home-page.is-focus-mode .timer-card__actions {
  /* Buttons bunched at the bottom; pause shrinks to a ghost so the
     primary "结束" reads as the only obvious action. */
  margin-top: auto;
  padding-top: 40rpx;
}

.home-page.is-focus-mode .timer-card__cycles {
  /* Pomodoro dots (legacy live sessions only) — kept small */
  justify-content: center;
}

/* Staggered fade-up entrance for the major sections so the page
   composes itself top-down rather than appearing all at once.
   `backwards` keeps each child invisible during its delay window. */
@keyframes home-fade-up {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.home-page > view {
  animation: home-fade-up 0.45s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
}

/* v0.21 density: tightened stagger so the page composes faster
   (0.04→0.02 first, then 0.05 increments instead of 0.06). */
.home-page > view:nth-child(1) { animation-delay: 0.02s; }
.home-page > view:nth-child(2) { animation-delay: 0.07s; }
.home-page > view:nth-child(3) { animation-delay: 0.12s; }
.home-page > view:nth-child(4) { animation-delay: 0.17s; }
.home-page > view:nth-child(5) { animation-delay: 0.22s; }
.home-page > view:nth-child(6) { animation-delay: 0.27s; }

/* v0.21.3 — .picker-card / .picker-chip styles removed along with the
   home-page subject picker. Subject is now chosen on the complete
   page (post-session). The `.timer-card__subject-pill` below is
   still used to surface the picked subject on a running session's
   meta row when present on the server record. */

/* Subject pill that appears in timer card meta when running. */
.timer-card__subject-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  color: var(--mint-600);
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  margin-right: 8rpx;
}

/* Sibling pill showing the active ambient scene (e.g. "🌧️ 雨声").
   Same shape as the subject pill but blue palette so the two
   coexist visually without competing. */
.timer-card__audio-pill {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(74, 110, 217, 0.1);
  color: #4a6ed9;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.4rpx;
  margin-right: 8rpx;
}

/* Pomodoro cycle dots — sit just below the clock. */
.timer-card__cycles {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.timer-card__cycle-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: rgba(46, 169, 133, 0.16);
  transition: all 0.32s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.timer-card__cycle-dot.is-done {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  box-shadow: 0 2rpx 8rpx rgba(46, 169, 133, 0.3);
  transform: scale(1.1);
}

.timer-card__cycle-extra {
  margin-left: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--mint-600);
  font-feature-settings: "tnum" 1;
}

/* Pomodoro mode overlay: subtle tomato hue so the active state is
   visually distinct from the free-timer mode. */
.timer-card.is-pomodoro {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 159, 90, 0.16), transparent 45%),
    radial-gradient(circle at 0% 100%, rgba(94, 195, 157, 0.12), transparent 45%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border-color: rgba(229, 122, 50, 0.18);
}

/* ============================================================
   Exam-hero — prominent countdown card. v0.18.1 upgrade from
   the v0.13 slim-pill. Big number on the right, subject + date
   on the left, motivation line at the bottom. Four urgency
   tiers still drive the palette + a gentle pulse on the day
   badge for ≤30 days.
   ============================================================ */
.exam-hero {
  display: flex;
  align-items: center;
  /* v0.21 density: 24→18 / 28×30→22×24 */
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.22), transparent 45%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 12rpx 32rpx -6rpx rgba(46, 169, 133, 0.14);
}

.exam-hero__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.exam-hero__eyebrow {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1.5rpx;
  color: #1d6f59;
  text-transform: uppercase;
  opacity: 0.85;
}

.exam-hero__subject {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  font-feature-settings: "tnum" 1;
}

.exam-hero__motivation {
  margin-top: 4rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.exam-hero__count {
  flex-shrink: 0;
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  /* v0.21 density: 18×24→14×20 */
  padding: 14rpx 20rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(99, 203, 168, 0.18) 0%, rgba(46, 169, 133, 0.22) 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.28);
}

.exam-hero__count-num {
  /* v0.21 density: 84→72 — still readable as the hero number */
  font-size: 72rpx;
  font-weight: 800;
  color: #155946;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.4rpx;
  line-height: 0.95;
}

.exam-hero__count-unit {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d6f59;
  letter-spacing: 0.6rpx;
}

/* Urgency tiers — calm (default mint), soon (≤90, amber),
   urgent (≤30, orange + pulse), imminent (≤7, red + faster pulse). */
.exam-hero--soon {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.28), transparent 50%),
    linear-gradient(180deg, #fff8ec 0%, #ffefcf 100%);
  border-color: rgba(229, 158, 87, 0.32);
}
.exam-hero--soon .exam-hero__eyebrow { color: #8a4d10; }
.exam-hero--soon .exam-hero__count {
  background: linear-gradient(135deg, rgba(255, 207, 138, 0.32) 0%, rgba(229, 158, 87, 0.32) 100%);
  border-color: rgba(229, 158, 87, 0.4);
}
.exam-hero--soon .exam-hero__count-num,
.exam-hero--soon .exam-hero__count-unit { color: #7a3f0a; }

.exam-hero--urgent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 168, 107, 0.32), transparent 50%),
    linear-gradient(180deg, #fff3ea 0%, #ffe2cc 100%);
  border-color: rgba(229, 122, 50, 0.32);
}
.exam-hero--urgent .exam-hero__eyebrow { color: #7a330a; }
.exam-hero--urgent .exam-hero__count {
  background: linear-gradient(135deg, rgba(255, 168, 107, 0.34) 0%, rgba(229, 122, 50, 0.32) 100%);
  border-color: rgba(229, 122, 50, 0.4);
  animation: exam-hero-pulse 2.4s ease-in-out infinite;
}
.exam-hero--urgent .exam-hero__count-num,
.exam-hero--urgent .exam-hero__count-unit { color: #6b2906; }

.exam-hero--imminent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 156, 156, 0.36), transparent 50%),
    linear-gradient(180deg, #fff0f0 0%, #ffd9d9 100%);
  border-color: rgba(217, 80, 80, 0.36);
}
.exam-hero--imminent .exam-hero__eyebrow { color: #7a1a1a; }
.exam-hero--imminent .exam-hero__count {
  background: linear-gradient(135deg, rgba(255, 156, 156, 0.34) 0%, rgba(217, 80, 80, 0.32) 100%);
  border-color: rgba(217, 80, 80, 0.42);
  animation: exam-hero-pulse 1.6s ease-in-out infinite;
}
.exam-hero--imminent .exam-hero__count-num,
.exam-hero--imminent .exam-hero__count-unit { color: #6b0e0e; }

@keyframes exam-hero-pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.04); }
}

/* (Quote card + weekly-review removed in v0.9.3 — home is now
   focused on the immediate question "should I start a session now?".
   Heat map / weekly aggregates live in the dedicated tabs.) */

/* Timer is the hero card on this page: more elevation, gentle mesh
   gradient surface, and an ambient glow when a session is running.
   Three shadow layers (inset highlight + small crisp + large soft)
   give the card real "weight" that distinguishes it from secondary
   cards below. */
.timer-card {
  position: relative;
  /* v0.21 density: 40×36→32×30 */
  padding: 32rpx 30rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 92% 8%, rgba(143, 217, 190, 0.28), transparent 48%),
    radial-gradient(circle at 6% 92%, rgba(94, 195, 157, 0.16), transparent 44%),
    linear-gradient(180deg, #ffffff 0%, #f6fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.16);
  overflow: hidden;
  transition: box-shadow 0.4s ease, border-color 0.4s ease;
}

/* Active-session ambient: card edge lights up subtly, ring of mint
   glow extends 8rpx beyond the border like a soft halo. */
.timer-card.is-active {
  border-color: rgba(46, 169, 133, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 1rpx 2rpx rgba(20, 60, 50, 0.04),
    0 24rpx 48rpx -8rpx rgba(46, 169, 133, 0.22),
    0 0 0 8rpx rgba(46, 169, 133, 0.04);
}

.timer-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.timer-card__status-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

/* Status pill: tinted background + optional pulsing dot. The dot is
   a separate element so we can animate just the dot, not the text. */
.timer-card__status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  color: var(--mint-600);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 0.6rpx;
  transition: background 0.3s ease;
}

.timer-card__status.is-running {
  background: rgba(46, 169, 133, 0.14);
}

.timer-card__status.is-paused {
  background: rgba(229, 158, 87, 0.12);
  color: #c2782b;
}

/* Pulsing dot for "专注中". Two concentric rings: inner is the solid
   indicator, outer is a fading halo that breathes. */
.timer-card__status-dot {
  position: relative;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--mint-500);
  flex-shrink: 0;
}

.timer-card__status-dot::after {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: 50%;
  background: var(--mint-500);
  opacity: 0.4;
  animation: pulse-ring 1.6s cubic-bezier(0.4, 0, 0.2, 1) infinite;
}

@keyframes pulse-ring {
  0% { transform: scale(0.6); opacity: 0.5; }
  80%, 100% { transform: scale(1.6); opacity: 0; }
}

.timer-card__status-text {
  display: inline-block;
}

.timer-card__pause-hint {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.timer-card__streak {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

/* Subtle flame flicker — scale + rotation jitter under 3% so it
   reads as "alive" without yelling for attention. */
.timer-card__flame {
  display: inline-block;
  font-size: 22rpx;
  transform-origin: 50% 80%;
  animation: flame-flicker 1.6s ease-in-out infinite;
}

@keyframes flame-flicker {
  0%, 100% { transform: scale(1) rotate(0deg); }
  25% { transform: scale(1.04) rotate(-3deg); }
  50% { transform: scale(0.98) rotate(2deg); }
  75% { transform: scale(1.02) rotate(-1deg); }
}

.timer-card__meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: var(--text-sub);
  font-size: 22rpx;
  font-weight: 500;
  font-feature-settings: "tnum" 1;
  letter-spacing: 0.3rpx;
}

/* Big timer: subtle vertical gradient gives it a "carved" / metallic
   look without being loud. Solid color fallback so the number stays
   readable on renderers that ignore -webkit-background-clip. */
.timer-card__clock {
  display: block;
  /* v0.21 density: 52→36 / 108→96 — still the page hero, but tighter */
  margin-top: 36rpx;
  font-size: 96rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 1rpx;
  text-align: center;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  color: #155946;
  background: linear-gradient(180deg, #1a624f 0%, #0f4836 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.timer-card__hint {
  display: block;
  /* v0.21 density: 18→14 */
  margin-top: 14rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.5rpx;
  opacity: 0.85;
}

.timer-card__primary {
  /* v0.21 density: 38→26 */
  margin-top: 26rpx;
}

.timer-card__actions {
  display: flex;
  gap: 14rpx;
  /* v0.21 density: 36→26 */
  margin-top: 26rpx;
}

.timer-card__secondary {
  flex: 1;
}

.timer-card__primary {
  width: 100%;
}

/* ============================================================
   v0.18.1 — compact six-subject progress card on home. Six rows of
   "subject · bar · minutes / target". Tap anywhere on the card to
   open the dedicated 六科进度 page.
   ============================================================ */
.subjects-card {
  /* v0.21 density: 24×28×22→18×24×18 */
  padding: 18rpx 24rpx 18rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.16), transparent 42%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.1);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.75),
    0 8rpx 22rpx -4rpx rgba(46, 169, 133, 0.08);
}

.subjects-card__head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  /* v0.21 density: 14→10 */
  margin-bottom: 10rpx;
}

.subjects-card__title {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.subjects-card__hint {
  font-size: 22rpx;
  color: var(--mint-600);
  letter-spacing: 0.2rpx;
  font-weight: 600;
}

.subjects-card__grid {
  display: flex;
  flex-direction: column;
  /* v0.21 density: 10→8 */
  gap: 8rpx;
}

.subjects-card__row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.subjects-card__row-label {
  flex-shrink: 0;
  width: 80rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-main);
  letter-spacing: 0.3rpx;
}

.subjects-card__row-track {
  flex: 1;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(20, 60, 50, 0.04);
}

.subjects-card__row-fill {
  height: 100%;
  background: linear-gradient(90deg, #8aa6f0 0%, #4a6ed9 100%);
  border-radius: 999rpx;
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
}

.subjects-card__row-fill.is-reached {
  background: linear-gradient(90deg, #63cba8 0%, #2ea985 100%);
}

.subjects-card__row-value {
  flex-shrink: 0;
  min-width: 140rpx;
  text-align: right;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-sub);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.2rpx;
}

.subjects-card:active {
  transform: scale(0.998);
  transition: transform 0.16s ease;
}

.goal-card {
  position: relative;
  /* v0.21 density: 32→24 top / 32→26 horizontal / 30→22 bottom */
  padding: 24rpx 26rpx 22rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(143, 217, 190, 0.14), transparent 40%),
    linear-gradient(180deg, #ffffff 0%, #f7fcf9 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 1rpx 2rpx rgba(20, 60, 50, 0.03),
    0 12rpx 32rpx -4rpx rgba(46, 169, 133, 0.08);
}

/* v0.22 — daily challenge collapsed into an inline subtitle on
   goal-card. The earlier dedicated chip + progress track ate a full
   row on home; in practice users glance at the goal bar and the
   "挑战 60分" number is enough information to know whether they've
   cleared the soft floor. Done state turns mint, otherwise a quiet
   sub-text styling that doesn't compete with the goal value.
   The big chip + sub progress track block was deleted. */
.goal-card__challenge-inline {
  display: inline-block;
  margin-left: 10rpx;
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--mint-600);
  background: rgba(46, 169, 133, 0.1);
  letter-spacing: 0.3rpx;
  font-feature-settings: "tnum" 1;
}

.goal-card__challenge-inline.is-done {
  color: #fff;
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
}

.goal-card__challenge-inline:active {
  opacity: 0.85;
}

/* v0.22 note: the dedicated challenge chip (.goal-card__challenge,
   its head/emoji/label/target/track/fill children) was removed when
   the challenge collapsed into the inline pill above. Search the git
   history at tag v0.21.x for the previous styling. */

.goal-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.goal-card__title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.goal-card__title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
}

.goal-card__sub {
  font-size: 22rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__value {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.3rpx;
}

.goal-card__value.is-reached {
  color: var(--mint-600);
}

.goal-card__track {
  position: relative;
  /* v0.21 density: 22→16 / 14→12 */
  margin-top: 16rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.08);
  overflow: hidden;
  box-shadow: inset 0 1rpx 2rpx rgba(20, 60, 50, 0.06);
}

/* Subtle gradient fill + inset top highlight gives the bar
   "carved" depth without being shiny. */
.goal-card__fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(180deg, #4dbe96 0%, #228168 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.32);
  transform-origin: left center;
  transition: width 0.5s cubic-bezier(0.2, 0.7, 0.2, 1);
  animation: progress-grow 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) backwards;
  animation-delay: 0.3s;
}

@keyframes progress-grow {
  from { transform: scaleX(0); }
  to { transform: scaleX(1); }
}

.goal-card__fill.is-reached {
  background: linear-gradient(180deg, #2ea985 0%, #155946 100%);
}

.goal-card__hint {
  display: block;
  /* v0.21 density: 14→10 */
  margin-top: 10rpx;
  font-size: 22rpx;
  color: var(--mint-600);
  font-weight: 600;
}

/* Weekly progress row — sits under the daily bar in the same card.
   Visually quieter (thinner track, smaller text) so the daily metric
   stays the primary focus. */
.goal-card__weekly {
  /* v0.21 density: 18→14 / 16→12 */
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(46, 169, 133, 0.16);
}

.goal-card__weekly-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.goal-card__weekly-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
}

.goal-card__weekly-value {
  font-size: 22rpx;
  font-weight: 700;
  color: var(--text-main);
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.2rpx;
}

.goal-card__weekly-value.is-reached {
  color: var(--mint-600);
}

.goal-card__weekly-track {
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(46, 169, 133, 0.1);
  overflow: hidden;
}

.goal-card__weekly-fill {
  height: 100%;
  background: linear-gradient(90deg, #8aa6f0 0%, #4a6ed9 100%);
  border-radius: 999rpx;
  transition: width 0.42s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.goal-card__weekly-fill.is-reached {
  background: linear-gradient(90deg, #63cba8 0%, #2ea985 100%);
}

.makeup-banner {
  position: relative;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 207, 138, 0.22), transparent 40%),
    linear-gradient(180deg, rgba(255, 244, 224, 0.94) 0%, rgba(255, 233, 198, 0.92) 100%);
  border: 1rpx solid rgba(229, 158, 87, 0.26);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.7),
    0 12rpx 32rpx -4rpx rgba(229, 158, 87, 0.16);
}

.makeup-banner__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.makeup-banner__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #6b3f15;
}

.makeup-banner__sub {
  font-size: 22rpx;
  color: #8a5a2b;
  line-height: 1.5;
}

.makeup-banner__btn {
  flex-shrink: 0;
  min-height: 68rpx;
  height: 68rpx;
  padding: 0 26rpx;
  font-size: 24rpx;
  background: linear-gradient(180deg, #ec9a36 0%, #d97a23 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.32),
    0 10rpx 22rpx rgba(229, 137, 50, 0.28);
}

/* .home-version removed in v0.13 — version label no longer rendered
   on the home page (still in 我的 footer for diagnostic purposes). */
