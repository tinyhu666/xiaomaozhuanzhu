/* v0.30 — full WXSS rewrite per docs/design-handoff/screen-complete.jsx.
   The hero uses tokenized fs/colors directly (was the cause of the
   "字体大小比例完全失调" the user flagged in v0.29.1).

   Layout uses the new v2 utility classes from app.wxss:
   .page-pad / .card-v2 / .chip-v2 / .btn-v2 / .micro / .caption / .num
   — so this file only owns page-specific composition + the sticky
   submit bar + the unlock-reveal overlay (preserved from v0.25).
*/

.complete-page {
  min-height: 100vh;
  background: var(--c-bg-light);
  /* Leave space at the bottom equal to the sticky submit bar so the
     last chip row + textarea aren't covered. */
  padding-bottom: calc(env(safe-area-inset-bottom) + 180rpx);
  box-sizing: border-box;
}

.complete-scroll {
  display: flex;
  flex-direction: column;
}

/* -------- Hero (no card chrome, full-bleed text) -------- */

.complete-hero {
  padding-top: 28rpx;
  padding-bottom: 36rpx;
}

.complete-hero__eyebrow {
  display: block;
  margin-bottom: 12rpx;
}

.complete-hero__row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.complete-hero__num {
  /* design: 48px ≈ 96rpx, weight 800, primary color, tight letter-spacing.
     Bounded check (§1D): up to 4 digits × 0.6em × 96rpx = 230rpx — well
     within page-pad (750rpx − 56rpx = ~694rpx). */
  font-size: 96rpx;
  font-weight: 800;
  line-height: 1;
  color: var(--c-primary);
  letter-spacing: -2rpx;
}

.complete-hero__unit {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--c-text-2);
}

.complete-hero__pomo {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 18rpx;
  padding: 6rpx 18rpx;
  background: rgba(255, 184, 107, 0.18);
  color: #b3551a;
  border-radius: 999rpx;
  font-size: var(--fs-caption);
  font-weight: 600;
  line-height: 1.4;
}

.complete-hero__pomo-icon {
  /* v0.30.2 — line-height unified with the label (was 1 vs 1.4),
     because mismatched line-heights inside align-items:center caused
     the 🍅 to sit a hair higher than the CJK label. Same logic as
     ui-review-checklist §1A's vertical-align note. */
  font-size: 24rpx;
  line-height: 1.4;
}

.complete-hero__pomo-text {
  /* No emoji baseline drift — emoji is in its own <text> per §1A. */
  font-size: 24rpx;
  line-height: 1.4;
}

/* -------- Section (label + content) -------- */

.complete-section {
  padding-top: 0;
  padding-bottom: 36rpx;
}

.complete-section__label {
  display: block;
  margin-bottom: 16rpx;
}

/* -------- Photos grid (3-col) -------- */

.complete-photos {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.complete-photo {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20rpx;
  overflow: hidden;
  background: var(--c-soft-mint);
}

.complete-photo__img {
  display: block;
  width: 100%;
  height: 100%;
}

.complete-photo__remove {
  /* v0.30.2 — was width/height 40rpx (≈20pt), well below the 44pt
     tap-target floor and frequently missed. Enlarged the hit area to
     64rpx (32pt) and pulled it half-outside the photo so the visible
     disc still reads as a corner badge but the touch area is generous.
     The inner disc remains visually compact via the inset background. */
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 64rpx;
  text-align: center;
  /* Subtle ring so the disc doesn't blend into dark photos. */
  box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.6);
}

.complete-photo__remove:active {
  background: rgba(0, 0, 0, 0.75);
}

.complete-photo-add {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 20rpx;
  border: 2rpx dashed var(--c-stroke);
  background: transparent;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: var(--c-text-3);
  /* v0.30.2 — was var(--d-fast) which is not a defined motion token in
     app.wxss, killing the entire transition shorthand. The project's
     press-feedback duration token is --d-1 (100ms). */
  transition: transform var(--d-1) var(--ease-std), background var(--d-1) var(--ease-std);
}

.complete-photo-add:active {
  transform: scale(0.97);
  background: var(--c-soft-mint);
}

.complete-photo-add__icon {
  font-size: 36rpx;
  line-height: 1;
  font-weight: 300;
}

.complete-photo-add__label {
  font-size: 22rpx;
  line-height: 1.4;
}

.complete-photo-spacer {
  /* Reserve a 3rd cell when the user has 0 photos so the add tile
     sits in column 1 and the grid doesn't collapse to a giant centered
     tile. */
  width: 100%;
  aspect-ratio: 1 / 1;
}

/* -------- Summary card (textarea + counter) -------- */

.complete-summary {
  padding: 18rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.complete-summary__input {
  display: block;
  width: 100%;
  min-height: 88rpx;
  border: 0;
  outline: none;
  background: transparent;
  font-size: var(--fs-body);
  line-height: 1.5;
  color: var(--c-text-1);
  box-sizing: border-box;
}

.complete-summary__counter {
  display: flex;
  justify-content: flex-end;
}

/* -------- Chip row -------- */

.complete-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* -------- Sticky submit bar -------- */

.complete-bottom-spacer {
  height: 20rpx;
}

.complete-submit {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 28rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: linear-gradient(to top, var(--c-bg-light) 60%, rgba(243, 250, 246, 0));
  z-index: 50;
  pointer-events: none;
}

.complete-submit__btn {
  width: 100%;
  pointer-events: auto;
}

/* -------- Dark mode: complete page surfaces -------- */

@media (prefers-color-scheme: dark) {
  .complete-page {
    background: var(--c-bg-dark);
  }
  .complete-hero__num {
    /* In dark mode the deep --c-primary disappears; --c-accent (mint)
       is the project's designated dark-mode primary substitute. */
    color: var(--c-accent);
  }
  .complete-hero__unit {
    color: var(--c-text-2-dark);
  }
  /* v0.30.2 — .micro defaults to --c-text-2 (#5E7D75) which on the
     dark page bg sits at ~4.4:1, barely passing AA. Force the
     dark-mode token for legibility. Same for any caption labels we
     render directly on the page bg. */
  .complete-hero__eyebrow,
  .complete-section__label {
    color: var(--c-text-2-dark);
  }
  .complete-hero__pomo {
    background: rgba(255, 184, 107, 0.16);
    color: #f6c894;
  }
  .complete-photo {
    background: rgba(255, 255, 255, 0.05);
  }
  .complete-photo-add {
    border-color: rgba(255, 255, 255, 0.18);
    color: var(--c-text-2-dark);
  }
  .complete-photo__remove {
    box-shadow: 0 0 0 2rpx rgba(255, 255, 255, 0.4);
  }
  .complete-summary__input {
    color: var(--c-text-1-dark);
  }
  .complete-submit {
    background: linear-gradient(to top, var(--c-bg-dark) 60%, rgba(15, 26, 23, 0));
  }
}

/* ============================================================
   v0.25 — Achievement-unlock overlay (preserved verbatim).
   This block was already aligned with the new design language
   (rarity-tiered card with halo + animations) and the user has
   not flagged any issue with it. Don't touch.
   ============================================================ */
@keyframes unlock-reveal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes unlock-reveal-pop {
  0%   { opacity: 0; transform: scale(0.7) translateY(40rpx); }
  60%  { transform: scale(1.04) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes unlock-img-bounce {
  from { transform: scale(0.3) rotate(-12deg); opacity: 0; }
  60%  { transform: scale(1.15) rotate(4deg); opacity: 1; }
  to   { transform: scale(1) rotate(0); opacity: 1; }
}

@keyframes unlock-halo-pulse {
  0%   { transform: scale(0.6); opacity: 0; }
  40%  { opacity: 0.5; }
  100% { transform: scale(1.6); opacity: 0; }
}

.unlock-reveal {
  position: fixed;
  inset: 0;
  z-index: 230;
  background: rgba(20, 60, 50, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: unlock-reveal-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.unlock-reveal__card {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  padding: 52rpx 36rpx 36rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  animation: unlock-reveal-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.4), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(46, 169, 133, 0.32);
}

.unlock-reveal__card--rare {
  background:
    radial-gradient(circle at 50% 0%, rgba(138, 166, 240, 0.36), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #eef3ff 100%);
  border-color: rgba(74, 110, 217, 0.3);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(74, 110, 217, 0.32);
}

.unlock-reveal__card--epic {
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 107, 0.4), transparent 60%),
    linear-gradient(180deg, #fffaf0 0%, #ffe6c0 100%);
  border-color: rgba(229, 123, 43, 0.34);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(229, 123, 43, 0.34);
}

.unlock-reveal__card--legendary {
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 216, 107, 0.55), transparent 60%),
    linear-gradient(180deg, #fffaeb 0%, #ffe79b 100%);
  border-color: rgba(240, 169, 59, 0.5);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 24rpx 60rpx -8rpx rgba(240, 169, 59, 0.45);
}

.unlock-reveal__halo {
  position: absolute;
  top: 150rpx;
  left: 50%;
  margin-left: -120rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(46, 169, 133, 0.18);
  filter: blur(10rpx);
  animation: unlock-halo-pulse 2s ease-out infinite;
  pointer-events: none;
}

.unlock-reveal__card--rare .unlock-reveal__halo      { background: rgba(74, 110, 217, 0.2); }
.unlock-reveal__card--epic .unlock-reveal__halo      { background: rgba(229, 123, 43, 0.28); }
.unlock-reveal__card--legendary .unlock-reveal__halo { background: rgba(240, 169, 59, 0.36); }

.unlock-reveal__eyebrow {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: var(--c-primary);
  margin-bottom: 14rpx;
  z-index: 1;
}

.unlock-reveal__cat-img {
  width: 220rpx;
  height: 220rpx;
  animation: unlock-img-bounce 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) 0.2s backwards;
  z-index: 1;
}

.unlock-reveal__emoji {
  font-size: 180rpx;
  line-height: 1;
  animation: unlock-img-bounce 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) 0.2s backwards;
  z-index: 1;
}

.unlock-reveal__crown,
.unlock-reveal__star {
  position: absolute;
  top: 130rpx;
  right: 30%;
  font-size: 56rpx;
  line-height: 1;
  filter: drop-shadow(0 2rpx 6rpx rgba(0, 0, 0, 0.18));
  animation: unlock-img-bounce 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) 0.5s backwards;
  z-index: 2;
}

.unlock-reveal__star {
  font-size: 44rpx;
}

.unlock-reveal__name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--c-text-1);
  letter-spacing: 0.4rpx;
  margin-top: 12rpx;
}

.unlock-reveal__rarity {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.6rpx;
  margin-top: 4rpx;
  z-index: 1;
}

.unlock-reveal__rarity--common    { background: rgba(94, 125, 117, 0.16); color: var(--c-text-1); }
.unlock-reveal__rarity--rare      { background: rgba(74, 110, 217, 0.18); color: #3a4a92; }
.unlock-reveal__rarity--epic      { background: rgba(229, 123, 43, 0.2); color: #7a3f0a; }
.unlock-reveal__rarity--legendary { background: rgba(240, 169, 59, 0.3); color: #6b4108; }

.unlock-reveal__cond {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--c-text-2);
  letter-spacing: 0.3rpx;
  text-align: center;
  line-height: 1.4;
}

.unlock-reveal__actions {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
  width: 100%;
}

.unlock-reveal__ghost,
.unlock-reveal__primary {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  transition: transform 0.16s ease;
}

.unlock-reveal__ghost {
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(46, 169, 133, 0.22);
  color: var(--c-primary);
}

.unlock-reveal__primary {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(46, 169, 133, 0.28);
}

.unlock-reveal__ghost:active,
.unlock-reveal__primary:active {
  transform: scale(0.96);
}
