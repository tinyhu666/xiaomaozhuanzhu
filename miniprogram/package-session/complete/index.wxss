.page-shell {
  padding: 28rpx 28rpx 56rpx;
}

.photo-grid {
  margin-top: 18rpx;
}

.textarea-input {
  display: block;
  margin-top: 4rpx;
}

.cta-button {
  width: 100%;
  box-sizing: border-box;
}

/* v0.21.3 — subject is back as a tag-chip selector here. The
   shared `.tag-list` + `.tag-chip` styles (declared globally in
   app.wxss) handle layout + active-state visuals, so this file
   doesn't need any subject-specific selectors. */

/* ============================================================
   v0.25 — Achievement-unlock overlay. Replaces the v0.18-v0.24
   per-session cat-reveal modal (which fired on every submit and
   felt repetitive). Now this only appears when the just-completed
   session actually crossed an achievement threshold (server sets
   `newlyUnlockedBadge` on the response). Renders the breed's SVG,
   name, unlock condition, and rarity. Visual treatment leans
   harder on the rarity tier than the old cat-reveal because each
   appearance here is genuinely earned.
   ============================================================ */
@keyframes unlock-reveal-fade {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes unlock-reveal-pop {
  0%   { opacity: 0; transform: scale(0.7) translateY(40rpx); }
  60%  { transform: scale(1.04) translateY(0); }
  100% { opacity: 1; transform: scale(1) translateY(0); }
}

@keyframes unlock-img-bounce {
  from { transform: scale(0.3) rotate(-12deg); opacity: 0; }
  60%  { transform: scale(1.15) rotate(4deg); opacity: 1; }
  to   { transform: scale(1) rotate(0); opacity: 1; }
}

@keyframes unlock-halo-pulse {
  0%   { transform: scale(0.6); opacity: 0; }
  40%  { opacity: 0.5; }
  100% { transform: scale(1.6); opacity: 0; }
}

.unlock-reveal {
  position: fixed;
  inset: 0;
  z-index: 230;
  background: rgba(20, 60, 50, 0.65);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  animation: unlock-reveal-fade 0.28s cubic-bezier(0.2, 0.8, 0.3, 1);
}

.unlock-reveal__card {
  position: relative;
  width: 100%;
  max-width: 600rpx;
  padding: 52rpx 36rpx 36rpx;
  border-radius: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  animation: unlock-reveal-pop 0.5s cubic-bezier(0.2, 0.8, 0.3, 1);
  background:
    radial-gradient(circle at 50% 0%, rgba(143, 217, 190, 0.4), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #f3faf6 100%);
  border: 1rpx solid rgba(46, 169, 133, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(46, 169, 133, 0.32);
}

.unlock-reveal__card--rare {
  background:
    radial-gradient(circle at 50% 0%, rgba(138, 166, 240, 0.36), transparent 60%),
    linear-gradient(180deg, #ffffff 0%, #eef3ff 100%);
  border-color: rgba(74, 110, 217, 0.3);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(74, 110, 217, 0.32);
}

.unlock-reveal__card--epic {
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 184, 107, 0.4), transparent 60%),
    linear-gradient(180deg, #fffaf0 0%, #ffe6c0 100%);
  border-color: rgba(229, 123, 43, 0.34);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85),
    0 24rpx 60rpx -8rpx rgba(229, 123, 43, 0.34);
}

.unlock-reveal__card--legendary {
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 216, 107, 0.55), transparent 60%),
    linear-gradient(180deg, #fffaeb 0%, #ffe79b 100%);
  border-color: rgba(240, 169, 59, 0.5);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9),
    0 24rpx 60rpx -8rpx rgba(240, 169, 59, 0.45);
}

.unlock-reveal__halo {
  position: absolute;
  top: 150rpx;
  left: 50%;
  margin-left: -120rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(46, 169, 133, 0.18);
  filter: blur(10rpx);
  animation: unlock-halo-pulse 2s ease-out infinite;
  pointer-events: none;
}

.unlock-reveal__card--rare .unlock-reveal__halo      { background: rgba(74, 110, 217, 0.2); }
.unlock-reveal__card--epic .unlock-reveal__halo      { background: rgba(229, 123, 43, 0.28); }
.unlock-reveal__card--legendary .unlock-reveal__halo { background: rgba(240, 169, 59, 0.36); }

.unlock-reveal__eyebrow {
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: var(--mint-600);
  margin-bottom: 14rpx;
  z-index: 1;
}

.unlock-reveal__cat-img {
  width: 220rpx;
  height: 220rpx;
  animation: unlock-img-bounce 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) 0.2s backwards;
  z-index: 1;
}

.unlock-reveal__emoji {
  font-size: 180rpx;
  line-height: 1;
  animation: unlock-img-bounce 0.7s cubic-bezier(0.2, 0.8, 0.3, 1) 0.2s backwards;
  z-index: 1;
}

.unlock-reveal__crown,
.unlock-reveal__star {
  position: absolute;
  top: 130rpx;
  right: 30%;
  font-size: 56rpx;
  line-height: 1;
  filter: drop-shadow(0 2rpx 6rpx rgba(0, 0, 0, 0.18));
  animation: unlock-img-bounce 0.6s cubic-bezier(0.2, 0.8, 0.3, 1) 0.5s backwards;
  z-index: 2;
}

.unlock-reveal__star {
  font-size: 44rpx;
}

.unlock-reveal__name {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--text-main);
  letter-spacing: 0.4rpx;
  margin-top: 12rpx;
}

.unlock-reveal__rarity {
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 0.6rpx;
  margin-top: 4rpx;
  z-index: 1;
}

.unlock-reveal__rarity--common    { background: rgba(94, 125, 117, 0.16); color: var(--text-main); }
.unlock-reveal__rarity--rare      { background: rgba(74, 110, 217, 0.18); color: #3a4a92; }
.unlock-reveal__rarity--epic      { background: rgba(229, 123, 43, 0.2); color: #7a3f0a; }
.unlock-reveal__rarity--legendary { background: rgba(240, 169, 59, 0.3); color: #6b4108; }

.unlock-reveal__cond {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: var(--text-sub);
  letter-spacing: 0.3rpx;
  text-align: center;
  line-height: 1.4;
}

.unlock-reveal__actions {
  display: flex;
  gap: 14rpx;
  margin-top: 30rpx;
  width: 100%;
}

.unlock-reveal__ghost,
.unlock-reveal__primary {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  transition: transform 0.16s ease;
}

.unlock-reveal__ghost {
  background: rgba(255, 255, 255, 0.6);
  border: 1rpx solid rgba(46, 169, 133, 0.22);
  color: var(--mint-600);
}

.unlock-reveal__primary {
  background: linear-gradient(135deg, #63cba8 0%, #2ea985 100%);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(46, 169, 133, 0.28);
}

.unlock-reveal__ghost:active,
.unlock-reveal__primary:active {
  transform: scale(0.96);
}

/* GPT image2 redesign pass */
.complete-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: calc(56rpx + env(safe-area-inset-bottom));
}

.complete-hero,
.complete-form {
  border-radius: 24rpx;
  background: #FFFFFF;
  border: 1rpx solid #D2E1DA;
  box-shadow: 0 2rpx 8rpx rgba(20, 60, 50, 0.04);
}

.complete-hero {
  padding: 32rpx;
}

.complete-hero__label {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #ECF5F0;
  color: #155946;
  font-size: 22rpx;
  font-weight: 600;
}

.complete-hero__title {
  display: block;
  margin-top: 24rpx;
  color: #155946;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.12;
  letter-spacing: 0;
}

.complete-hero__pill {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  margin-top: 16rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #FFF3EA;
  color: #C2562B;
  font-size: 22rpx;
  font-weight: 600;
}

.complete-form {
  padding: 24rpx;
}

.complete-form .field-label {
  margin-top: 24rpx;
  margin-bottom: 16rpx;
}

.complete-form .field-label:first-child {
  margin-top: 0;
}

.field-label--spaced {
  margin-top: 24rpx;
}

.complete-submit {
  width: 100%;
}

.unlock-reveal {
  background: rgba(20, 60, 50, 0.55);
}

.unlock-reveal__card,
.unlock-reveal__card--rare,
.unlock-reveal__card--epic,
.unlock-reveal__card--legendary {
  border-radius: 32rpx;
  background: #FFFFFF;
  border: 1rpx solid #D2E1DA;
  box-shadow: 0 24rpx 60rpx -8rpx rgba(20, 60, 50, 0.16);
  animation: unlock-reveal-pop-calm 600ms cubic-bezier(0.2, 0.8, 0.3, 1);
}

@keyframes unlock-reveal-pop-calm {
  from { opacity: 0; transform: scale(0.96) translateY(24rpx); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.unlock-reveal__eyebrow {
  color: #155946;
  letter-spacing: 0;
}

.unlock-reveal__name {
  color: #1F2624;
  font-size: 40rpx;
}

.unlock-reveal__crown,
.unlock-reveal__star {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: #F7E8C5;
  color: #C9881C;
  font-size: 22rpx;
  font-weight: 800;
  filter: none;
}

.unlock-reveal__ghost,
.unlock-reveal__primary {
  border-radius: 16rpx;
}

.unlock-reveal__primary {
  background: #155946;
  box-shadow: none;
}

.unlock-reveal__ghost {
  background: transparent;
  border: 2rpx solid #155946;
  color: #155946;
}

/* Second polish pass — completion as a calm handoff, not a form stack. */
.complete-page {
  gap: 28rpx;
}

.complete-hero {
  position: relative;
  overflow: hidden;
  border-radius: 30rpx;
}

.complete-hero::after {
  content: "";
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: linear-gradient(90deg, rgba(21, 89, 70, 0), rgba(21, 89, 70, 0.18), rgba(21, 89, 70, 0));
}

.complete-hero__title {
  text-shadow: 0 14rpx 34rpx rgba(21, 89, 70, 0.10);
}

.complete-form {
  border-radius: 28rpx;
}

.photo-item,
.photo-picker {
  background: linear-gradient(180deg, #F5FBF8 0%, #EAF4EF 100%);
  border-color: rgba(21, 89, 70, 0.12);
}

.complete-submit {
  box-shadow: 0 18rpx 34rpx -24rpx rgba(21, 89, 70, 0.68);
}

.unlock-reveal__halo {
  opacity: 0.24;
}

.unlock-reveal__card,
.unlock-reveal__card--rare,
.unlock-reveal__card--epic,
.unlock-reveal__card--legendary {
  background: linear-gradient(180deg, #FFFFFF 0%, #F8FCFA 100%);
}
