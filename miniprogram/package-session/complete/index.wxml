<!--
  v0.30 — full structural rewrite per docs/design-handoff/screen-complete.jsx.
  Previous version was the v0.21.3 hero-card / surface-card layout still
  on the old token names (--mint-600 / --text-main). Result on device:
  the hero "这次专注了 52 分钟" rendered with the wrong font scale because
  .title used a generic size while the design wants a huge dedicated
  number + tiny unit.

  Structure:
  - hero (no card chrome): micro label → big number + 分钟 + pomodoro chip
  - photo grid (3-col): existing photos + add tile (dashed) + spacer
  - summary section: micro label + .card-v2 with textarea + counter
  - subject chips (.chip-v2 single-select)
  - tag chips (.chip-v2 multi-select)
  - sticky bottom submit bar (gradient fade so content scrolls under it)
  - unlock-reveal overlay preserved verbatim (it was redesigned in v0.25
    already and the user hasn't flagged it; keep it stable).

  Submit handler + all chip toggle handlers preserved — no TS changes
  beyond exposing `durationMinutes` (number) for the hero.
-->
<view class="complete-page">
  <view class="complete-scroll">

    <!-- Hero: this session — big number, small unit, optional pomodoro chip -->
    <view class="page-pad fade-up complete-hero">
      <text class="complete-hero__eyebrow micro">这次专注了</text>
      <view class="complete-hero__row">
        <text class="complete-hero__num num">{{durationMinutes}}</text>
        <text class="complete-hero__unit">分钟</text>
      </view>
      <view wx:if="{{pomodoroBadgeText}}" class="complete-hero__pomo">
        <text class="complete-hero__pomo-icon">🍅</text>
        <text class="complete-hero__pomo-text">完成 {{pomodoroCycles}} 个番茄</text>
      </view>
    </view>

    <!--
      v0.31 — section order rewritten so the user sees the most
      load-bearing fields FIRST. Subject drives the six-subject grid,
      weekly recap, and calendar day detail — it's the one piece of
      info worth recording even when everything else is skipped.
      Tags second (multi-select, same input idiom). Summary + photos
      drop to the bottom because they're occasional add-ons, not the
      core record. The submit button works with NO fields filled —
      everything stays optional, this is purely visual priority.
    -->

    <!-- Subject (primary): single-select chips. Bigger label, bigger
         chips than the rest of the page. -->
    <view class="page-pad complete-section complete-section--primary">
      <text class="complete-section__label">选科目</text>
      <view class="complete-chips">
        <view
          wx:for="{{subjectChips}}"
          wx:key="value"
          class="chip-v2 {{item.selected ? 'is-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="toggleSubject"
        >{{item.value}}</view>
      </view>
    </view>

    <!-- Tags: multi-select chips -->
    <view class="page-pad complete-section">
      <text class="complete-section__label micro">标签 · 可选</text>
      <view class="complete-chips">
        <view
          wx:for="{{tagChips}}"
          wx:key="value"
          class="chip-v2 {{item.selected ? 'is-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="toggleTag"
        >{{item.value}}</view>
      </view>
    </view>

    <!-- One-line summary: micro label + card with textarea + counter -->
    <view class="page-pad complete-section">
      <text class="complete-section__label micro">一句话总结 · 可选</text>
      <view class="card-v2 complete-summary">
        <textarea
          class="complete-summary__input"
          maxlength="80"
          placeholder="今天主要学了什么？哪里更顺了？"
          value="{{summary}}"
          bindinput="handleSummaryInput"
          auto-height
        />
        <view class="complete-summary__counter">
          <text class="caption num">{{summary.length}} / 80</text>
        </view>
      </view>
    </view>

    <!-- Photo grid: micro label + 3-col grid with dashed add tile -->
    <view class="page-pad complete-section">
      <text class="complete-section__label micro">照片 · 可选 0–3 张</text>
      <view class="complete-photos">
        <view wx:for="{{photos}}" wx:key="objectKey" class="complete-photo">
          <image
            class="complete-photo__img"
            src="{{item.localPath}}"
            mode="aspectFill"
            data-index="{{index}}"
            bindtap="previewPhoto"
          />
          <view class="complete-photo__remove" data-index="{{index}}" catchtap="removePhoto">×</view>
        </view>
        <view wx:if="{{photos.length < 3}}" class="complete-photo-add" bindtap="choosePhotos">
          <text class="complete-photo-add__icon">+</text>
          <text class="complete-photo-add__label">加一张</text>
        </view>
        <!-- v0.30.2 — Trailing spacer keeps the 3-col grid visually
             complete when the user has 0 OR 1 photos. With only the
             0-photos check the 1-photo+add-tile layout left column 3
             empty without filler, which read as "broken row". -->
        <view wx:if="{{photos.length < 2}}" class="complete-photo-spacer"></view>
      </view>
    </view>

    <!-- Spacer so sticky submit bar doesn't cover the last chip row -->
    <view class="complete-bottom-spacer"></view>
  </view>

  <!-- Sticky bottom: gradient fade + full-width primary button -->
  <view class="complete-submit">
    <button
      class="btn-v2 btn-v2--primary complete-submit__btn"
      loading="{{submitting}}"
      disabled="{{submitting}}"
      bindtap="submit"
    >完成打卡</button>
  </view>

  <!--
    v0.25 — Achievement unlock overlay. Preserved from v0.25/v0.26
    verbatim; only the wrapping container class changed (.complete-page
    instead of .page-shell). The unlock-reveal__* tree is internally
    self-contained and was the only part of this page already aligned
    with the new design language.
  -->
  <view wx:if="{{unlockedBadge}}" class="unlock-reveal" bindtap="onTapUnlockDismiss">
    <view class="unlock-reveal__card unlock-reveal__card--{{unlockedBadge.rarity}}" catchtap="onTapUnlockContent">
      <view class="unlock-reveal__halo"></view>
      <view wx:if="{{unlockedBadge.rarity === 'legendary'}}" class="unlock-reveal__crown">👑</view>
      <view wx:elif="{{unlockedBadge.rarity === 'epic'}}" class="unlock-reveal__star">🌟</view>

      <text class="unlock-reveal__eyebrow">🎉 成就解锁</text>
      <image
        wx:if="{{unlockedBadge.imageUrl}}"
        class="unlock-reveal__cat-img"
        src="{{unlockedBadge.imageUrl}}"
        mode="aspectFit"
      />
      <text wx:else class="unlock-reveal__emoji">{{unlockedBadge.icon}}</text>
      <text class="unlock-reveal__name">{{unlockedBadge.name}}</text>
      <text class="unlock-reveal__rarity unlock-reveal__rarity--{{unlockedBadge.rarity}}">{{unlockedBadgeRarityLabel}}</text>
      <text class="unlock-reveal__cond">{{unlockedBadge.description}}</text>

      <view class="unlock-reveal__actions">
        <view class="unlock-reveal__ghost" bindtap="onTapOpenAchievements">去成就墙</view>
        <view class="unlock-reveal__primary" bindtap="onTapUnlockDismiss">继续专注</view>
      </view>
    </view>
  </view>
</view>
