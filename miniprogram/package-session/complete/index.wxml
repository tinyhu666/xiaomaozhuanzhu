<view class="page-shell">
  <view class="hero-card">
    <view class="badge">结束学习</view>
    <view class="title" style="margin-top: 18rpx;">这次专注了 {{durationText}}</view>
    <view wx:if="{{pomodoroBadgeText}}" class="badge" style="margin-top: 14rpx; background: rgba(229, 122, 50, 0.12); color: #b3551a;">{{pomodoroBadgeText}}</view>
    <view class="subtitle">想记的就填几个字 / 拍一张照片，不想填直接提交也行。</view>
  </view>

  <view class="surface-card" style="margin-top: 24rpx;">
    <view class="field-label">学习照片（可选，最多 3 张）</view>
    <view class="photo-grid">
      <view wx:for="{{photos}}" wx:key="objectKey" class="photo-item">
        <image
          src="{{item.localPath}}"
          mode="aspectFill"
          data-index="{{index}}"
          bindtap="previewPhoto"
        />
        <view class="photo-remove" data-index="{{index}}" catchtap="removePhoto">×</view>
      </view>
      <view wx:if="{{photos.length < 3}}" class="photo-picker" bindtap="choosePhotos">
        <view>上传照片</view>
      </view>
    </view>
  </view>

  <view class="surface-card" style="margin-top: 20rpx;">
    <view class="field-label">一句话总结（可选）</view>
    <textarea
      class="textarea-input"
      maxlength="80"
      placeholder="今天主要学了什么？哪里更顺了？"
      value="{{summary}}"
      bindinput="handleSummaryInput"
    />
  </view>

  <!--
    v0.21.3 — restored subject chip picker. Single-select: tapping a
    chip selects it; tapping the active chip clears the selection.
    Picking here (after the session, not before start) avoids the
    URL-encoding round-trip that broke submits in v0.21.2.
  -->
  <view class="surface-card" style="margin-top: 20rpx;">
    <view class="field-label">可选科目</view>
    <view class="tag-list">
      <view
        wx:for="{{subjectChips}}"
        wx:key="value"
        class="tag-chip {{item.selected ? 'is-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="toggleSubject"
      >{{item.value}}</view>
    </view>

    <view class="field-label" style="margin-top: 24rpx;">标签</view>
    <view class="tag-list">
      <view
        wx:for="{{tagChips}}"
        wx:key="value"
        class="tag-chip {{item.selected ? 'is-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="toggleTag"
      >{{item.value}}</view>
    </view>
  </view>

  <button class="cta-button" style="margin-top: 24rpx;" loading="{{submitting}}" bindtap="submit">完成打卡</button>

  <!--
    v0.25 — Achievement unlock overlay. Replaces the per-session
    cat-reveal modal that used to fire after every submit (it felt
    repetitive: 100 sessions = 100 nearly-identical "你又收获了一只
    小猫" pops). Now this only renders when the just-completed
    session actually crossed an achievement threshold — i.e. the
    server set `newlyUnlockedBadge` on the response. Card content
    leans on the achievement's real metadata: breed SVG, name,
    unlock condition, rarity. Big "解锁" eyebrow makes the
    achievement framing unmistakable.
  -->
  <view wx:if="{{unlockedBadge}}" class="unlock-reveal" bindtap="onTapUnlockDismiss">
    <view class="unlock-reveal__card unlock-reveal__card--{{unlockedBadge.rarity}}" catchtap="onTapUnlockContent">
      <view class="unlock-reveal__halo"></view>
      <view wx:if="{{unlockedBadge.rarity === 'legendary'}}" class="unlock-reveal__crown">👑</view>
      <view wx:elif="{{unlockedBadge.rarity === 'epic'}}" class="unlock-reveal__star">🌟</view>

      <text class="unlock-reveal__eyebrow">🎉 成就解锁</text>
      <image
        wx:if="{{unlockedBadge.imageUrl}}"
        class="unlock-reveal__cat-img"
        src="{{unlockedBadge.imageUrl}}"
        mode="aspectFit"
      />
      <text wx:else class="unlock-reveal__emoji">{{unlockedBadge.icon}}</text>
      <text class="unlock-reveal__name">{{unlockedBadge.name}}</text>
      <text class="unlock-reveal__rarity unlock-reveal__rarity--{{unlockedBadge.rarity}}">{{unlockedBadgeRarityLabel}}</text>
      <text class="unlock-reveal__cond">{{unlockedBadge.description}}</text>

      <view class="unlock-reveal__actions">
        <view class="unlock-reveal__ghost" bindtap="onTapOpenAchievements">去成就墙</view>
        <view class="unlock-reveal__primary" bindtap="onTapUnlockDismiss">继续专注</view>
      </view>
    </view>
  </view>
</view>
