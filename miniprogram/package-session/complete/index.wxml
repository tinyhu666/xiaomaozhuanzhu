<view class="page-shell">
  <view class="hero-card">
    <view class="badge">结束学习</view>
    <view class="title" style="margin-top: 18rpx;">这次专注了 {{durationText}}</view>
    <view wx:if="{{pomodoroBadgeText}}" class="badge" style="margin-top: 14rpx; background: rgba(229, 122, 50, 0.12); color: #b3551a;">{{pomodoroBadgeText}}</view>
    <view class="subtitle">拍一张照片，再写一句总结，把今天的努力稳稳记下来。</view>
  </view>

  <view class="surface-card" style="margin-top: 24rpx;">
    <view class="field-label">学习照片（至少 1 张，最多 3 张）</view>
    <view class="photo-grid">
      <view wx:for="{{photos}}" wx:key="objectKey" class="photo-item">
        <image
          src="{{item.localPath}}"
          mode="aspectFill"
          data-index="{{index}}"
          bindtap="previewPhoto"
        />
        <view class="photo-remove" data-index="{{index}}" catchtap="removePhoto">×</view>
      </view>
      <view wx:if="{{photos.length < 3}}" class="photo-picker" bindtap="choosePhotos">
        <view>上传照片</view>
      </view>
    </view>
  </view>

  <view class="surface-card" style="margin-top: 20rpx;">
    <view class="field-label">一句话总结</view>
    <textarea
      class="textarea-input"
      maxlength="80"
      placeholder="今天主要学了什么？哪里更顺了？"
      value="{{summary}}"
      bindinput="handleSummaryInput"
    />
  </view>

  <!--
    v0.18.1 — subject is now selected ONCE on the home page before
    starting; the complete page renders it as a read-only chip so the
    user can confirm what they're submitting without re-picking from
    six options (which is the same decision they already made). If
    no subject was selected on home, we show a "未分类" placeholder
    chip instead of forcing a pick here.
  -->
  <view class="surface-card" style="margin-top: 20rpx;">
    <view class="field-label">科目</view>
    <view class="subject-readonly">
      <text class="subject-readonly__chip {{lockedSubject ? '' : 'is-empty'}}">{{lockedSubject || '未分类'}}</text>
      <text class="subject-readonly__hint">如需修改请回到首页重新开始</text>
    </view>

    <view class="field-label" style="margin-top: 24rpx;">标签</view>
    <view class="tag-list">
      <view
        wx:for="{{tagChips}}"
        wx:key="value"
        class="tag-chip {{item.selected ? 'is-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="toggleTag"
      >{{item.value}}</view>
    </view>
  </view>

  <button class="cta-button" style="margin-top: 24rpx;" loading="{{submitting}}" bindtap="submit">完成打卡</button>

  <!--
    v0.18 — instant cat reveal. After a successful submit, the
    overlay covers the page while the new cat pops in. Tap the
    backdrop or "继续专注" to head home; "去花园看看" navigates to
    the full garden so the user can see their growing collection
    in context.
  -->
  <view wx:if="{{earnedCat}}" class="cat-reveal" bindtap="onTapCatDismiss">
    <view class="cat-reveal__card cat-reveal__card--{{earnedCat.rarity}}" catchtap="onTapCatContent">
      <view class="cat-reveal__halo"></view>
      <view wx:if="{{earnedCat.rarity === 'legendary'}}" class="cat-reveal__crown">👑</view>
      <view wx:elif="{{earnedCat.rarity === 'epic'}}" class="cat-reveal__star">🌟</view>

      <text class="cat-reveal__rarity cat-reveal__rarity--{{earnedCat.rarity}}">{{earnedCatRarityLabel}}</text>
      <text class="cat-reveal__emoji">{{earnedCat.emoji}}</text>
      <text class="cat-reveal__title">收获一只小猫</text>
      <text class="cat-reveal__sub">{{earnedCat.subject}}{{earnedCat.accessory !== "—" ? " · " + earnedCat.accessory : ""}}</text>

      <view class="cat-reveal__actions">
        <view class="cat-reveal__ghost" bindtap="onTapOpenGarden">去花园看看</view>
        <view class="cat-reveal__primary" bindtap="onTapCatDismiss">继续专注</view>
      </view>
    </view>
  </view>
</view>
