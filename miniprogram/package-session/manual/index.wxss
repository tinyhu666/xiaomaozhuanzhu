/* v0.34 — A1 补录. Only the date-picker row needs page-specific style;
   everything else reuses global .surface-card / .tag-chip / etc. */
.manual-page {
  display: flex;
  flex-direction: column;
}

.manual-date {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  background: #f2faf6;
  border: 1rpx solid rgba(46, 169, 133, 0.12);
}

.manual-date__value {
  font-size: 30rpx;
  font-weight: 600;
  color: #21473f;
  font-feature-settings: "tnum" 1;
  font-variant-numeric: tabular-nums;
}

.manual-date__chev {
  font-size: 32rpx;
  /* v0.42.1 — #8fa59c was 2.46:1 on #f2faf6 (below AA). #4F6E66 = 5.27:1,
     still lighter than the date value (#21473f) so the chevron stays sub. */
  color: #4F6E66;
}

/* v0.37 — A3 章节/主题 input. */
.manual-topic-input {
  display: block;
  width: 100%;
  /* v0.44.1 — 同 complete 页：原生 <input> 竖向 padding 无 height 会裁字。
     改显式 height + 横向 padding。 */
  height: 84rpx;
  margin-top: 10rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f2faf6;
  border: 1rpx solid rgba(46, 169, 133, 0.12);
  font-size: 28rpx;
  color: #21473f;
  box-sizing: border-box;
}
